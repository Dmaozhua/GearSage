/* pages/env-test/env-test.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 页面标题 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  color: white;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.9;
}

/* 区块样式 */
.section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.refresh-btn {
  background: #007aff;
  color: white;
  border: none;
}

/* 环境信息 */
.env-info {
  space: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.dev-tool {
  color: #ff6b35;
  background: #fff2f0;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.real-device {
  color: #52c41a;
  background: #f6ffed;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

/* 测试信息 */
.test-info {
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.test-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

/* 按钮组 */
.button-group {
  display: flex;
  gap: 20rpx;
}

.test-btn {
  flex: 1;
  background: #007aff;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.clear-btn {
  flex: 1;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 30rpx;
  background: white;
  color: #666;
}

/* 结果信息 */
.result-info {
  space: 20rpx;
}

.result-status {
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.result-status.success {
  background: #f6ffed;
  color: #52c41a;
  border: 2rpx solid #b7eb8f;
}

.result-status.error {
  background: #fff2f0;
  color: #ff4d4f;
  border: 2rpx solid #ffccc7;
}

.result-message {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.result-data {
  background: #fafafa;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.data-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.data-item:last-child {
  border-bottom: none;
}

.token {
  word-break: break-all;
  max-width: 400rpx;
  font-family: monospace;
  font-size: 24rpx;
  background: #f0f0f0;
  padding: 8rpx;
  border-radius: 6rpx;
}

.error-detail {
  background: #fff2f0;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid #ffccc7;
}

.error-text {
  font-size: 26rpx;
  color: #ff4d4f;
  line-height: 1.5;
  word-break: break-all;
}

/* 说明信息 */
.description {
  background: #f8f9fa;
  padding: 30rpx;
  border-radius: 12rpx;
  border-left: 6rpx solid #007aff;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  white-space: pre-line;
}