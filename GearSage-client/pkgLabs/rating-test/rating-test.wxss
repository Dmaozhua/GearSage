/* pages/rating-test/rating-test.wxss */
.test-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.test-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.test-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 表单项样式 */
.form-item {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.form-label {
  margin-bottom: 20rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.form-picker {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  background-color: #fafafa;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
}

/* 评分区域样式 */
.rating-section {
  background-color: #fff;
  margin-bottom: 30rpx;
  padding: 30rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

/* 操作按钮样式 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.btn-primary {
  background-color: #007aff;
  color: #fff;
}

.btn-primary:active {
  background-color: #0056cc;
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #333;
}

.btn-secondary:active {
  background-color: #e0e0e0;
}

/* 调试信息样式 */
.debug-section {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.debug-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 20rpx;
  border-bottom: 2rpx solid #e0e0e0;
  padding-bottom: 10rpx;
}

.debug-item {
  margin-bottom: 15rpx;
  display: flex;
  align-items: flex-start;
}

.debug-label {
  font-size: 24rpx;
  color: #888;
  min-width: 160rpx;
  margin-right: 20rpx;
}

.debug-value {
  font-size: 24rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
  font-family: 'Courier New', monospace;
}

.debug-value.error {
  color: #ff3b30;
}

/* 响应式适配 */
@media (max-width: 750rpx) {
  .test-container {
    padding: 15rpx;
  }
  
  .form-item,
  .rating-section,
  .debug-section {
    padding: 20rpx;
  }
  
  .test-title {
    font-size: 32rpx;
  }
  
  .section-title {
    font-size: 28rpx;
  }
}

/* 夜间模式适配 */
@media (prefers-color-scheme: dark) {
  .test-container {
    background-color: #1c1c1e;
  }
  
  .form-item,
  .rating-section,
  .debug-section {
    background-color: #2c2c2e;
  }
  
  .test-title,
  .label-text,
  .picker-text,
  .section-title,
  .debug-value {
    color: #fff;
  }
  
  .form-picker {
    background-color: #3a3a3c;
    border-color: #48484a;
  }
  
  .btn-secondary {
    background-color: #3a3a3c;
    color: #fff;
  }
  
  .btn-secondary:active {
    background-color: #48484a;
  }
  
  .debug-title {
    color: #8e8e93;
    border-color: #48484a;
  }
  
  .debug-label {
    color: #8e8e93;
  }
}