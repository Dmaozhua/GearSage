/* pages/text-editor-test/text-editor-test.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.test-section {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.test-item {
  margin-bottom: 40rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
}

.test-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.debug-info {
  margin-top: 40rpx;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid #dee2e6;
}

.debug-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #495057;
  margin-bottom: 15rpx;
}

.debug-item {
  font-size: 24rpx;
  color: #6c757d;
  margin-bottom: 10rpx;
  word-break: break-all;
}