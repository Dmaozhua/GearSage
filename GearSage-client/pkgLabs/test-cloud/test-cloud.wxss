/* pages/test-cloud/test-cloud.wxss */
.container {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header {
  margin-bottom: 40rpx;
  width: 100%;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-container {
  margin-top: 40rpx;
  width: 100%;
  background-color: #f8f8f8;
  padding: 20rpx;
  border-radius: 10rpx;
}

.result-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.result-content {
  font-size: 24rpx;
  color: #666;
  word-break: break-all;
  white-space: pre-wrap;
}