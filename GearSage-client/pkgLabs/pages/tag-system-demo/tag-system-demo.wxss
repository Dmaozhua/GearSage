page {
  background-color: #121212; /* Deep matte black */
  color: #eee;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  padding-bottom: 100rpx;
}

.container {
  padding: 40rpx;
}

.header {
  margin-bottom: 60rpx;
  border-bottom: 1rpx solid #333;
  padding-bottom: 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 800;
  display: block;
  letter-spacing: -1rpx;
  color: #fff;
  text-transform: uppercase;
}

.subtitle {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-top: 10rpx;
  font-family: monospace;
}

.section {
  margin-bottom: 80rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #888;
  margin-bottom: 30rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  border-left: 6rpx solid #d4af37; /* Metallic Gold */
  padding-left: 20rpx;
  display: flex;
  align-items: center;
}

.tag-ladder {
  background: #1a1a1a;
  padding: 30rpx;
  border-radius: 8rpx;
  border: 1rpx solid #333;
}

/* Ladder */
.ladder-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #222;
}
.ladder-row:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.ladder-row .label {
  width: 80rpx;
  font-family: monospace;
  color: #555;
  font-size: 24rpx;
}

/* Context Boxes */
.context-box {
  background: #1a1a1a;
  border: 1rpx solid #333;
  padding: 40rpx;
  margin-bottom: 60rpx;
  border-radius: 4rpx; /* Industrial sharp corners */
  position: relative;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.5);
}

.mock-label {
  position: absolute;
  top: -16rpx;
  right: 20rpx;
  background: #333;
  color: #aaa;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 2rpx;
  text-transform: uppercase;
  border: 1rpx solid #444;
  font-family: monospace;
}

/* Profile Mock */
.profile-header {
  display: flex;
  align-items: center;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  background: #2a2a2a;
  border-radius: 50%;
  margin-right: 30rpx;
  border: 2rpx solid #444;
  position: relative;
}
.avatar::after {
  content: '';
  position: absolute;
  bottom: 0; right: 0;
  width: 20rpx; height: 20rpx;
  background: #4caf50;
  border: 4rpx solid #1a1a1a;
  border-radius: 50%;
}

.info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}
.username {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-right: 16rpx;
  letter-spacing: -0.5rpx;
}
.bio {
  font-size: 26rpx;
  color: #777;
  display: block;
}

/* Feed Mock */
.post-header {
  display: flex;
  align-items: center;
}
.avatar-sm {
  width: 80rpx;
  height: 80rpx;
  background: #2a2a2a;
  border-radius: 50%;
  margin-right: 20rpx;
}
.post-meta {
  flex: 1;
}
.author-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}
.author-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #ddd;
  margin-right: 12rpx;
}
.timestamp {
  font-size: 22rpx;
  color: #555;
  display: block;
}

/* Comment Mock */
.comment-row {
  display: flex;
  align-items: flex-start;
}
.avatar-xs {
  width: 60rpx;
  height: 60rpx;
  background: #2a2a2a;
  border-radius: 50%;
  margin-right: 20rpx;
}
.comment-content {
  flex: 1;
  background: #222;
  padding: 16rpx;
  border-radius: 0 12rpx 12rpx 12rpx;
}
.c-user {
  font-size: 24rpx;
  font-weight: bold;
  color: #bbb;
  margin-right: 12rpx;
}
.c-text {
  font-size: 26rpx;
  color: #ddd;
  display: block;
  margin-top: 8rpx;
  line-height: 1.4;
}
.comment-header {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

/* Shop Mock */
.shop-card {
  display: flex;
  background: #1e1e1e;
  padding: 24rpx;
  border: 1rpx solid #333;
}
.item-img {
  width: 140rpx;
  height: 140rpx;
  background: #252525;
  margin-right: 24rpx;
  border: 1rpx solid #333;
}
.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.item-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}
.item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
