/* pages/debounce-test/debounce-test.wxss */

.test-container {
  padding: 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.test-header {
  text-align: center;
  margin-bottom: 60rpx;
  padding: 40rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.test-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.test-subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.test-section {
  margin-bottom: 40rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #eee;
}

.button-row {
  margin-bottom: 24rpx;
  display: flex;
  gap: 20rpx;
}

.button-row:last-child {
  margin-bottom: 0;
}

.test-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s;
}

.test-btn.primary {
  background-color: #007aff;
  color: #fff;
}

.test-btn.primary:not([disabled]):active {
  background-color: #0056cc;
}

.test-btn.success {
  background-color: #34c759;
  color: #fff;
}

.test-btn.success:not([disabled]):active {
  background-color: #28a745;
}

.test-btn.warning {
  background-color: #ff9500;
  color: #fff;
}

.test-btn.warning:not([disabled]):active {
  background-color: #e6850e;
}

.test-btn.danger {
  background-color: #ff3b30;
  color: #fff;
}

.test-btn.danger:not([disabled]):active {
  background-color: #d70015;
}

.test-btn.info {
  background-color: #5ac8fa;
  color: #fff;
}

.test-btn.info:not([disabled]):active {
  background-color: #32ade6;
}

.test-btn.secondary {
  background-color: #8e8e93;
  color: #fff;
}

.test-btn.secondary:not([disabled]):active {
  background-color: #6d6d72;
}

.test-btn[disabled] {
  opacity: 0.6;
}

.test-btn[loading] {
  opacity: 0.8;
}

/* 测试结果样式 */
.results-container {
  max-height: 600rpx;
  overflow-y: auto;
}

.result-item {
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  border-left: 8rpx solid;
}

.result-item.success {
  background-color: #f0f9ff;
  border-left-color: #34c759;
}

.result-item.error {
  background-color: #fff5f5;
  border-left-color: #ff3b30;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.result-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.result-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #fff;
}

.result-item.success .result-status {
  background-color: #34c759;
}

.result-item.error .result-status {
  background-color: #ff3b30;
}

.result-time {
  font-size: 24rpx;
  color: #999;
}

.result-message {
  font-size: 28rpx;
  color: #666;
  line-height: 1.4;
}

/* 状态显示样式 */
.status-container {
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
}

.status-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eee;
}

.status-item:last-child {
  border-bottom: none;
}

.status-key {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.status-value {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #fff;
}

.status-value.active {
  background-color: #ff9500;
}

.status-value.inactive {
  background-color: #8e8e93;
}

.status-empty {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  width: 100%;
}

/* 组件按钮自定义样式 */
.button-row debounce-button {
  width: 100%;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .test-container {
    padding: 20rpx;
  }
  
  .test-header {
    padding: 30rpx;
  }
  
  .test-title {
    font-size: 40rpx;
  }
  
  .test-subtitle {
    font-size: 24rpx;
  }
  
  .section-title {
    font-size: 32rpx;
  }
  
  .test-btn {
    height: 80rpx;
    font-size: 28rpx;
  }
}

/* 滚动条样式 */
.results-container::-webkit-scrollbar {
  width: 6rpx;
}

.results-container::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 6rpx;
}

.results-container::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 6rpx;
}

.results-container::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}