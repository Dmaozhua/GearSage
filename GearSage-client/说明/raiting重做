### JavaScript逻辑
```javascript
Component({
  properties: {
    // 初始评分值
    value: {
      type: Number,
      value: null // 默认为空
    },
    // 是否显示分数文字
    showScore: {
      type: Boolean,
      value: true
    },
    // 是否禁用交互
    disabled: {
      type: Boolean,
      value: false
    }
  },

  data: {
    currentRating: 0, // 当前评分
    ratingWidth: 0,   // 前景星星宽度百分比
    startX: 0         // 滑动起始位置
  },

  observers: {
    'value': function(val) {
      if (val !== this.data.currentRating) {
        this.updateRating(val, false);
      }
    }
  },

  methods: {
    // 初始化评分显示
    updateRating: function(rating, triggerEvent = true) {
      const width = rating ? (rating / 5) * 100 : 0;
      
      this.setData({
        currentRating: rating,
        ratingWidth: width
      });

      if (triggerEvent) {
        this.triggerEvent('change', { rating });
      }
    },

    // 点击事件处理
    handleTap: function(e) {
      if (this.data.disabled) return;
      
      const { offsetX } = e.detail;
      const starWidth = this.data.starWidth || 80; // 单颗星星宽度
      const clickedPosition = offsetX / starWidth;
      const rating = Math.ceil(clickedPosition * 2) / 2; // 转换为0.5的倍数
      
      this.updateRating(Math.min(5, Math.max(0, rating)));
    },

    // 触摸开始事件
    handleTouchStart: function(e) {
      if (this.data.disabled) return;
      
      this.setData({
        startX: e.touches[0].pageX
      });
    },

    // 触摸移动事件
    handleTouchMove: function(e) {
      if (this.data.disabled) return;
      
      const { pageX } = e.touches[0];
      const moveX = pageX - this.data.startX;
      const starWidth = this.data.starWidth || 80;
      const containerLeft = this.data.containerLeft || 0;
      
      // 计算相对容器左侧的位置
      const relativeX = pageX - containerLeft;
      const rating = Math.ceil((relativeX / starWidth) * 2) / 2;
      
      this.updateRating(Math.min(5, Math.max(0, rating)), false);
    },

    // 触摸结束事件
    handleTouchEnd: function() {
      if (this.data.disabled) return;
      
      this.triggerEvent('change', { rating: this.data.currentRating });
    },

    // 获取组件布局信息
    getContainerRect: function() {
      const query = this.createSelectorQuery();
      query.select('.stars-wrapper').boundingClientRect(rect => {
        if (rect) {
          this.setData({
            starWidth: rect.width / 5, // 单颗星星宽度
            containerLeft: rect.left
          });
        }
      }).exec();
    }
  },

  ready: function() {
    // 组件初始化
    this.updateRating(this.data.value !== null ? this.data.value : 0, false);
    this.getContainerRect();
  }
})
```

