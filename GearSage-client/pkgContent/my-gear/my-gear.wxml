<custom-navbar title="我的装备" show-back="{{true}}"></custom-navbar>

<view class="my-gear-page {{isDarkMode ? 'dark' : ''}}" style="padding-top: {{navBarHeight}}px;">
  <view class="my-gear-header">
    <view>
      <text class="my-gear-title">{{activePanel === 'sets' ? '我的搭配' : '我的装备'}}</text>
      <text class="my-gear-summary">{{activePanel === 'sets' ? setSummaryText : summaryText}}</text>
    </view>
    <button class="add-btn" wx:if="{{activePanel === 'sets'}}" bindtap="onAddSet">新建搭配</button>
    <button class="add-btn" wx:else bindtap="onAddGear">添加装备</button>
  </view>

  <view class="panel-tabs">
    <view class="panel-tab {{activePanel === 'gear' ? 'active' : ''}}" data-panel="gear" bindtap="onPanelChange">装备</view>
    <view class="panel-tab {{activePanel === 'sets' ? 'active' : ''}}" data-panel="sets" bindtap="onPanelChange">我的搭配</view>
  </view>

  <view class="tab-row" wx:if="{{activePanel === 'gear'}}">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-item {{activeType === item.key ? 'active' : ''}}"
      data-type="{{item.key}}"
      bindtap="onTabChange"
    >
      <text>{{item.label}}</text>
      <text class="tab-count">{{item.count}}</text>
    </view>
  </view>

  <view class="page-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="empty-state" wx:elif="{{activePanel === 'gear' && !visibleItems.length}}">
    <text class="empty-title">{{emptyText}}</text>
    <text class="empty-desc">从装备库添加你正在用的鱼轮、鱼竿和常用饵。</text>
    <button class="empty-btn" bindtap="onAddGear">去添加</button>
  </view>

  <view class="empty-state" wx:elif="{{activePanel === 'sets' && !gearSets.length}}">
    <text class="empty-title">还没有搭配</text>
    <text class="empty-desc">先把常用鱼竿、渔轮、鱼饵添加到我的装备，再组合成常用搭配。</text>
    <button class="empty-btn" bindtap="onAddSet">新建搭配</button>
  </view>

  <view class="gear-list" wx:elif="{{activePanel === 'gear'}}">
    <view class="gear-item" wx:for="{{visibleItems}}" wx:key="id">
      <image class="gear-image" src="{{item.imageUrl || '/images/empty.png'}}" mode="aspectFill"></image>
      <view class="gear-main">
        <view class="gear-name">{{item.displayName}}</view>
        <view class="gear-meta">
          <text>{{item.typeLabel}}</text>
          <text>{{item.ownershipText}}</text>
          <text>{{item.usageStatusText}}</text>
        </view>
        <view class="gear-sub" wx:if="{{item.brandName || item.variantLabel}}">
          {{item.brandName}}{{item.variantLabel ? '｜' + item.variantLabel : ''}}
        </view>
        <view class="gear-note" wx:if="{{item.notePreview}}">备注：{{item.notePreview}}</view>
      </view>
      <view class="gear-actions">
        <button class="icon-btn" data-id="{{item.id}}" bindtap="onEditGear">编辑</button>
        <button class="icon-btn danger" data-id="{{item.id}}" bindtap="onDeleteGear">删除</button>
      </view>
    </view>
  </view>

  <view class="set-list" wx:else>
    <view class="set-item" wx:for="{{gearSets}}" wx:key="id">
      <view class="set-main">
        <view class="set-title-row">
          <text class="set-name">{{item.name}}</text>
          <text class="set-public {{item.profileDisplayStatus}}">{{item.profileStatusText}}</text>
        </view>
        <view class="set-note" wx:if="{{item.profileBlockedText}}">展示异常：{{item.profileBlockedText}}</view>
        <view class="set-meta" wx:if="{{item.metaText}}">{{item.metaText}}</view>
        <view class="set-lures" wx:if="{{item.lureText}}">常用饵：{{item.lureText}}</view>
        <view class="set-tags" wx:if="{{item.tagText}}">{{item.tagText}}</view>
        <view class="set-note" wx:if="{{item.notePreview}}">备注：{{item.notePreview}}</view>
      </view>
      <view class="gear-actions">
        <button class="icon-btn" data-id="{{item.id}}" bindtap="onEditSet">编辑</button>
        <button class="icon-btn" data-id="{{item.id}}" bindtap="onToggleSetProfile">{{item.showOnProfile ? '取消主页展示' : '展示到主页'}}</button>
        <button class="icon-btn danger" data-id="{{item.id}}" bindtap="onDeleteSet">删除</button>
      </view>
    </view>
  </view>
</view>
