@import "/styles/dark.wxss";

page {
  background: #f3f5f1;
}

.my-gear-page {
  min-height: 100vh;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 48rpx;
  box-sizing: border-box;
  background: #f3f5f1;
  color: #1f2a27;
}

.my-gear-page.dark {
  background: #10161a;
  color: #edf4ef;
}

.my-gear-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 0 18rpx;
}

.my-gear-title,
.my-gear-summary {
  display: block;
}

.my-gear-title {
  font-size: 38rpx;
  line-height: 1.3;
  font-weight: 700;
}

.my-gear-summary {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #68716b;
}

.dark .my-gear-summary {
  color: rgba(237, 244, 239, 0.64);
}

.add-btn,
.empty-btn {
  min-height: 64rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 8rpx;
  background: #33483e;
  color: #fff;
  font-size: 24rpx;
  line-height: 64rpx;
}

.tab-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.tab-item {
  padding: 18rpx 12rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(64, 77, 69, 0.12);
  background: rgba(255, 255, 255, 0.72);
  color: #58645d;
  text-align: center;
  font-size: 24rpx;
}

.tab-item.active {
  border-color: rgba(51, 72, 62, 0.28);
  background: #e6ece5;
  color: #25372f;
  font-weight: 700;
}

.tab-count {
  margin-left: 8rpx;
  color: #7a837c;
}

.page-state,
.empty-state {
  padding: 84rpx 24rpx;
  text-align: center;
  color: #69736d;
}

.empty-title,
.empty-desc {
  display: block;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #28352f;
}

.empty-desc {
  margin: 14rpx 0 26rpx;
  font-size: 24rpx;
  line-height: 1.7;
}

.gear-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.gear-item {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr);
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(64, 77, 69, 0.1);
}

.dark .gear-item,
.dark .tab-item {
  background: rgba(238, 245, 242, 0.07);
  border-color: rgba(238, 245, 242, 0.1);
}

.gear-image {
  width: 112rpx;
  height: 112rpx;
  border-radius: 8rpx;
  background: #e8ece8;
}

.gear-main {
  min-width: 0;
}

.gear-name {
  font-size: 29rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #1e2d27;
}

.dark .gear-name,
.dark .empty-title {
  color: #edf4ef;
}

.gear-meta,
.gear-sub,
.gear-note {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #6d776f;
}

.gear-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.gear-actions {
  grid-column: 1 / -1;
  display: flex;
  gap: 12rpx;
  padding-top: 6rpx;
}

.icon-btn {
  flex: 1;
  min-height: 56rpx;
  margin: 0;
  padding: 0 12rpx;
  border-radius: 8rpx;
  background: #edf1ec;
  color: #30443b;
  font-size: 22rpx;
  line-height: 56rpx;
}

.icon-btn.danger {
  color: #8f4d42;
}
