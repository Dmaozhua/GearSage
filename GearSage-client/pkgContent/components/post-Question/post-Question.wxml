<view class="post-question-container {{isDarkMode ? 'dark' : ''}}">
  <view class="step-content">
    <view class="form-item">
      <view class="form-label">
        <text>选择类型</text>
        <text class="required">*</text>
      </view>
      <view class="control-group">
        <label
          class="control control--radio {{formData.questionType === item.id ? 'checked' : ''}}"
          wx:for="{{typeOptions}}"
          wx:key="id"
          data-value="{{item.id}}"
          bindtap="onQuestionTypeSelect"
        >
          <view class="control__indicator"></view>
          {{item.label}}
        </label>
      </view>
      <view class="error-text" wx:if="{{errors.questionType}}">{{errors.questionType}}</view>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text>关联装备</text>
        <text class="{{formData.questionType === 'recommend' ? 'required' : 'optional'}}">{{formData.questionType === 'recommend' ? '*' : '（选填）'}}</text>
      </view>
      <view class="control-group">
        <label
          class="control control--radio {{formData.relatedGearCategory === item.id ? 'checked' : ''}}"
          wx:for="{{gearCategoryOptions}}"
          wx:key="id"
          data-value="{{item.id}}"
          bindtap="onRelatedGearCategorySelect"
        >
          <view class="control__indicator"></view>
          {{item.label}}
        </label>
      </view>
      <view class="gear-model-block" wx:if="{{canSelectGearModel}}">
        <view class="gear-model-input-wrap">
          <input
            class="gear-model-input"
            placeholder="{{gearModelPlaceholder}}"
            value="{{formData.relatedGearModel}}"
            bindinput="onGearModelInput"
            bindfocus="onGearModelFocus"
            bindblur="onGearModelBlur"
            maxlength="60"
          />
          <view class="gear-model-dropdown" wx:if="{{showGearModelOptions}}">
            <view class="gear-model-option" wx:for="{{gearModelOptions}}" wx:key="id" data-name="{{item.name}}" data-source-id="{{item.sourceId}}" bindtap="onGearModelSelect">{{item.name}}</view>
            <view class="gear-model-empty" wx:if="{{gearModelOptions.length === 0}}">暂无匹配装备</view>
          </view>
        </view>
      </view>
      <view class="form-tip" wx:if="{{canSelectGearModel}}">{{gearModelTip}}</view>
      <view class="form-tip" wx:if="{{formData.relatedGearCategory && !canSelectGearModel}}">当前装备库联想暂支持鱼竿、渔轮、鱼饵、鱼线、钩子/配件</view>
      <view class="error-text" wx:if="{{errors.relatedGearCategory}}">{{errors.relatedGearCategory}}</view>
    </view>

    <block wx:if="{{formData.questionType === 'recommend'}}">
      <view class="form-item">
        <view class="recommend-section-title">楼主当前情况</view>
        <view class="recommend-section-subtitle">先把关键条件说清楚，后面的推荐才不会跑偏。</view>
      </view>

      <view class="form-item">
        <view class="form-label">
          <text>你现在更接近哪种情况</text>
          <text class="required">*</text>
        </view>
        <view class="option-flow">
          <view
            wx:for="{{recommendIntentOptions}}"
            wx:key="id"
            class="option-chip {{formData.recommendMeta.recommendIntent === item.id ? 'active' : ''}}"
            data-field="recommendIntent"
            data-value="{{item.id}}"
            bindtap="onRecommendSingleSelect"
          >
            {{item.label}}
          </view>
        </view>
        <view class="error-text" wx:if="{{errors.recommendIntent}}">{{errors.recommendIntent}}</view>
      </view>

      <view class="form-item">
        <view class="form-label">
          <text>预算大概多少</text>
          <text class="required">*</text>
        </view>
        <view class="option-flow">
          <view
            wx:for="{{budgetRangeOptions}}"
            wx:key="id"
            class="option-chip {{formData.recommendMeta.budgetRange === item.id ? 'active' : ''}}"
            data-field="budgetRange"
            data-value="{{item.id}}"
            bindtap="onRecommendSingleSelect"
          >
            {{item.label}}
          </view>
        </view>
        <view class="error-text" wx:if="{{errors.budgetRange}}">{{errors.budgetRange}}</view>
      </view>

      <view class="form-item">
        <view class="form-label">
          <text>预算弹性</text>
          <text class="optional">（选填）</text>
        </view>
        <view class="option-flow">
          <view
            wx:for="{{budgetFlexibleOptions}}"
            wx:key="id"
            class="option-chip {{formData.recommendMeta.budgetFlexible === item.id ? 'active' : ''}}"
            data-field="budgetFlexible"
            data-value="{{item.id}}"
            bindtap="onRecommendSingleSelect"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">
          <text>主要钓什么鱼</text>
          <text class="required">*</text>
        </view>
        <view class="option-flow">
          <view
            wx:for="{{targetFishOptions}}"
            wx:key="id"
            class="option-chip {{item.selected ? 'active' : ''}}"
            data-field="targetFish"
            data-value="{{item.id}}"
            data-max="3"
            bindtap="onRecommendMultiSelect"
          >
            {{item.label}}
          </view>
        </view>
        <view class="form-tip">最多 3 个</view>
        <view class="error-text" wx:if="{{errors.targetFish}}">{{errors.targetFish}}</view>
      </view>

      <view class="form-item">
        <view class="form-label">
          <text>常在哪钓</text>
          <text class="required">*</text>
        </view>
        <view class="option-flow">
          <view
            wx:for="{{useSceneOptions}}"
            wx:key="id"
            class="option-chip {{item.selected ? 'active' : ''}}"
            data-field="useScene"
            data-value="{{item.id}}"
            data-max="2"
            bindtap="onRecommendMultiSelect"
          >
            {{item.label}}
          </view>
        </view>
        <view class="form-tip">最多 2 个</view>
        <view class="error-text" wx:if="{{errors.useScene}}">{{errors.useScene}}</view>
      </view>

      <view class="form-item">
        <view class="form-label">
          <text>你最在意什么</text>
          <text class="required">*</text>
        </view>
        <view class="option-flow">
          <view
            wx:for="{{carePriorityOptions}}"
            wx:key="id"
            class="option-chip {{item.selected ? 'active' : ''}}"
            data-field="carePriorities"
            data-value="{{item.id}}"
            data-max="3"
            bindtap="onRecommendMultiSelect"
          >
            {{item.label}}
          </view>
        </view>
        <view class="form-tip">最多 3 个</view>
        <view class="error-text" wx:if="{{errors.carePriorities}}">{{errors.carePriorities}}</view>
      </view>

      <view class="form-item">
        <view class="form-label">
          <text>不想要的点</text>
          <text class="optional">（选填）</text>
        </view>
        <view class="option-flow">
          <view
            wx:for="{{avoidPointOptions}}"
            wx:key="id"
            class="option-chip {{item.selected ? 'active' : ''}}"
            data-field="avoidPoints"
            data-value="{{item.id}}"
            data-max="3"
            bindtap="onRecommendMultiSelect"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">
          <text>已有装备</text>
          <text class="optional">（选填）</text>
        </view>
        <input
          class="text-input"
          data-field="currentGear"
          value="{{formData.recommendMeta.currentGear}}"
          maxlength="80"
          placeholder="已有装备可简单写，如“ML竿 + 1000纺车轮”"
          bindinput="onRecommendInput"
        />
        <view class="field-action-row">
          <view class="field-action" bindtap="onOpenUserGearSelector">从我的装备选择</view>
          <view class="field-action-note" wx:if="{{formData.recommendMeta.currentGearItems.length}}">
            已选 {{formData.recommendMeta.currentGearItems.length}} 件
          </view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">
          <text>使用频率</text>
          <text class="optional">（选填）</text>
        </view>
        <view class="option-flow">
          <view
            wx:for="{{recommendUsageFrequencyOptions}}"
            wx:key="id"
            class="option-chip {{formData.recommendMeta.usageFrequency === item.id ? 'active' : ''}}"
            data-field="usageFrequency"
            data-value="{{item.id}}"
            bindtap="onRecommendSingleSelect"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">
          <text>有没有候选项</text>
          <text class="optional">（选填，最多 3 个）</text>
        </view>
        <view class="candidate-list">
          <input
            wx:for="{{formData.recommendMeta.candidateOptions}}"
            wx:key="index"
            class="text-input"
            data-index="{{index}}"
            value="{{item}}"
            maxlength="40"
            placeholder="候选项 {{index + 1}}，可写型号或方向"
            bindinput="onCandidateOptionInput"
          />
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">
          <text>你最纠结的点是什么</text>
          <text class="required">*</text>
        </view>
        <textarea
          class="textarea-input"
          data-field="coreQuestion"
          value="{{formData.recommendMeta.coreQuestion}}"
          maxlength="120"
          placeholder="比如：第一次买轮，怕买重了；或者 A / B 两个型号不知道差价值不值。"
          bindinput="onRecommendInput"
        />
        <view class="form-tip-row">
          <view class="form-tip">10 ~ 120 字</view>
          <view class="form-tip form-tip--count">{{coreQuestionLength}} / 120</view>
        </view>
        <view class="error-text" wx:if="{{errors.coreQuestion}}">{{errors.coreQuestion}}</view>
      </view>
    </block>

    <view class="form-item">
      <view class="form-label">
        <text>{{formData.questionType === 'recommend' ? '补充说明' : '填写内容'}}</text>
        <text class="{{formData.questionType === 'recommend' ? 'optional' : 'required'}}">{{formData.questionType === 'recommend' ? '（选填）' : '*'}}</text>
      </view>
      <view class="wechat-content-container">
        <publish-wechatcontent
          formData="{{formData}}"
          errors="{{errors}}"
          maxImages="{{maxImages}}"
          minImages="{{0}}"
          maxTitleLength="{{maxTitleLength}}"
          maxContentLength="{{maxContentLength}}"
          titlePlaceholder="{{titlePlaceholder}}"
          contentPlaceholder="{{contentPlaceholder}}"
          writingTips="{{writingTips}}"
          bind:titleinput="onTitleInput"
          bind:maincontentinput="onMainContentInput"
          bind:previewimage="onPreviewImage"
          bind:deleteimage="onDeleteImage"
          bind:chooseimage="onChooseImage"
        />
      </view>
      <view class="form-tip">
        {{formData.questionType === 'recommend'
          ? '标题可留空，系统会按预算 / 场景 / 装备帮你生成。图片非必填，最多 3 张。'
          : '图片非必填，最多可上传9张'}}
      </view>
      <view class="error-text" wx:if="{{errors.mainImages}}">{{errors.mainImages}}</view>
    </view>

    <view class="form-item">
      <view class="switch-card">
        <view class="switch-copy">
          <view class="switch-title-row">
            <text class="switch-title">快速回答</text>
            <text class="optional">（选填）</text>
          </view>
          <view class="switch-status {{formData.quickReplyOnly ? 'active' : ''}}">
            当前状态：{{formData.quickReplyOnly ? '已开启' : '未开启'}}
          </view>
          <view class="switch-desc">如果希望到其他钓友直接回复结论，如：选A或者选B，无需解释，请开关。关闭则无特殊需求。</view>
        </view>
        <view class="switch-container">
          <switch checked="{{formData.quickReplyOnly}}" bindchange="onQuickReplyChange" color="#2c5aa0" />
        </view>
      </view>
    </view>
  </view>

  <root-portal>
    <view class="bottom-buttons">
      <button class="btn btn-primary" bindtap="onSubmit">发布</button>
    </view>
  </root-portal>

  <view class="selector-mask" wx:if="{{showUserGearSelector}}" catchtap="onCloseUserGearSelector">
    <view class="selector-panel" catchtap="noop">
      <view class="selector-head">
        <text class="selector-title">从我的装备选择</text>
        <text class="selector-close" bindtap="onCloseUserGearSelector">关闭</text>
      </view>
      <view class="selector-tip">最多选择 5 件，选中后会写入“已有装备”，你仍然可以手动修改文案。</view>
      <view class="selector-state" wx:if="{{userGearLoading}}">加载中...</view>
      <scroll-view scroll-y class="selector-list" wx:else>
        <view class="selector-empty" wx:if="{{!userGearItems.length}}">还没有添加我的装备</view>
        <view
          wx:for="{{userGearItems}}"
          wx:key="id"
          class="selector-item {{item.selected ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onToggleUserGearSelect"
        >
          <view class="selector-item-main">
            <text class="selector-item-name">{{item.displayName}}</text>
            <text class="selector-item-meta">{{item.typeLabel}}｜{{item.usageStatusText}}{{item.variantLabel ? '｜' + item.variantLabel : ''}}</text>
          </view>
          <text class="selector-check">{{item.selected ? '已选' : '选择'}}</text>
        </view>
      </scroll-view>
      <button class="selector-confirm" bindtap="onApplyUserGearSelection">写入已有装备</button>
    </view>
  </view>
</view>
