/* pages/search/search.wxss */
.search-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 搜索框样式 */
.search-input-container {
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #e5e5e5;
}

.search-input-box {
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  position: relative;
}

.search-icon {
  font-size: 32rpx;
  color: #999;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  background: transparent;
}

.clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background-color: #ccc;
  margin-left: 16rpx;
}

.clear-icon {
  font-size: 24rpx;
  color: #fff;
  line-height: 1;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e5e5e5;
  border-top: 4rpx solid #007aff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 搜索结果 */
.search-results {
  background-color: #fff;
  margin-top: 20rpx;
}

.results-header {
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.results-count {
  font-size: 28rpx;
  color: #666;
}

.results-list {
  padding: 0 30rpx;
}

.result-item {
  display: flex;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.result-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.result-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.result-description {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.result-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.result-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff6b35;
}

.result-rating {
  display: flex;
  align-items: center;
}

.rating-star {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.rating-score {
  font-size: 26rpx;
  color: #666;
}

/* 空结果 */
.empty-results {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-subtitle {
  font-size: 26rpx;
  color: #999;
}

/* 搜索历史 */
.search-history {
  padding: 20rpx 30rpx;
}

.history-section {
  margin-bottom: 40rpx;
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.history-title,
.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.clear-history {
  font-size: 26rpx;
  color: #999;
  padding: 8rpx 16rpx;
}

.history-tags,
.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag,
.hot-tag {
  padding: 16rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 24rpx;
  transition: background-color 0.3s;
}

.history-tag:active,
.hot-tag:active {
  background-color: #e5e5e5;
}

.hot-tag {
  background-color: #fff;
  border: 1rpx solid #e5e5e5;
}

.hot-tag:active {
  background-color: #f5f5f5;
}

.tag-text {
  font-size: 26rpx;
  color: #666;
}

.hot-search-section {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-top: 20rpx;
}

.section-title {
  margin-bottom: 20rpx;
}