.like-btn.active .bottom-btn-text {
  color: #1b6bcf;
}

.bottom-btn--disabled {
  opacity: 0.56;
}

.bottom-btn--disabled .bottom-btn-text {
  color: #90a0af;
}

.share-native-trigger {
  position: absolute;
  inset: 0;
  z-index: 2;
  padding: 0;
  margin: 0;
  opacity: 0;
  background: transparent;
  border: none;
}

.share-native-trigger::after {
  border: none;
}

