@import '/styles/dark.wxss';

.container {
  background:
    radial-gradient(circle at top, rgba(31, 118, 219, 0.14), transparent 28%),
    linear-gradient(180deg, #f4f7fb 0%, #edf2f7 100%);
  min-height: 100vh;
}

.topic-page {
  padding-bottom: 160rpx;
}

.topic-page--editing {
  padding-bottom: 260rpx;
}

.topic-layout {
  padding: 24rpx 20rpx 0;
}

.topic-hero-card,
.topic-section-card,
.comments-section {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 30rpx;
  box-shadow: 0 20rpx 46rpx rgba(24, 39, 64, 0.1);
}

.topic-hero-card,
.topic-section-card {
  margin-bottom: 20rpx;
}

.topic-hero-card {
  padding: 30rpx;
}

.topic-hero-card--experience {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 248, 255, 0.98));
}

.topic-kicker {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #e7f0ff;
  color: #215ea8;
  font-size: 22rpx;
  margin-bottom: 18rpx;
}

.topic-title {
  font-size: 42rpx;
  line-height: 1.38;
  font-weight: 700;
  color: #122236;
}

.topic-subtitle {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #607286;
}

.topic-subtitle--link {
  color: #245d97;
}

.topic-subtitle--link::after {
  content: '查看装备详情';
  display: inline-block;
  margin-left: 12rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(36, 93, 151, 0.1);
  font-size: 20rpx;
  line-height: 1.5;
  color: #245d97;
  vertical-align: middle;
}

.topic-author-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 18rpx;
}

.topic-author-card--strong {
  margin-top: 22rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(18, 34, 54, 0.04);
}

.topic-author-card--medium,
.topic-author-card--light {
  margin-top: 16rpx;
}

.topic-author-card--light {
  opacity: 0.94;
}

.topic-author-card--medium {
  opacity: 0.97;
}

.topic-author-card--mini {
  margin-top: 14rpx;
  opacity: 0.92;
}

.topic-author-card--micro {
  margin-top: 16rpx;
  opacity: 0.78;
}

.topic-author-card--strong .topic-author-name {
  font-size: 28rpx;
}

.topic-author-card--light .topic-author-name,
.topic-author-card--medium .topic-author-name {
  font-size: 25rpx;
}

.topic-author-card--mini .topic-author-name {
  font-size: 24rpx;
}

.topic-author-card--micro .topic-author-name {
  font-size: 22rpx;
  font-weight: 500;
}

.topic-author-card--mini .topic-author-tags,
.topic-author-card--micro .topic-author-tags {
  margin-top: 4rpx;
}

.topic-author-card--micro .topic-author-head {
  gap: 8rpx;
}

.topic-author-avatar {
  border-radius: 50%;
  background: #edf2f7;
  flex-shrink: 0;
}

.topic-author-avatar--md {
  width: 74rpx;
  height: 74rpx;
}

.topic-author-avatar--sm {
  width: 60rpx;
  height: 60rpx;
}

.topic-author-avatar--xs {
  width: 48rpx;
  height: 48rpx;
}

.topic-author-avatar--xxs {
  width: 40rpx;
  height: 40rpx;
}

.topic-author-body {
  min-width: 0;
  flex: 1;
}

.topic-author-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.topic-author-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #223247;
}

.topic-author-time {
  font-size: 22rpx;
  color: #8b9aab;
}

.topic-author-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 6rpx;
}

.topic-author-meta-line {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: #6f8194;
}

.topic-author-tag {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #eef4fb;
  color: #4b627d;
  font-size: 20rpx;
}

.topic-author-tag--light,
.topic-author-tag--mini {
  font-size: 18rpx;
  min-height: 30rpx;
  padding: 0 10rpx;
}

.topic-author-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 22rpx;
}

.topic-author-meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.user-avatar-sm {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.user-name-sm {
  font-size: 26rpx;
  font-weight: 600;
  color: #223247;
}

.topic-time {
  font-size: 22rpx;
  color: #8090a3;
}

.topic-summary-card {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #122236, #24486d);
  color: #f7fbff;
  font-size: 30rpx;
  line-height: 1.65;
}

.topic-chip-row,
.topic-header-stack {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.topic-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #edf4fb;
  color: #47617f;
  font-size: 22rpx;
}

.topic-chip--warm {
  background: #fff1de;
  color: #b06b14;
}

.topic-chip--sky {
  background: #e8f4ff;
  color: #1668c6;
}

.topic-chip--dark {
  background: #132741;
  color: #fff;
}

.topic-chip--accept {
  background: rgba(187, 131, 46, 0.14);
  color: #95631b;
}

.topic-section-card {
  padding: 26rpx;
}

.topic-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #16283d;
  margin-bottom: 20rpx;
}

.topic-info-grid,
.topic-conclusion-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.topic-conclusion-grid {
  margin-top: 20rpx;
}

.topic-info-item,
.topic-conclusion-item,
.topic-boundary-card {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f5f8fb;
}

.topic-info-item--full,
.topic-conclusion-item--full {
  grid-column: 1 / -1;
}

.topic-info-label {
  display: block;
  font-size: 22rpx;
  color: #7a8c9f;
  margin-bottom: 8rpx;
}

.topic-info-value,
.topic-boundary-text {
  font-size: 27rpx;
  line-height: 1.6;
  color: #223247;
}

.topic-info-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.topic-info-tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 14rpx;
  background: linear-gradient(180deg, rgba(239, 245, 252, 0.98), rgba(229, 238, 248, 0.98));
  border: 1rpx solid rgba(176, 194, 214, 0.72);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  line-height: 1.4;
  color: #39506b;
}

.topic-boundary-note {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6b7d91;
  white-space: pre-line;
}

.topic-score-strip {
  margin-top: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: #eaf4ff;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.topic-score-strip__label {
  font-size: 24rpx;
  color: #4e6b8c;
}

.topic-score-strip__value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1668c6;
}

.topic-rating-chart {
  margin-top: 20rpx;
}

.rating-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.rating-label {
  width: 132rpx;
  font-size: 24rpx;
  color: #607286;
}

.rating-bar-bg {
  flex: 1;
  height: 12rpx;
  border-radius: 999rpx;
  background: #e3ebf4;
  overflow: hidden;
}

.rating-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1c6bd1, #61b0ff);
}

.rating-score {
  width: 48rpx;
  text-align: right;
  font-size: 24rpx;
  color: #223247;
}

.topic-boundary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.topic-boundary-title {
  display: block;
  font-size: 22rpx;
  color: #7a8c9f;
  margin-bottom: 10rpx;
}

.topic-richtext {
  font-size: 30rpx;
  line-height: 1.8;
  color: #223247;
}

.topic-gallery {
  padding: 0 20rpx;
}

.topic-gallery__image {
  width: 100%;
  display: block;
  margin-bottom: 18rpx;
  border-radius: 24rpx;
}

.comments-section {
  margin: 20rpx;
  margin-bottom: 160rpx;
  padding: 26rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #16283d;
  margin-bottom: 18rpx;
}

.comment-disabled-note {
  margin-bottom: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: #f4f7fa;
  color: #6d7f91;
  font-size: 24rpx;
  line-height: 1.6;
}

.comment-subsection + .comment-subsection {
  margin-top: 28rpx;
}

.comment-accepted-note {
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #f7f4ee;
  color: #7a6f5e;
  font-size: 23rpx;
  line-height: 1.6;
}

.comment-subsection__title {
  margin-bottom: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #38516c;
}

.comment-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf1f5;
}

.comment-item--accepted {
  border-bottom: none;
}

.comment-item:last-child,
.reply-item:last-child {
  border-bottom: none;
}

.comment-content,
.reply-content {
  flex: 1;
  min-width: 0;
}

.comment-avatar,
.reply-avatar {
  border-radius: 50%;
  background: #edf2f7;
}

.comment-avatar {
  width: 70rpx;
  height: 70rpx;
  margin-right: 18rpx;
}

.reply-avatar {
  width: 50rpx;
  height: 50rpx;
  margin-right: 14rpx;
}

.comment-user,
.reply-user {
  font-weight: 600;
  color: #223247;
}

.comment-user-row,
.reply-user-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.comment-user {
  font-size: 28rpx;
  margin-bottom: 0;
}

.reply-user {
  font-size: 24rpx;
  margin-bottom: 0;
}

.comment-user-row {
  margin-bottom: 8rpx;
}

.comment-user-meta {
  margin-bottom: 12rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #6e8196;
}

.reply-user-row {
  margin-bottom: 6rpx;
}

.comment-user-tag,
.reply-user-tag {
  flex-shrink: 0;
  max-width: 100%;
}

.comment-text,
.reply-text {
  color: #516479;
  line-height: 1.7;
}

.comment-text {
  font-size: 27rpx;
}

.answer-template-card {
  margin-top: 8rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f5f8fc, #eef4fa);
  border: 1rpx solid rgba(143, 167, 194, 0.24);
}

.answer-template-card--accepted {
  background: linear-gradient(180deg, #fffaf2, #f6efe1);
  border-color: rgba(182, 141, 77, 0.24);
}

.answer-template-badge-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.answer-template-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(184, 129, 45, 0.16);
  color: #9a6821;
  font-size: 20rpx;
  font-weight: 700;
}

.answer-template-badge-meta {
  font-size: 22rpx;
  color: #8d7a60;
}

.answer-template-row + .answer-template-row {
  margin-top: 14rpx;
}

.answer-template-label {
  display: block;
  margin-bottom: 6rpx;
  font-size: 22rpx;
  color: #7b8ea3;
}

.answer-template-value {
  font-size: 26rpx;
  line-height: 1.65;
  color: #223247;
}

.answer-template-value--strong {
  font-size: 28rpx;
  font-weight: 700;
  color: #183654;
}

.reply-text {
  font-size: 24rpx;
}

.comment-footer,
.reply-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}

.comment-action-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-time,
.reply-time {
  font-size: 22rpx;
  color: #8c99a8;
}

.comment-like-btn,
.comment-reply-btn,
.comment-accept-btn {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f4f7fa;
  font-size: 22rpx;
  color: #516479;
}

.comment-accept-btn--primary {
  background: rgba(38, 93, 150, 0.12);
  color: #21578f;
  font-weight: 600;
}

.comment-like-btn--active {
  background: rgba(225, 88, 88, 0.12);
  color: #d04d4d;
}

.replies-list {
  margin-top: 18rpx;
  margin-left: 88rpx;
  padding-left: 18rpx;
  border-left: 2rpx solid #edf1f5;
}

.reply-item {
  display: flex;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f3f6f9;
}

.empty-comments {
  padding: 50rpx 0 30rpx;
  text-align: center;
  color: #7d8c9d;
  font-size: 26rpx;
}

.detail-empty-state {
  min-height: 70vh;
  padding: 180rpx 48rpx 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.detail-empty-icon {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: #eef3f8;
  color: #607284;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.detail-empty-title {
  margin-top: 28rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #203244;
}

.detail-empty-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #6c7d8f;
}

.comment-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.28);
  z-index: 999;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  min-height: 110rpx;
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  z-index: 1000;
  box-sizing: border-box;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.02);
}

.bottom-bar--editing {
  align-items: flex-end;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.bottom-bar--editor-mode {
  display: block;
  min-height: auto;
  padding: 18rpx 18rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
}

.bottom-bar--answer-mode {
  padding-top: 18rpx;
}

.comment-input-container {
  flex: 1;
  min-width: 0;
}

.answer-entry-group {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-entry-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  padding: 0 24rpx;
  border-radius: 38rpx;
  background: #eef3f8;
  color: #48617a;
  font-size: 26rpx;
  font-weight: 600;
}

.comment-entry-btn--primary {
  background: linear-gradient(135deg, #23476c, #3f78ae);
  color: #fff;
  box-shadow: 0 4rpx 14rpx rgba(35, 71, 108, 0.22);
}

.comment-entry-btn--disabled {
  opacity: 0.56;
}

.comment-input-container--disabled .comment-input {
  color: #7d8c9d;
  background: #f5f7fa;
}

.comment-input,
.comment-textarea {
  width: 100%;
  background: #f0f3f6;
  border-radius: 40rpx;
  border: 1rpx solid transparent;
}

.comment-input {
  height: 76rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #506070;
  box-sizing: border-box;
  transition: all 0.2s;
}

.comment-input:active {
  background: #e8ecf0;
}

.comment-input-expanded {
  flex: 1;
  min-width: 0;
}

.comment-editor-panel,
.recommend-answer-panel {
  width: 100%;
}

.comment-input-wrapper {
  width: 100%;
}

.recommend-answer-editor {
  width: 100%;
  max-height: 62vh;
  padding: 8rpx 2rpx 6rpx;
  box-sizing: border-box;
}

.recommend-answer-editor__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #16283d;
}

.recommend-answer-editor__desc {
  margin-top: 8rpx;
  margin-bottom: 18rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #708397;
}

.recommend-answer-block {
  margin-bottom: 18rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 22rpx;
  background: #f4f7fa;
}

.recommend-answer-label {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #213449;
}

.recommend-answer-option-flow {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.recommend-answer-chip {
  padding: 14rpx 18rpx;
  border-radius: 16rpx;
  background: #fff;
  color: #5b7087;
  font-size: 22rpx;
  line-height: 1.5;
  border: 1rpx solid rgba(142, 160, 180, 0.28);
}

.recommend-answer-chip.active {
  background: #193957;
  border-color: #193957;
  color: #fff;
}

.recommend-answer-input,
.recommend-answer-textarea {
  width: 100%;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  box-sizing: border-box;
  background: #fff;
  border: 1rpx solid rgba(142, 160, 180, 0.28);
  color: #223247;
  font-size: 24rpx;
}

.recommend-answer-input + .recommend-answer-input {
  margin-top: 12rpx;
}

.recommend-answer-textarea {
  min-height: 120rpx;
}

.recommend-answer-textarea--sm {
  min-height: 90rpx;
  margin-top: 12rpx;
}

.recommend-answer-error {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #d85f5f;
}

.comment-input-wrapper {
  width: 100%;
}

.comment-textarea {
  display: block;
  width: 100%;
  min-height: 76rpx;
  max-height: 240rpx;
  padding: 20rpx 28rpx;
  font-size: 30rpx;
  line-height: 1.5;
  color: #1a2b3c;
  border-radius: 38rpx;
  box-sizing: border-box;
  background: #f0f3f6;
}

.comment-textarea--editor {
  min-height: 180rpx;
  max-height: 260rpx;
  border-radius: 26rpx;
  padding: 26rpx 28rpx;
}

.comment-send-btn {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  align-self: flex-end;
  margin-left: 0;
}

.comment-send-btn--answer-mode {
  margin-top: 16rpx;
}

.comment-send-btn--editor-mode {
  width: 100%;
  margin-top: 18rpx;
  align-self: auto;
}

.send-btn {
  min-width: 110rpx;
  height: 76rpx;
  line-height: 76rpx;
  border: none;
  border-radius: 38rpx;
  background: linear-gradient(135deg, #2b7ce3, #5caaff);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0;
  margin: 0;
  box-shadow: 0 4rpx 12rpx rgba(43, 124, 227, 0.25);
}

.send-btn--answer-mode {
  border-radius: 24rpx;
}

.send-btn--editor-mode {
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 24rpx;
}

.right-buttons {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: auto;
  gap: 32rpx;
}

.bottom-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 80rpx;
  padding: 0 4rpx;
  position: relative;
}

.bottom-btn-icon-img,
.share-image {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 2rpx;
}

.bottom-btn-text {
  margin-top: 0;
  font-size: 20rpx;
  color: #607286;
  font-weight: 500;
}

