/* Skeleton Screen */
.skeleton-container {
  padding: 24rpx 20rpx 0;
}

.skeleton-card {
  background: #fff;
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 20rpx 46rpx rgba(24, 39, 64, 0.04);
}

.skeleton-pulse {
  background: #f0f3f6;
  animation: skeleton-loading 1.4s ease infinite;
}

@keyframes skeleton-loading {
  0% { opacity: 1; }
  50% { opacity: 0.6; }
  100% { opacity: 1; }
}

.skeleton-tag {
  width: 120rpx;
  height: 42rpx;
  border-radius: 999rpx;
  margin-bottom: 20rpx;
}

.skeleton-title {
  width: 80%;
  height: 50rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.skeleton-subtitle {
  width: 60%;
  height: 36rpx;
  border-radius: 8rpx;
  margin-bottom: 30rpx;
}

.skeleton-author-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.skeleton-avatar {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
}

.skeleton-author-info {
  flex: 1;
}

.skeleton-name {
  width: 200rpx;
  height: 32rpx;
  border-radius: 6rpx;
  margin-bottom: 10rpx;
}

.skeleton-time {
  width: 140rpx;
  height: 24rpx;
  border-radius: 6rpx;
}

.skeleton-section-title {
  width: 160rpx;
  height: 40rpx;
  border-radius: 8rpx;
  margin-bottom: 30rpx;
}

.skeleton-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.skeleton-grid-item {
  height: 100rpx;
  border-radius: 16rpx;
}

.skeleton-line {
  height: 32rpx;
  border-radius: 6rpx;
  margin-bottom: 20rpx;
}

.skeleton-rect {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  margin-top: 30rpx;
}

/* Dark Mode Skeleton */
.dark .skeleton-card {
  background: #181e26;
  box-shadow: 0 20rpx 48rpx rgba(0, 0, 0, 0.2);
}

.dark .skeleton-pulse {
  background: #28303b;
}
