/* pages/publishMode/publishMode.wxss */
@import "../../styles/dark.wxss";

.publish-mode-container {
  min-height: 100vh;
  width: 100vw;
  max-width: 100vw;
  overflow-x: hidden;
  /* 深邃的极光渐变背景 */
  background: linear-gradient(135deg, #1e3c72 0%, #2a5298 50%, #243b55 100%);
  padding: 0 10rpx;
  box-sizing: border-box;
  position: relative;
}

/* 添加背景纹理/光晕效果 */
.publish-mode-container::before {
  content: '';
  position: absolute;
  top: -10%;
  left: -10%;
  width: 60%;
  height: 40%;
  background: radial-gradient(circle, rgba(48, 207, 208, 0.3) 0%, rgba(0, 0, 0, 0) 70%);
  filter: blur(60rpx);
  z-index: 0;
  pointer-events: none;
}

.publish-mode-container::after {
  content: '';
  position: absolute;
  bottom: -10%;
  right: -10%;
  width: 60%;
  height: 40%;
  background: radial-gradient(circle, rgba(255, 0, 150, 0.15) 0%, rgba(0, 0, 0, 0) 70%);
  filter: blur(60rpx);
  z-index: 0;
  pointer-events: none;
}

/* 内容层级提升，防止被背景遮挡 */
.mode-selection, .publish-content {
  position: relative;
  z-index: 1;
}

/* 当显示模式选择界面时，禁止页面滚动 */
.publish-mode-container.mode-selection-active {
  height: 100vh;
  overflow: hidden;
}

/* 当显示发布内容界面时，允许页面滚动 */
.publish-mode-container.publish-content-active {
  overflow-y: auto;
}

/* 模式选择界面 */
.mode-selection {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40rpx;
  height: 100%;
}

.mode-title {
  text-align: center;
  margin-bottom: 60rpx;
  animation: fadeInDown 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.title-text {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
  letter-spacing: 2rpx;
}

.subtitle-text {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 300;
  letter-spacing: 1rpx;
}

.mode-carousel {
  width: 100%;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

/* 选中模式后的发布界面 */
.publish-content {
  padding-top: 40rpx;
  padding-top: calc(constant(safe-area-inset-top) + 40rpx);
  padding-top: calc(env(safe-area-inset-top) + 40rpx);
  animation: fadeIn 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  height: 100vh;
  box-sizing: border-box;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.selected-mode-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  padding: 30rpx 40rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.selected-mode-header:active {
  transform: scale(0.99);
  background: rgba(255, 255, 255, 0.15);
}

.back-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx 16rpx 10rpx;
  margin-right: 24rpx;
  border-right: 1px solid rgba(255, 255, 255, 0.2);
  cursor: pointer;
}

.back-icon {
  font-size: 48rpx;
  color: #ffffff;
  margin-right: 8rpx;
  line-height: 1;
  margin-top: -6rpx;
}

.back-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

.selected-mode-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-left: 10rpx;
}

.selected-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.selected-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.4;
}

.publish-form-container {
  width: 100%;
  animation: slideUp 0.6s 0.2s backwards;
  padding-bottom: 60rpx;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ==================== 夜间模式样式 ==================== */

/* 页面容器夜间模式 */
.dark .publish-mode-container {
  /* 统一调整为深邃蓝调，与日间模式的蓝色系呼应，但更深沉 */
  background: linear-gradient(135deg, #0a1122 0%, #111d33 50%, #1a2a44 100%);
}

.dark .publish-mode-container::before {
  /* 调整光晕颜色为冷蓝色 */
  background: radial-gradient(circle, rgba(58, 135, 240, 0.15) 0%, rgba(0, 0, 0, 0) 70%);
}

.dark .publish-mode-container::after {
  /* 调整光晕颜色为深紫色 */
  background: radial-gradient(circle, rgba(110, 60, 230, 0.15) 0%, rgba(0, 0, 0, 0) 70%);
}

.dark .title-text {
  color: #f0f0f0;
}

.dark .subtitle-text {
  color: rgba(240, 240, 240, 0.7);
}

/* 发布内容界面夜间模式 */
.dark .selected-mode-header {
  /* 调整为与背景协调的深蓝半透明色 */
  background: rgba(13, 25, 48, 0.6);
  border: 1px solid rgba(255, 255, 255, 0.05);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.dark .selected-mode-header:active {
  background: rgba(13, 25, 48, 0.8);
}

.dark .back-btn {
  border-right: 1px solid rgba(255, 255, 255, 0.1);
}

.dark .back-icon {
  color: #f0f0f0;
}

.dark .back-text {
  color: #f0f0f0;
}

.dark .selected-title {
  color: #f0f0f0;
}

.dark .selected-desc {
  color: rgba(240, 240, 240, 0.6);
}
