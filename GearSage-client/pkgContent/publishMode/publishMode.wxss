/* pages/publishMode/publishMode.wxss */
@import "../../styles/dark.wxss";

.publish-mode-container {
  min-height: 100vh;
  width: 100vw;
  max-width: 100vw;
  overflow-x: hidden;
  background: #f4f5f1;
  padding: 0 28rpx;
  box-sizing: border-box;
  position: relative;
}

.publish-mode-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 220rpx;
  background: linear-gradient(180deg, rgba(229, 233, 224, 0.88), rgba(244, 245, 241, 0));
  z-index: 0;
  pointer-events: none;
}

.publish-mode-container::after {
  display: none;
}

/* 内容层级提升，防止被背景遮挡 */
.mode-selection, .publish-content {
  position: relative;
  z-index: 1;
}

/* 当显示模式选择界面时，禁止页面滚动 */
.publish-mode-container.mode-selection-active {
  height: 100vh;
  overflow: hidden;
}

/* 当显示发布内容界面时，允许页面滚动 */
.publish-mode-container.publish-content-active {
  overflow-y: auto;
}

/* 模式选择界面 */
.mode-selection {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 34rpx;
  height: 100%;
}

.mode-title {
  text-align: center;
  margin-bottom: 30rpx;
  animation: fadeInDown 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.title-text {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2a27;
  margin-bottom: 14rpx;
}

.subtitle-text {
  display: block;
  font-size: 25rpx;
  line-height: 1.55;
  color: #68716b;
  font-weight: 400;
}

.mode-carousel {
  width: 100%;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

/* 选中模式后的发布界面 */
.publish-content {
  padding-top: 16rpx;
  animation: fadeIn 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  height: 100vh;
  box-sizing: border-box;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.selected-mode-header {
  display: flex;
  align-items: center;
  margin: 0 0 22rpx;
  padding: 22rpx 24rpx;
  background: #ffffff;
  border-radius: 10rpx;
  border: 1rpx solid rgba(58, 68, 62, 0.11);
  box-shadow: 0 6rpx 18rpx rgba(31, 42, 39, 0.045);
  transition: all 0.3s ease;
}

.selected-mode-header:active {
  transform: scale(0.99);
  background: #f8f9f5;
}

.back-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx 12rpx 4rpx;
  margin-right: 20rpx;
  border-right: 1rpx solid rgba(58, 68, 62, 0.12);
  cursor: pointer;
}

.back-icon {
  font-size: 44rpx;
  color: #4f6654;
  margin-right: 8rpx;
  line-height: 1;
  margin-top: -6rpx;
}

.back-text {
  font-size: 26rpx;
  color: #4f6654;
  font-weight: 600;
}

.selected-mode-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-left: 10rpx;
}

.selected-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2a27;
  margin-bottom: 8rpx;
}

.selected-desc {
  display: block;
  font-size: 24rpx;
  color: #68716b;
  line-height: 1.5;
}

.publish-form-container {
  width: 100%;
  animation: slideUp 0.6s 0.2s backwards;
  padding-bottom: 60rpx;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ==================== 夜间模式样式 ==================== */

/* 页面容器夜间模式 */
.dark .publish-mode-container {
  background: #0f1518;
}

.dark .publish-mode-container::before {
  background: linear-gradient(180deg, rgba(24, 32, 40, 0.88), rgba(15, 21, 24, 0));
}

.dark .publish-mode-container::after {
  display: none;
}

.dark .title-text {
  color: #eef5f2;
}

.dark .subtitle-text {
  color: rgba(236, 244, 241, 0.68);
}

/* 发布内容界面夜间模式 */
.dark .selected-mode-header {
  background: #182028;
  border: 1rpx solid rgba(229, 236, 231, 0.08);
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.22);
}

.dark .selected-mode-header:active {
  background: rgba(238, 245, 242, 0.08);
}

.dark .back-btn {
  border-right: 1rpx solid rgba(229, 236, 231, 0.08);
}

.dark .back-icon {
  color: #b8bfa0;
}

.dark .back-text {
  color: #b8bfa0;
}

.dark .selected-title {
  color: #eef5f2;
}

.dark .selected-desc {
  color: rgba(236, 244, 241, 0.68);
}
