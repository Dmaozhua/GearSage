@import "/styles/dark.wxss";

page {
  background: #eef3f7;
  min-height: 100vh;
}

.user-profile-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top, rgba(67, 110, 153, 0.16), transparent 30%),
    linear-gradient(180deg, #eef3f7 0%, #e8eef3 100%);
}

.user-profile-scroll {
  padding: 24rpx 20rpx 40rpx;
  box-sizing: border-box;
}

.page-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 50vh;
}

.page-state__text {
  font-size: 28rpx;
  color: #5c7084;
}

.profile-hero,
.section-card {
  position: relative;
  overflow: hidden;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 40rpx rgba(23, 39, 57, 0.09);
}

.profile-hero {
  min-height: 420rpx;
  margin-bottom: 20rpx;
}

.profile-hero__bg,
.profile-hero__fallback,
.profile-hero__mask {
  position: absolute;
  inset: 0;
}

.profile-hero__bg {
  width: 100%;
  height: 100%;
}

.profile-hero__fallback {
  background:
    radial-gradient(circle at 20% 18%, rgba(111, 154, 190, 0.35), transparent 30%),
    linear-gradient(135deg, #4d667d 0%, #314658 100%);
}

.profile-hero__mask {
  background: linear-gradient(180deg, rgba(18, 32, 45, 0.12), rgba(12, 23, 34, 0.72));
}

.profile-hero__body {
  position: relative;
  z-index: 1;
  min-height: 420rpx;
  padding: 34rpx 28rpx 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.profile-avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 10rpx 26rpx rgba(12, 23, 34, 0.2);
  margin-bottom: 18rpx;
}

.profile-name {
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #f7fbff;
}

.profile-tag {
  margin-top: 10rpx;
}

.profile-bio,
.profile-summary {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(244, 249, 255, 0.9);
}

.section-card {
  padding: 26rpx 24rpx;
  margin-bottom: 18rpx;
}

.section-card--empty {
  margin-bottom: 0;
}

.section-title {
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #193047;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.stat-card {
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f4f8fb, #edf3f7);
  border: 1rpx solid rgba(117, 142, 166, 0.16);
}

.stat-value {
  display: block;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #17324d;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #667b90;
}

.feed-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf1f4;
}

.feed-card:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.feed-card__meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.feed-badge {
  display: inline-flex;
  align-items: center;
  min-height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #e9f0f7;
  color: #385979;
  font-size: 20rpx;
}

.feed-badge--warm {
  background: #f5eee1;
  color: #8b6532;
}

.feed-time {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #7b8ea0;
}

.feed-title {
  font-size: 28rpx;
  line-height: 1.5;
  color: #1b3249;
  font-weight: 600;
}

.feed-desc,
.empty-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #62778b;
}

.dark.user-profile-page {
  background:
    radial-gradient(circle at top, rgba(67, 110, 153, 0.18), transparent 28%),
    linear-gradient(180deg, #16212c 0%, #111923 100%);
}

.dark .page-state__text,
.dark .feed-time,
.dark .feed-desc,
.dark .empty-text,
.dark .stat-label {
  color: #96a9bc;
}

.dark .section-card {
  background: rgba(25, 35, 46, 0.95);
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.26);
}

.dark .section-title,
.dark .feed-title,
.dark .stat-value {
  color: #edf5ff;
}

.dark .stat-card {
  background: rgba(38, 50, 63, 0.92);
  border-color: rgba(111, 136, 161, 0.14);
}

.dark .feed-card {
  border-bottom-color: rgba(80, 96, 111, 0.3);
}

.dark .feed-badge {
  background: rgba(65, 87, 109, 0.75);
  color: #c5d8eb;
}

.dark .feed-badge--warm {
  background: rgba(98, 78, 50, 0.82);
  color: #f0d3a5;
}
