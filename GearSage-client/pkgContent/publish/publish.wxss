/* pages/publish/publish.wxss */
@import "../../styles/dark.wxss";
.publish-container {
    min-height: 100vh;
    height: auto; /* 让高度能根据内容自适应 */
    background: #ffffff;
    padding: 0 0 30rpx 0;
    position: relative;
    width: 100%;
    max-width: 100vw;
    overflow-x: hidden;
    box-sizing: border-box;
}

/* 页面副标题 */
.publish-subtitle {
    padding: 20rpx 30rpx 30rpx;
    color: rgb(94, 120, 153);
    text-align: center;
    position: relative;
    background: linear-gradient(180deg, #f8fafc 0%, #e2e8f0 100%); /* 添加背景渐变 */
}

.publish-subtitle::after {
    content: '';
    position: absolute;
    bottom: -10rpx;
    left: 50%;
    transform: translateX(-50%);
    width: 60rpx;
    height: 4rpx;
    background: rgba(255, 255, 255, 0.3);
    border-radius: 2rpx;
}

.subtitle-text {
    font-size: 28rpx;
    opacity: 0.9;
    display: block;
    font-weight: 300;
    letter-spacing: 0.5rpx;
}

/* 表单样式 */
.publish-form {
  background: #ffffff;
  margin: 0;
  border-radius: 0;
  padding: 0;
  border: none;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

/* .publish-form::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
} */

/* 微信朋友圈风格内容区域 */
.wechat-content-section {
  background: #ffffff;
  margin: 0 30rpx;
  padding: 0;
}

.title-input-container {
  padding: 32rpx 20rpx 16rpx 20rpx;
  border-bottom: none;
}

.wechat-title-input {
  width: 100%;
  font-size: 36rpx;
  font-weight: 500;
  color: #333333;
  background: transparent;
  border: none;
  outline: none;
  padding: 0;
  margin: 0;
  line-height: 1.4;
}

.wechat-title-input::placeholder {
  color: #999999;
  font-weight: 400;
}

.content-input-container {
  padding: 16rpx 20rpx 32rpx 20rpx;
}

.wechat-content-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 32rpx;
  color: #333333;
  background: transparent;
  border: none;
  outline: none;
  padding: 0;
  margin: 0;
  line-height: 1.5;
  resize: none;
}

.wechat-content-textarea::placeholder {
  color: #999999;
}

/* 微信朋友圈风格图片区域 */
.wechat-image-container {
  margin-top: 24rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.wechat-image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.wechat-image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.wechat-image-item .image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.wechat-image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.wechat-image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.wechat-image-add .add-icon {
  font-size: 60rpx;
  color: #999;
  font-weight: 300;
}

/* 微信朋友圈风格的表单项 - 同一行布局 */
.form-item {
  margin-bottom: 0;
  margin-left: 30rpx;
  margin-right: 30rpx;
  padding: 16rpx 27rpx;
  border-bottom: 1rpx solid #e5e5e5;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 70rpx;
  transform: scale(0.9);
  transform-origin: center;
}

.form-item:last-child {
  border-bottom: none;
}

/* 推荐理由保持原有布局 */
.form-item:has(.recommend-list) {
  display: block;
  padding: 20rpx 27rpx;
}

.form-item:has(.recommend-list) .form-label {
  margin-bottom: 16rpx;
}

/* 使用频次保持原有布局 */
.form-item:has(.frequency-container) {
  display: block;
  padding: 20rpx 27rpx;
}

.form-item:has(.frequency-container) .form-label {
  margin-bottom: 16rpx;
}

/* 使用环境保持原有布局 */
.form-item:has(.environment-input) {
  display: block;
  padding: 20rpx 27rpx;
}

.form-item:has(.environment-input) .form-label {
  margin-bottom: 16rpx;
}

/* 星级评分采用同一行布局但需要特殊处理 */
.form-item:has(.star-rating) {
  align-items: flex-start;
  padding: 16rpx 27rpx;
}

.form-item:has(.star-rating) .form-label {
  margin-top: 8rpx;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 0;
  position: relative;
  flex-shrink: 0;
  min-width: 160rpx;
}

.label-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  position: relative;
}

.required {
  color: #ff3b30;
  margin-left: 8rpx;
  font-size: 32rpx;
}

.label-tip {
  font-size: 26rpx;
  color: #999999;
  margin-left: 16rpx;
}

/* 输入框样式 */
.form-input {
  width: 100%;
  height: 88rpx;
  border: none;
  border-radius: 0;
  padding: 0;
  font-size: 32rpx;
  background: transparent;
  color: #333333;
  outline: none;
}

.form-input:focus {
  background: transparent;
}

.form-input.error {
  color: #ff3b30;
}

/* 选择器样式 - 适应同一行布局 */
.form-picker {
  flex: 1;
  height: 88rpx;
  border: none;
  border-radius: 0;
  background: transparent;
  position: relative;
  overflow: hidden;
  text-align: right;
}

.form-picker.error {
  color: #ff3b30;
}

.picker-text {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  font-size: 30rpx;
  color: #333333;
  font-weight: 400;
  text-align: right;
}

.picker-text.placeholder {
  color: #999999;
  font-weight: 400;
}

/* 文本域样式 */
.form-textarea {
  width: 100%;
  min-height: 220rpx;
  border: none;
  border-radius: 0;
  padding: 0;
  font-size: 32rpx;
  background: transparent;
  line-height: 1.6;
  color: #333333;
  outline: none;
  resize: none;
}

.form-textarea:focus {
  background: transparent;
}

.form-textarea.error {
  color: #ff3b30;
}

.wechat-content-section .char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 16rpx;
  font-weight: 400;
}

.char-count {
  text-align: right;
  font-size: 26rpx;
  color: #999999;
  margin-top: 16rpx;
  font-weight: 400;
}

/* 主要内容文本域容器 */
.textarea-container {
  position: relative;
  overflow: hidden;
}

.textarea-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  font-size: 32rpx;
  color: #999999;
  line-height: 1.6;
  pointer-events: none;
  z-index: 1;
  font-weight: 400;
}

/* 推荐理由样式 */
.recommend-list {
  width: 100%;
  background: transparent;
  padding: 0;
  box-sizing: border-box;
}

.recommend-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 12rpx;
  background: transparent;
  padding: 0;
  box-sizing: border-box;
}

.recommend-item:last-child {
  margin-bottom: 0;
}

.recommend-input {
  flex: 1;
  height: 76rpx;
  border: none;
  border-radius: 0;
  padding: 0;
  font-size: 30rpx;
  background: transparent;
  color: #333333;
  outline: none;
}

.recommend-input:focus {
  background: transparent;
}

.recommend-input.error {
  color: #ff3b30;
}

.recommend-actions {
  display: flex;
  gap: 12rpx;
}

.add-btn,
.delete-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: normal;
  border: none;
}

.add-btn {
  background: #07C160;
  color: white;
}

.add-btn:active {
  background: #06AD56;
}

.delete-btn {
  background: #ff3b30;
  color: white;
}

.delete-btn:active {
  background: #d70015;
}

/* 图片上传样式 */
.image-upload {
  width: 100%;
  background: transparent;
  padding: 0;
  box-sizing: border-box;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  justify-content: flex-start;
}

.image-item {
  position: relative;
  width: calc(33.333% - 6rpx);
  height: 200rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  object-fit: cover;
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 20rpx;
  z-index: 10;
}

.image-delete:active {
  background: rgba(0, 0, 0, 0.8);
}

.image-add {
  width: calc(33.333% - 6rpx);
  height: 200rpx;
  border: 2rpx dashed #d1d1d6;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  box-sizing: border-box;
}

.image-add:active {
  border-color: #07C160;
}

.add-icon {
  font-size: 48rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.image-add:active .add-icon {
  color: #07C160;
}

.add-text {
  font-size: 24rpx;
  color: #999999;
  font-weight: 400;
}

.image-add:active .add-text {
  color: #07C160;
}

/* 错误提示 */
.error-text {
  color: #ff3b30;
  font-size: 26rpx;
  margin-top: 12rpx;
  line-height: 1.4;
}

/* 使用频次组合样式 */
.frequency-container {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.frequency-picker {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #e1e8ed;
  border-radius: 12rpx;
  background: #fafbfc;
  transition: all 0.3s ease;
}

.frequency-picker.error {
  border-color: #ff4757;
  background: #fff5f5;
}

.frequency-result {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
}

/* 环境输入框样式 */
.environment-input {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  background: #ffffff;
  font-size: 30rpx;
  color: #333333;
  line-height: 1.6;
  box-sizing: border-box;
  resize: none;
}

.environment-input::placeholder {
  color: #999999;
}

.environment-input.error {
  border-color: #ff4757;
}

.environment-input:focus {
  border-color: #07C160;
  outline: none;
}

/* 操作按钮 */
/* 操作按钮 - 新布局 */
.action-buttons {
  margin: 0 30rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-top: 1rpx solid #e5e5e5;
  padding: 30rpx 30rpx;
  z-index: 100;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  gap: 20rpx;
}

.btn {
  border: none;
  border-radius: 50rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

/* 保存草稿按钮 */
.btn-draft {
  width: 200rpx;
  height: 88rpx;
  background: #f8f9fa;
  color: #6c757d;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid #dee2e6;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  gap: 8rpx;
}

.btn-draft:active {
  background: #e9ecef;
  transform: scale(0.98);
}

.btn-draft:disabled {
  background: #f8f9fa;
  color: #adb5bd;
  border-color: #e9ecef;
  box-shadow: none;
}

.draft-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.8;
}

/* 发布按钮 - 居中显示 */
.btn-primary {
  width: 300rpx;
  height: 88rpx;
  background: #07C160;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
  gap: 12rpx;
}

.btn-primary:active {
  background: #06AD56;
  transform: scale(0.98);
}

.btn-primary:disabled {
  background: #d1d1d6;
  color: #999999;
  box-shadow: none;
}

.btn-icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
}

/* 重置按钮 - 右下角小按钮 */
.btn-reset {
    position: absolute;
    right: -100rpx; /* 调整右侧偏移 */
    bottom: 36rpx; /* 调整垂直位置 */
    width: 60rpx; /* 调整宽度 */
    height: 60rpx; /* 调整高度 */
    background: transparent;
    border: none;
    border-radius: 50%;
  }

.btn-reset:active {
  transform: scale(0.95);
}

.btn-reset:disabled {
  opacity: 0.5;
}

.reset-icon {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.7;
}

.submit-btn {
  position: relative;
}



/* 底部提示 */
.publish-tips {
  margin: 0 30rpx;
  padding: 20rpx 27rpx;
  background: #ffffff;
  border-top: 1rpx solid #e5e5e5;
  box-sizing: border-box;
  transform: scale(0.9);
  transform-origin: center;
}

/* 提示折叠头部 */
.tips-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0;
  background: transparent;
  margin-bottom: 16rpx;
}

.tips-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.tips-arrow {
  font-size: 28rpx;
  color: #999999;
}

.tips-arrow.expanded {
  transform: rotate(180deg);
}

/* 提示内容区域 */
.tips-content {
  overflow: hidden;
}

.tips-content.collapsed {
  max-height: 0;
  opacity: 0;
}

.tips-content.expanded {
  max-height: 1000rpx;
  opacity: 1;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding: 0;
  background: transparent;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  margin-top: 2rpx;
}

.tip-text {
  flex: 1;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  font-weight: 400;
}

/* 响应式适配 */
@media (max-width: 375px) {
  .form-item {
    padding: 24rpx 20rpx;
  }
  
  .image-item,
  .image-add {
    width: calc(33.333% - 6rpx);
    height: 160rpx;
  }
  
  .image-list {
    gap: 6rpx;
  }
  
  .add-btn,
  .delete-btn {
    width: 48rpx;
    height: 48rpx;
    font-size: 24rpx;
  }
  
  .publish-tips {
    padding: 24rpx 20rpx;
  }
  
  .action-buttons {
    padding: 12rpx 20rpx;
  }
  
  .btn-primary {
    width: 280rpx;
    height: 78rpx;
    font-size: 30rpx;
  }
  
  .btn-reset {
    width: 70rpx;
    height: 70rpx;
    right: -10rpx;
    bottom: 12rpx;
  }
  
  .reset-icon {
    width: 40rpx;
    height: 40rpx;
  }
}

/* 加载状态 */
.btn-primary[loading] {
  position: relative;
}

.btn-primary[loading]::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 32rpx;
  height: 32rpx;
  margin: -16rpx 0 0 -16rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 星级评分样式 - 适应同一行布局 */
.score-display {
  font-size: 28rpx;
  color: #07C160;
  font-weight: 600;
  margin-left: 16rpx;
}

.star-rating {
  flex: 1;
  padding: 0;
  background: transparent;
  border: none;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.star-rating.error {
  color: #ff3b30;
}

.stars-container {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 6rpx;
  padding: 0;
}

.star {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.star-icon {
  font-size: 36rpx;
  color: #e5e5e5;
  cursor: pointer;
}

.star-icon.filled {
  color: #fbbf24;
}

.star-icon.filled.half {
  background: linear-gradient(90deg, #fbbf24 50%, #e5e5e5 50%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.star-icon.filled.full {
  color: #fbbf24;
}

/* 星级评分响应式适配 */
@media (max-width: 375px) {
  .star-icon {
    font-size: 40rpx;
  }
  
  .stars-container {
    gap: 6rpx;
  }
  
  .score-display {
    font-size: 26rpx;
  }
}

/* 购买凭证上传样式 */
.receipt-upload-container {
  width: 100%;
}

.receipt-images {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.receipt-image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.receipt-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.delete-receipt-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ff4757;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.delete-icon {
  color: white;
  font-size: 24rpx;
  font-weight: bold;
}

.add-receipt-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  background: #fafafa;
  transition: all 0.3s;
}

.add-receipt-btn:active {
  background: #f0f0f0;
  transform: scale(0.98);
}

.add-icon {
  font-size: 48rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.add-text {
  font-size: 24rpx;
  color: #999;
}

.receipt-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.optional {
  color: #999;
  font-size: 24rpx;
  margin-left: 8rpx;
}

/* 夜间模式样式 */
.dark .action-buttons {
  background: #1a1a1a;
  border-top-color: #333333;
}

.dark .btn-draft {
  background: #2a2a2a;
  color: #cccccc;
  border-color: #444444;
}

.dark .btn-draft:active {
  background: #333333;
}

.dark .btn-draft:disabled {
  background: #2a2a2a;
  color: #666666;
  border-color: #333333;
}

.dark .draft-icon {
  opacity: 0.9;
}

/* 购买凭证夜间模式样式 */
.dark .add-receipt-btn {
  background: #333;
  border-color: #555;
}

.dark .add-receipt-btn:active {
  background: #444;
}

.dark .add-icon,
