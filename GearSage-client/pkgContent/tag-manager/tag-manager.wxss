@import '../../styles/dark.wxss';

.tag-manager-page {
  --page-bg:
    linear-gradient(180deg, #f5f8fb 0%, #e7edf2 54%, #dde6ed 100%);
  --surface-bg: rgba(255, 255, 255, 0.9);
  --surface-border: rgba(122, 140, 158, 0.12);
  --surface-shadow: 0 12rpx 32rpx rgba(18, 34, 52, 0.08);
  --text-primary: #223140;
  --text-secondary: #5c6d7d;
  --text-muted: #7f91a3;
  --soft-bg: rgba(241, 245, 249, 0.92);
  --soft-border: rgba(143, 161, 180, 0.18);
  --accent: #5b7d9d;
  --accent-soft: rgba(113, 152, 187, 0.14);
  --accent-strong: rgba(113, 152, 187, 0.22);
  --accent-border: rgba(113, 152, 187, 0.24);
  min-height: 100vh;
  background: var(--page-bg);
  padding-bottom: 160rpx;
}

.tag-manager-page.dark {
  --page-bg:
    radial-gradient(circle at top, rgba(83, 113, 142, 0.18), transparent 28%),
    linear-gradient(180deg, #111821 0%, #0d131c 54%, #091018 100%);
  --surface-bg:
    linear-gradient(180deg, rgba(28, 34, 43, 0.98), rgba(18, 24, 33, 0.99)),
    radial-gradient(circle at top right, rgba(96, 123, 148, 0.14), transparent 54%);
  --surface-border: rgba(92, 110, 127, 0.22);
  --surface-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04),
    0 18rpx 44rpx rgba(6, 10, 18, 0.22);
  --text-primary: #f4f7fb;
  --text-secondary: rgba(214, 223, 232, 0.84);
  --text-muted: rgba(166, 181, 196, 0.76);
  --soft-bg: rgba(255, 255, 255, 0.04);
  --soft-border: rgba(116, 132, 148, 0.16);
  --accent: #d8e9f7;
  --accent-soft: rgba(143, 182, 216, 0.14);
  --accent-strong: rgba(143, 182, 216, 0.22);
  --accent-border: rgba(143, 182, 216, 0.24);
}

.page-content {
  padding: 24rpx 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tag-hero-card,
.mode-section,
.preview-section,
.custom-section,
.wardrobe-section {
  padding: 24rpx;
  border-radius: 28rpx;
  background: var(--surface-bg);
  border: 1rpx solid var(--surface-border);
  box-shadow: var(--surface-shadow);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.tag-hero-top,
.section-head,
.custom-topic-head,
.wardrobe-group-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.tag-hero-kicker {
  display: block;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: var(--text-muted);
}

.tag-hero-title,
.section-title {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-desc,
.tag-hero-caption,
.tag-hero-empty,
.tag-preview-empty,
.custom-topic-summary,
.custom-topic-empty,
.wardrobe-group-desc,
.no-tags-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.tag-hero-action {
  font-size: 24rpx;
  color: var(--accent);
}

.tag-hero-user {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 22rpx;
}

.tag-hero-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 38rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 10rpx 24rpx rgba(13, 24, 36, 0.12);
}

.tag-hero-meta {
  display: flex;
  flex-direction: column;
}

.tag-hero-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.tag-hero-chip {
  margin-top: 20rpx;
}

.mode-card-list,
.custom-topic-list,
.wardrobe-card-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.mode-card.is-active,
.custom-topic-card.is-active,
.wardrobe-card.is-selected,
.tag-empty-choice.is-selected {
  border-color: rgba(133, 178, 215, 0.4);
  background: var(--accent-soft);
}

.mode-card-desc,
.wardrobe-card-meta,
.wardrobe-card-source,
.tag-empty-desc {
  display: block;
  margin-top: 8rpx;
}

.tag-preview-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.custom-topic-preview {
  margin-top: 16rpx;
}

.custom-topic-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.mode-card,
.custom-topic-card,
.wardrobe-card,
.tag-preview-card,
.tag-empty-choice {
  padding: 20rpx;
  border-radius: 22rpx;
  background: var(--soft-bg);
  border: 1rpx solid var(--soft-border);
}

.mode-card-title,
.custom-topic-title,
.wardrobe-card-title,
.tag-empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.mode-card-desc,
.custom-topic-value,
.wardrobe-card-meta,
.wardrobe-card-source,
.tag-preview-label,
.wardrobe-rarity,
.tag-filter-count,
.wardrobe-group-count {
  font-size: 22rpx;
  color: var(--text-muted);
}

.custom-ref-pill,
.tag-filter-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: var(--soft-bg);
  border: 1rpx solid var(--soft-border);
  color: var(--text-primary);
  font-size: 22rpx;
}

.custom-ref-pill.is-active,
.tag-filter-pill.is-active {
  background: var(--accent-soft);
  border-color: rgba(133, 178, 215, 0.4);
}

.custom-ref-pill {
  position: relative;
  z-index: 1;
}

.tag-filter-scroll {
  margin-top: 20rpx;
  white-space: nowrap;
}

.tag-filter-list {
  display: inline-flex;
  gap: 12rpx;
}

.tag-filter-text {
  font-size: 24rpx;
  color: var(--text-primary);
}

.tag-empty-choice {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
}

.tag-empty-desc {
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-muted);
}

.tag-empty-action {
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
}

.tag-empty-action-text {
  font-size: 22rpx;
  color: var(--text-muted);
}

.tag-empty-switch {
  position: relative;
  width: 92rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: rgba(216, 225, 234, 0.88);
  border: 1rpx solid rgba(143, 161, 180, 0.28);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
  transition: all 0.24s ease;
}

.tag-manager-page.dark .tag-empty-switch {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(116, 132, 148, 0.18);
}

.tag-empty-switch-thumb {
  position: absolute;
  top: 5rpx;
  left: 5rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #f7fafc, #d4dce4);
  box-shadow:
    0 6rpx 14rpx rgba(4, 8, 14, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
  transition: transform 0.24s ease, background 0.24s ease;
}

.tag-empty-action.is-selected .tag-empty-action-text {
  color: var(--accent);
}

.tag-empty-action.is-selected .tag-empty-switch {
  background: var(--accent-strong);
  border-color: rgba(133, 178, 215, 0.42);
}

.tag-empty-action.is-selected .tag-empty-switch-thumb {
  transform: translateX(40rpx);
  background: linear-gradient(180deg, #fefefe, #e4edf5);
}

.wardrobe-group {
  margin-top: 24rpx;
}

.wardrobe-card-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.wardrobe-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.wardrobe-card {
  padding: 18rpx;
  min-height: 0;
}

.wardrobe-card-title {
  display: none;
}

.wardrobe-card-meta,
.wardrobe-card-source {
  margin-top: 8rpx;
}

.wardrobe-card-action {
  margin-top: 12rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(143, 161, 180, 0.24);
  color: var(--text-primary);
  font-size: 22rpx;
}

.tag-manager-page.dark .wardrobe-card-action {
  background: rgba(255, 255, 255, 0.05);
  border: none;
}

.wardrobe-card-action.is-selected {
  background: var(--accent-soft);
  color: var(--accent);
  border-color: rgba(133, 178, 215, 0.32);
}

.no-tags {
  padding: 24rpx 0 4rpx;
}

.save-bar {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 24rpx;
  display: flex;
  gap: 16rpx;
  z-index: 120;
  padding: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(122, 140, 158, 0.14);
  box-shadow: 0 18rpx 40rpx rgba(18, 34, 52, 0.12);
  backdrop-filter: blur(22rpx);
  -webkit-backdrop-filter: blur(22rpx);
}

.tag-manager-page.dark .save-bar {
  background: rgba(12, 18, 26, 0.78);
  border-color: rgba(92, 110, 127, 0.24);
  box-shadow: 0 18rpx 40rpx rgba(4, 8, 14, 0.22);
}

.cancel-btn,
.save-btn {
  flex: 1;
  min-height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  position: relative;
  z-index: 121;
  overflow: hidden;
}

.cancel-btn {
  background: rgba(240, 245, 249, 0.96);
  color: #223140;
}

.save-btn {
  background: linear-gradient(135deg, #4d6982, #7fa2c2);
  color: #fff;
}

.tag-manager-page.dark .cancel-btn {
  background: rgba(255, 255, 255, 0.9);
}

.loading-overlay {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(9, 12, 18, 0.16);
  z-index: 200;
}

.fixed-tag-picker-mask {
  position: fixed;
  inset: 0;
  z-index: 160;
  display: flex;
  align-items: flex-end;
  background: rgba(6, 10, 16, 0.4);
}

.fixed-tag-picker-panel {
  width: 100%;
  max-height: 72vh;
  padding: 26rpx 22rpx 30rpx;
  border-radius: 30rpx 30rpx 0 0;
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(143, 161, 180, 0.2);
  box-shadow: 0 -10rpx 30rpx rgba(18, 34, 52, 0.12);
  box-sizing: border-box;
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}
.tag-manager-page.dark .fixed-tag-picker-panel {
  background:
    linear-gradient(180deg, rgba(28, 34, 43, 0.99), rgba(18, 24, 33, 0.99)),
    radial-gradient(circle at top right, rgba(96, 123, 148, 0.14), transparent 54%);
  border-top: 1rpx solid rgba(92, 110, 127, 0.26);
  box-shadow: 0 -20rpx 50rpx rgba(6, 10, 18, 0.24);
}

.fixed-tag-picker-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.fixed-tag-picker-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.fixed-tag-picker-desc,
.fixed-tag-picker-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-muted);
}

.fixed-tag-picker-close {
  font-size: 24rpx;
  color: var(--accent);
}

.fixed-tag-picker-scroll {
  max-height: calc(72vh - 120rpx);
  margin-top: 22rpx;
}

.fixed-tag-picker-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.fixed-tag-picker-card {
  padding: 16rpx;
  border-radius: 20rpx;
  background: var(--soft-bg);
  border: 1rpx solid var(--soft-border);
}

.fixed-tag-picker-card.is-selected {
  border-color: rgba(133, 178, 215, 0.4);
  background: var(--accent-soft);
}
