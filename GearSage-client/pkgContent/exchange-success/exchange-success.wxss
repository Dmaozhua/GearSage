/* pages/exchange-success/exchange-success.wxss */
.container {
  min-height: 100vh;
  background: #f4f5f1;
  padding: 34rpx 28rpx 48rpx;
  position: relative;
  overflow: hidden;
}

/* 成功头部 */
.success-header {
  text-align: center;
  margin-bottom: 34rpx;
  padding-top: 48rpx;
}

.success-icon {
  width: 132rpx;
  height: 132rpx;
  margin: 0 auto 30rpx;
  background: #eef2ed;
  border: 1rpx solid rgba(79, 102, 84, 0.16);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 18rpx rgba(31, 42, 39, 0.045);
}

.success-icon image {
  width: 80rpx;
  height: 80rpx;
}

@keyframes bounce {
  0% {
    transform: scale(0);
  }
  50% {
    transform: scale(1.1);
  }
  100% {
    transform: scale(1);
  }
}

.success-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2a27;
  margin-bottom: 16rpx;
}

.success-subtitle {
  display: block;
  font-size: 26rpx;
  color: #68716b;
  line-height: 1.55;
}

/* 兑换信息卡片 */
.exchange-info {
  background: #ffffff;
  border: 1rpx solid rgba(58, 68, 62, 0.11);
  border-radius: 10rpx;
  padding: 26rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 6rpx 18rpx rgba(31, 42, 39, 0.045);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(58, 68, 62, 0.1);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #68716b;
}

.info-value {
  font-size: 26rpx;
  color: #1f2a27;
  font-weight: 600;
}

.info-value.points {
  color: #766f4f;
  font-weight: 700;
}

/* 虚拟权益信息 */
.virtual-info {
  background: #ffffff;
  border: 1rpx solid rgba(58, 68, 62, 0.11);
  border-radius: 10rpx;
  padding: 26rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 6rpx 18rpx rgba(31, 42, 39, 0.045);
}

.virtual-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.virtual-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2a27;
  margin-bottom: 10rpx;
}

.virtual-tip {
  display: block;
  font-size: 24rpx;
  color: #8a918a;
}

.code-container {
  margin-bottom: 30rpx;
}

.code-box {
  background: #f6f7f3;
  border: 1rpx solid rgba(58, 68, 62, 0.1);
  border-radius: 8rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.code-label {
  display: block;
  font-size: 24rpx;
  color: #68716b;
  margin-bottom: 15rpx;
}

.code-value {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2a27;
  font-family: 'Courier New', monospace;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
  word-break: break-all;
}

.copy-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: #26332d;
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.copy-btn image {
  width: 24rpx;
  height: 24rpx;
}

.validity-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.validity-label {
  font-size: 26rpx;
  color: #68716b;
}

.validity-date {
  font-size: 26rpx;
  color: #766f4f;
  font-weight: 600;
}

.usage-tips {
  background: #f3efe2;
  border: 1rpx solid #ded2a9;
  border-radius: 8rpx;
  padding: 20rpx;
}

.tips-title {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #766f4f;
  margin-bottom: 15rpx;
}

.tips-content {
  display: block;
  font-size: 24rpx;
  color: #766f4f;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.tips-content:last-child {
  margin-bottom: 0;
}

/* 实体商品信息 */
.physical-info {
  background: #ffffff;
  border: 1rpx solid rgba(58, 68, 62, 0.11);
  border-radius: 10rpx;
  padding: 26rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 6rpx 18rpx rgba(31, 42, 39, 0.045);
}

.delivery-notice {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.notice-icon {
  width: 60rpx;
  height: 60rpx;
  background: #eef2ed;
  border: 1rpx solid rgba(79, 102, 84, 0.16);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.notice-icon image {
  width: 32rpx;
  height: 32rpx;
}

.notice-content {
  flex: 1;
}

.notice-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2a27;
  margin-bottom: 15rpx;
}

.notice-text {
  display: block;
  font-size: 26rpx;
  color: #68716b;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.notice-text:last-child {
  margin-bottom: 0;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 18rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  flex: 1;
  height: 82rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.action-btn.primary {
  background: #26332d;
  color: #ffffff;
}

.action-btn.secondary {
  background: #ffffff;
  color: #4f6654;
  border: 1rpx solid rgba(79, 102, 84, 0.24);
}

.action-btn:active {
  transform: scale(0.95);
}

/* 底部装饰 */
.bottom-decoration {
  display: none;
}

.decoration-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  animation: float 6s ease-in-out infinite;
}

.circle-1 {
  width: 120rpx;
  height: 120rpx;
  bottom: -60rpx;
  left: 10%;
  animation-delay: 0s;
}

.circle-2 {
  width: 80rpx;
  height: 80rpx;
  bottom: -40rpx;
  right: 20%;
  animation-delay: 2s;
}

.circle-3 {
  width: 60rpx;
  height: 60rpx;
  bottom: -30rpx;
  left: 60%;
  animation-delay: 4s;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  50% {
    transform: translateY(-20rpx) rotate(180deg);
  }
}

/* 深色模式 */
.dark {
  background: #0f1518;
}

.dark .exchange-info,
.dark .virtual-info,
.dark .physical-info {
  background: #182028;
  border-color: rgba(229, 236, 231, 0.08);
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.22);
}

.dark .success-title {
  color: #eef5f2;
}

.dark .success-subtitle {
  color: rgba(236, 244, 241, 0.68);
}

.dark .success-icon {
  background: rgba(238, 245, 242, 0.08);
  border-color: rgba(229, 236, 231, 0.08);
}

.dark .info-label {
  color: rgba(236, 244, 241, 0.68);
}

.dark .info-value {
  color: #eef5f2;
}

.dark .virtual-title {
  color: #eef5f2;
}

.dark .virtual-tip {
  color: rgba(236, 244, 241, 0.48);
}

.dark .code-box {
  background: rgba(238, 245, 242, 0.08);
  border-color: rgba(229, 236, 231, 0.08);
}

.dark .code-label {
  color: rgba(236, 244, 241, 0.68);
}

.dark .code-value {
  color: #eef5f2;
}

.dark .copy-btn {
  background: #9aa083;
  color: #101619;
}

.dark .validity-label {
  color: rgba(236, 244, 241, 0.68);
}

.dark .usage-tips {
  background: rgba(151, 117, 62, 0.16);
  border-color: rgba(199, 179, 125, 0.22);
}

.dark .tips-title,
.dark .tips-content {
  color: #c7b37d;
}

.dark .notice-title {
  color: #eef5f2;
}

.dark .notice-text {
  color: rgba(236, 244, 241, 0.68);
}

.dark .action-btn.primary {
  background: #9aa083;
  color: #101619;
}

.dark .action-btn.secondary {
  background: #182028;
  color: #b8bfa0;
  border-color: rgba(154, 160, 131, 0.28);
}
