/* pages/points-exchange/points-exchange.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 48rpx;
  position: relative;
  overflow-x: hidden;
  box-sizing: border-box;
  color: #112033;
  background:
    radial-gradient(circle at top left, rgba(160, 189, 216, 0.18), transparent 32%),
    radial-gradient(circle at bottom right, rgba(212, 223, 234, 0.22), transparent 30%),
    linear-gradient(180deg, #eef3f8 0%, #f6f9fc 42%, #fafcff 100%);
}

.container.dark {
  color: #eff4fb;
  background:
    radial-gradient(circle at top left, rgba(92, 120, 147, 0.22), transparent 34%),
    radial-gradient(circle at bottom right, rgba(77, 98, 121, 0.16), transparent 30%),
    linear-gradient(180deg, #0d141d 0%, #111a25 44%, #0c1219 100%);
}

.container::before,
.container::after {
  content: '';
  position: absolute;
  pointer-events: none;
}

.container::before {
  top: 80rpx;
  left: -90rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.48), rgba(255, 255, 255, 0));
}

.container::after {
  right: -110rpx;
  bottom: 180rpx;
  width: 360rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(126, 160, 193, 0.14), rgba(126, 160, 193, 0));
}

.container.dark::before {
  background: radial-gradient(circle, rgba(173, 196, 221, 0.08), rgba(173, 196, 221, 0));
}

.container.dark::after {
  background: radial-gradient(circle, rgba(112, 146, 183, 0.12), rgba(112, 146, 183, 0));
}

.hero-panel,
.tab-container,
.product-container {
  position: relative;
  z-index: 1;
}

.hero-panel {
  margin: 24rpx 24rpx 18rpx;
  padding: 32rpx 30rpx;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  border: 1rpx solid rgba(154, 176, 198, 0.24);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(243, 247, 251, 0.84)),
    linear-gradient(135deg, rgba(255, 255, 255, 0.26), rgba(255, 255, 255, 0));
  box-shadow:
    0 18rpx 42rpx rgba(125, 145, 166, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(16rpx);
}

.container.dark .hero-panel {
  border-color: rgba(109, 126, 146, 0.26);
  background:
    linear-gradient(180deg, rgba(20, 28, 38, 0.96), rgba(14, 21, 29, 0.98)),
    linear-gradient(135deg, rgba(175, 196, 218, 0.05), rgba(175, 196, 218, 0));
  box-shadow:
    0 20rpx 46rpx rgba(4, 8, 14, 0.24),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.hero-panel::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.4), transparent 36%),
    linear-gradient(120deg, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0) 34%);
  pointer-events: none;
}

.container.dark .hero-panel::before {
  background:
    radial-gradient(circle at top right, rgba(173, 196, 221, 0.1), transparent 36%),
    linear-gradient(120deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0) 34%);
}

.hero-points,
.hero-meta {
  position: relative;
  z-index: 1;
}

.hero-points {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.hero-label {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  color: rgba(17, 32, 51, 0.56);
}

.container.dark .hero-label {
  color: rgba(226, 234, 243, 0.62);
}

.hero-value {
  font-size: 66rpx;
  line-height: 1;
  font-weight: 700;
  letter-spacing: -2rpx;
  color: #112033;
}

.container.dark .hero-value {
  color: #f3f7fc;
}

.hero-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  text-align: right;
}

.hero-tip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #365978;
  background: rgba(255, 255, 255, 0.48);
  border: 1rpx solid rgba(154, 176, 198, 0.22);
}

.container.dark .hero-tip {
  color: #d3dfeb;
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(109, 126, 146, 0.2);
}

.hero-note {
  font-size: 22rpx;
  color: rgba(17, 32, 51, 0.48);
}

.container.dark .hero-note {
  color: rgba(226, 234, 243, 0.52);
}

.tab-container {
  margin: 0 24rpx;
  padding: 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(154, 176, 198, 0.22);
  background: rgba(255, 255, 255, 0.76);
  box-shadow:
    0 12rpx 28rpx rgba(125, 145, 166, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(14rpx);
}

.container.dark .tab-container {
  border-color: rgba(109, 126, 146, 0.22);
  background: rgba(17, 25, 34, 0.82);
  box-shadow:
    0 16rpx 34rpx rgba(4, 8, 14, 0.22),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.tab-scroll {
  white-space: nowrap;
}

.tab-list {
  display: flex;
  gap: 10rpx;
}

.tab-item {
  position: relative;
  flex: none;
  min-width: 176rpx;
  padding: 18rpx 20rpx;
  text-align: center;
  border-radius: 999rpx;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(17, 32, 51, 0.48);
  letter-spacing: 0.2rpx;
}

.container.dark .tab-text {
  color: rgba(214, 223, 233, 0.58);
}

.tab-item.active {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(242, 247, 252, 0.88)),
    linear-gradient(135deg, rgba(137, 160, 184, 0.18), rgba(137, 160, 184, 0));
  box-shadow:
    0 10rpx 20rpx rgba(125, 145, 166, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.container.dark .tab-item.active {
  background:
    linear-gradient(180deg, rgba(37, 49, 63, 0.94), rgba(23, 32, 42, 0.98)),
    linear-gradient(135deg, rgba(139, 163, 188, 0.14), rgba(139, 163, 188, 0));
  box-shadow:
    0 10rpx 22rpx rgba(4, 8, 14, 0.22),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.06);
}

.tab-item.active .tab-text {
  color: #112033;
}

.container.dark .tab-item.active .tab-text {
  color: #f3f7fc;
}

.product-container {
  margin: 24rpx 20rpx 32rpx;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(128, 150, 171, 0.14);
  border-top: 4rpx solid #7d9db8;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.container.dark .loading-spinner {
  border-color: rgba(255, 255, 255, 0.08);
  border-top-color: #a8bfd5;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }

  100% {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 20rpx;
  color: rgba(17, 32, 51, 0.48);
  font-size: 28rpx;
}

.container.dark .loading-text {
  color: rgba(220, 229, 238, 0.6);
}

.product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.product-card {
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 34rpx;
  border: 1rpx solid rgba(154, 176, 198, 0.2);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(244, 248, 252, 0.88)),
    linear-gradient(135deg, rgba(255, 255, 255, 0.24), rgba(255, 255, 255, 0));
  box-shadow:
    0 18rpx 38rpx rgba(125, 145, 166, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
}

.container.dark .product-card {
  border-color: rgba(112, 127, 146, 0.18);
  background:
    linear-gradient(180deg, rgba(22, 29, 38, 0.98), rgba(14, 20, 28, 0.98)),
    linear-gradient(135deg, rgba(175, 196, 218, 0.06), rgba(175, 196, 218, 0));
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05),
    0 20rpx 42rpx rgba(4, 8, 14, 0.24);
}

.product-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.18), rgba(120, 160, 198, 0.32), rgba(255, 255, 255, 0.18));
  opacity: 0.55;
}

.container.dark .product-card::after {
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.04), rgba(168, 191, 213, 0.24), rgba(255, 255, 255, 0.04));
}

.product-card:active {
  transform: scale(0.985);
  border-color: rgba(132, 149, 170, 0.3);
  box-shadow:
    0 12rpx 28rpx rgba(125, 145, 166, 0.14),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.86);
}

.container.dark .product-card:active {
  box-shadow:
    0 14rpx 30rpx rgba(4, 8, 14, 0.24),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.product-card.out-of-stock {
  opacity: 0.56;
}

.card-glow {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 46rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.24), transparent);
  pointer-events: none;
}

.container.dark .card-glow {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.06), transparent);
}

.product-tag-container {
  position: relative;
  margin: 18rpx 18rpx 0;
  padding: 24rpx 18rpx 22rpx;
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.42);
  border: 1rpx solid rgba(154, 176, 198, 0.14);
}

.container.dark .product-tag-container {
  background: rgba(255, 255, 255, 0.03);
  border-color: rgba(109, 126, 146, 0.14);
}

.product-info {
  margin: 18rpx 18rpx 0;
  padding: 20rpx 22rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 16rpx;
  flex: 1;
  box-sizing: border-box;
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(243, 247, 251, 0.9)),
    linear-gradient(135deg, rgba(143, 167, 191, 0.08), rgba(143, 167, 191, 0));
  border: 1rpx solid rgba(154, 176, 198, 0.14);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.88);
}

.container.dark .product-info {
  background:
    linear-gradient(180deg, rgba(31, 40, 52, 0.92), rgba(21, 29, 38, 0.96)),
    linear-gradient(135deg, rgba(143, 167, 191, 0.08), rgba(143, 167, 191, 0));
  border-color: rgba(109, 126, 146, 0.14);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.product-points {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8rpx;
  margin: 0;
}

.points-number {
  font-size: 42rpx;
  font-weight: 700;
  color: #112033;
  letter-spacing: -0.4rpx;
}

.container.dark .points-number {
  color: #f4f7fb;
}

.points-unit {
  margin-left: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(17, 32, 51, 0.44);
}

.container.dark .points-unit {
  color: rgba(211, 220, 229, 0.82);
}

.product-stock {
  align-self: flex-start;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: rgba(17, 32, 51, 0.46);
  font-weight: 500;
  background: rgba(122, 152, 181, 0.1);
}

.container.dark .product-stock {
  color: rgba(206, 216, 228, 0.58);
  background: rgba(168, 191, 213, 0.08);
}

.exchange-btn-container {
  width: 100%;
  padding: 18rpx;
  box-sizing: border-box;
  display: flex;
  justify-content: center;
  align-items: center;
}

.exchange-btn {
  width: 100%;
  min-width: 0;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0;
  padding: 0 18rpx;
  box-sizing: border-box;
  display: block;
  border-radius: 22rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #f7fbff;
  border: 1rpx solid rgba(82, 111, 140, 0.32);
  background: linear-gradient(135deg, #45627b 0%, #7f9eb8 100%);
  box-shadow: 0 12rpx 24rpx rgba(82, 111, 140, 0.22);
  transition: transform 0.2s ease, border-color 0.2s ease;
}

.container.dark .exchange-btn {
  color: #eef4fb;
  border-color: rgba(120, 143, 168, 0.24);
  background:
    linear-gradient(180deg, rgba(44, 58, 74, 0.96), rgba(27, 35, 46, 0.98)),
    radial-gradient(circle at top right, rgba(109, 149, 183, 0.16), transparent 54%);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05),
    0 10rpx 22rpx rgba(5, 10, 16, 0.18);
}

.exchange-btn:active {
  transform: scale(0.99);
  border-color: rgba(138, 161, 187, 0.34);
}

.exchange-btn::after {
  border: none;
}

.exchange-btn.disabled {
  color: rgba(17, 32, 51, 0.26);
  border-color: rgba(154, 176, 198, 0.16);
  background: rgba(236, 241, 246, 0.9);
  box-shadow: none;
}

.container.dark .exchange-btn.disabled {
  color: rgba(218, 224, 231, 0.34);
  border-color: rgba(102, 110, 121, 0.12);
  background: linear-gradient(180deg, rgba(27, 32, 39, 0.98), rgba(18, 22, 29, 0.98));
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 140rpx 0;
}

.empty-icon {
  width: 140rpx;
  height: 140rpx;
  opacity: 0.6;
}

.empty-text {
  margin-top: 32rpx;
  color: rgba(17, 32, 51, 0.46);
  font-size: 30rpx;
  font-weight: 500;
}

.container.dark .empty-text {
  color: rgba(220, 229, 238, 0.62);
}

/* GearSage UI polish: restrained gear-database exchange tone */
.container {
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 56rpx;
  color: #1f2a27;
  background: #f4f5f1;
}

.container.dark {
  color: #eef2ed;
  background: #101619;
}

.container::before,
.container::after {
  display: none;
}

.hero-panel,
.tab-container,
.product-card {
  border-radius: 18rpx;
  border: 1rpx solid rgba(58, 68, 62, 0.12);
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(31, 42, 39, 0.05);
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
}

.container.dark .hero-panel,
.container.dark .tab-container,
.container.dark .product-card {
  border-color: rgba(238, 242, 237, 0.08);
  background: #18201d;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.22);
}

.hero-panel {
  margin: 22rpx 0 20rpx;
  padding: 30rpx 28rpx;
  gap: 20rpx;
}

.hero-panel::before {
  display: none;
}

.hero-label {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  letter-spacing: 0;
  color: #68716b;
}

.container.dark .hero-label {
  color: rgba(238, 242, 237, 0.58);
}

.hero-value {
  font-size: 66rpx;
  letter-spacing: 0;
  color: #1f2a27;
}

.container.dark .hero-value {
  color: #f1f4ee;
}

.hero-tip {
  padding: 10rpx 16rpx;
  color: #4f6654;
  background: #eef2ed;
  border-color: rgba(79, 102, 84, 0.2);
}

.container.dark .hero-tip {
  color: #d8decb;
  background: rgba(154, 160, 131, 0.16);
  border-color: rgba(238, 242, 237, 0.08);
}

.hero-note {
  color: #68716b;
}

.container.dark .hero-note {
  color: rgba(238, 242, 237, 0.56);
}

.tab-container {
  margin: 0;
  padding: 8rpx;
  border-radius: 18rpx;
}

.tab-list {
  gap: 8rpx;
}

.tab-item {
  min-width: 168rpx;
  padding: 16rpx 20rpx;
  border-radius: 14rpx;
}

.tab-text {
  font-size: 27rpx;
  color: #68716b;
  letter-spacing: 0;
}

.container.dark .tab-text {
  color: rgba(238, 242, 237, 0.58);
}

.tab-item.active {
  background: #eef2ed;
  box-shadow: none;
}

.container.dark .tab-item.active {
  background: rgba(154, 160, 131, 0.18);
  box-shadow: none;
}

.tab-item.active .tab-text {
  color: #1f2a27;
}

.container.dark .tab-item.active .tab-text {
  color: #f1f4ee;
}

.product-container {
  margin: 22rpx 0 32rpx;
}

.product-grid {
  gap: 18rpx;
}

.product-card {
  overflow: hidden;
  transition: transform 0.18s ease, border-color 0.18s ease;
}

.product-card::after,
.card-glow {
  display: none;
}

.product-card:active {
  transform: scale(0.99);
  border-color: rgba(79, 102, 84, 0.22);
  box-shadow: 0 6rpx 18rpx rgba(31, 42, 39, 0.06);
}

.container.dark .product-card:active {
  border-color: rgba(238, 242, 237, 0.12);
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.24);
}

.product-card.out-of-stock {
  opacity: 0.62;
}

.product-tag-container {
  margin: 16rpx 16rpx 0;
  padding: 22rpx 16rpx;
  min-height: 108rpx;
  border-radius: 14rpx;
  background: #f7f8f5;
  border-color: rgba(58, 68, 62, 0.1);
}

.container.dark .product-tag-container {
  background: rgba(255, 255, 255, 0.035);
  border-color: rgba(238, 242, 237, 0.07);
}

.product-info {
  margin: 14rpx 16rpx 0;
  padding: 18rpx 18rpx;
  gap: 14rpx;
  border-radius: 14rpx;
  background: #fbfcf9;
  border-color: rgba(58, 68, 62, 0.1);
  box-shadow: none;
}

.container.dark .product-info {
  background: rgba(255, 255, 255, 0.035);
  border-color: rgba(238, 242, 237, 0.07);
  box-shadow: none;
}

.points-number {
  font-size: 40rpx;
  letter-spacing: 0;
  color: #1f2a27;
}

.container.dark .points-number {
  color: #eef2ed;
}

.points-unit {
  margin-left: 4rpx;
  color: #68716b;
}

.container.dark .points-unit {
  color: rgba(238, 242, 237, 0.6);
}

.product-stock {
  padding: 7rpx 13rpx;
  color: #68716b;
  background: #eef2ed;
}

.container.dark .product-stock {
  color: rgba(238, 242, 237, 0.58);
  background: rgba(154, 160, 131, 0.14);
}

.exchange-btn-container {
  padding: 16rpx;
}

.exchange-btn {
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 12rpx;
  color: #ffffff;
  border-color: #26332d;
  background: #26332d;
  box-shadow: 0 8rpx 18rpx rgba(31, 42, 39, 0.16);
}

.container.dark .exchange-btn {
  color: #101619;
  border-color: #b9c0a1;
  background: #b9c0a1;
  box-shadow: none;
}

.exchange-btn:active {
  border-color: #4f6654;
}

.exchange-btn.disabled {
  color: #8a918a;
  border-color: rgba(58, 68, 62, 0.1);
  background: #f4f5f1;
}

.container.dark .exchange-btn.disabled {
  color: rgba(238, 242, 237, 0.34);
  border-color: rgba(238, 242, 237, 0.06);
  background: rgba(255, 255, 255, 0.03);
}

.loading-spinner {
  border-color: #e4e8df;
  border-top-color: #6c7654;
}

.container.dark .loading-spinner {
  border-color: rgba(238, 242, 237, 0.1);
  border-top-color: #b9c0a1;
}

.loading-text,
.empty-text {
  color: #68716b;
}

.container.dark .loading-text,
.container.dark .empty-text {
  color: rgba(238, 242, 237, 0.6);
}

.empty-state {
  margin-top: 16rpx;
  padding: 128rpx 0;
  border-radius: 18rpx;
  border: 1rpx solid rgba(58, 68, 62, 0.1);
  background: #ffffff;
}

.container.dark .empty-state {
  border-color: rgba(238, 242, 237, 0.08);
  background: #18201d;
}
