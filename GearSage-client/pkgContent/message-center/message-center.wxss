.message-page {
  min-height: 100vh;
  background: #f4f5f1;
  padding: 24rpx 28rpx 44rpx;
  box-sizing: border-box;
}

.message-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
  padding: 4rpx 2rpx 0;
}

.message-summary {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.message-title {
  position: relative;
  padding-left: 18rpx;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #1f2a27;
}

.message-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 8rpx;
  width: 6rpx;
  height: 26rpx;
  border-radius: 4rpx;
  background: #6c7654;
}

.message-subtitle {
  padding-left: 18rpx;
  font-size: 23rpx;
  color: #68716b;
}

.mark-all-btn {
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  background: #eef2ed;
  border: 1rpx solid rgba(79, 102, 84, 0.2);
  color: #4f6654;
  font-size: 24rpx;
  font-weight: 500;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.message-item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 24rpx 24rpx 24rpx 22rpx;
  border-radius: 10rpx;
  background: #ffffff;
  border: 1rpx solid rgba(58, 68, 62, 0.11);
  border-left: 4rpx solid #6c7654;
  box-shadow: 0 6rpx 18rpx rgba(31, 42, 39, 0.045);
}

.message-item.read {
  border-left-color: #d8ddd2;
  box-shadow: none;
}

.message-main {
  flex: 1;
  min-width: 0;
}

.message-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 12rpx;
}

.message-item-title {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #1f2a27;
}

.message-time {
  font-size: 22rpx;
  color: #8a918a;
  white-space: nowrap;
}

.message-content,
.message-reason {
  display: block;
  font-size: 25rpx;
  line-height: 1.6;
  color: #52605b;
}

.message-reason {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 8rpx;
  background: #f3efe2;
  color: #766f4f;
}

.unread-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: #9a4a42;
  flex-shrink: 0;
}

.loading-container,
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 140rpx 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(58, 68, 62, 0.1);
  border-radius: 10rpx;
}

.loading-text,
.empty-subtitle {
  font-size: 25rpx;
  color: #8a918a;
}

.empty-title {
  font-size: 30rpx;
  color: #1f2a27;
  margin-bottom: 12rpx;
  font-weight: 700;
}

.message-page.dark {
  background: #0f1518;
}

.dark .message-title,
.dark .empty-title,
.dark .message-item-title {
  color: #eef5f2;
}

.dark .message-subtitle,
.dark .loading-text,
.dark .empty-subtitle,
.dark .message-time {
  color: rgba(236, 244, 241, 0.48);
}

.dark .message-item {
  background: #182028;
  border-color: rgba(229, 236, 231, 0.08);
  border-left-color: rgba(154, 160, 131, 0.34);
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.22);
}

.dark .message-item.read {
  border-left-color: rgba(238, 245, 242, 0.12);
  box-shadow: none;
}

.dark .message-content {
  color: rgba(236, 244, 241, 0.68);
}

.dark .message-reason {
  background: rgba(151, 117, 62, 0.16);
  color: #c7b37d;
}

.dark .mark-all-btn {
  background: rgba(154, 160, 131, 0.12);
  border-color: rgba(154, 160, 131, 0.24);
  color: #b8bfa0;
}

.dark .loading-container,
.dark .empty-container {
  background: #182028;
  border-color: rgba(229, 236, 231, 0.08);
}
