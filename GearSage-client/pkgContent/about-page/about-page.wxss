/* pages/about-page/about-page.wxss */

.about-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* 暗黑模式 */
.about-container.dark {
  background-color: #1a1a1a;
  color: #e0e0e0;
}

.about-content {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.dark .about-content {
  background-color: #2a2a2a;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.2);
}

/* 富文本样式 */
.rich-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.dark .rich-content {
  color: #e0e0e0;
}

/* 标题样式 */
.main-title, .title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
}

.dark .main-title, .dark .title {
  color: #ffffff;
}

.subheading, .subtitle {
  font-size: 32rpx;
  font-weight: bold;
  margin: 20rpx 0;
  color: #444;
}

.dark .subheading, .dark .subtitle {
  color: #d0d0d0;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin: 16rpx 0;
  color: #555;
}

.dark .section-title {
  color: #c0c0c0;
}

.section-content, .content {
  margin-bottom: 20rpx;
}

/* 列表样式 */
.check-list {
  padding-left: 30rpx;
}

.check-list li {
  margin-bottom: 10rpx;
}

/* 强调文本 */
.highlight {
  color: #e74c3c;
  font-weight: bold;
}

.dark .highlight {
  color: #ff6b6b;
}