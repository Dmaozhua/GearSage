@import "/styles/dark.wxss";

page {
  background: #f3f5f1;
}

.set-edit-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
  background: #f3f5f1;
  color: #1f2a27;
}

.set-edit-page.dark {
  background: #10161a;
  color: #edf4ef;
}

.page-state {
  padding: 84rpx 0;
  text-align: center;
  color: #68716b;
}

.form-card {
  margin-bottom: 16rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(57, 72, 63, 0.1);
}

.form-label,
.section-title {
  margin-bottom: 12rpx;
  font-size: 25rpx;
  font-weight: 700;
  color: #26352f;
}

.with-gap {
  margin-top: 18rpx;
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
}

.form-tip,
.selector-empty,
.gear-meta {
  font-size: 22rpx;
  line-height: 1.5;
  color: #6d776f;
}

.text-input,
.note-input {
  box-sizing: border-box;
  width: 100%;
  border-radius: 8rpx;
  border: 1rpx solid rgba(57, 72, 63, 0.12);
  background: rgba(255, 255, 255, 0.92);
  color: #1f2a27;
  font-size: 26rpx;
}

.text-input {
  height: 72rpx;
  padding: 0 20rpx;
}

.note-input {
  min-height: 150rpx;
  padding: 18rpx 20rpx;
}

.gear-option {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid rgba(57, 72, 63, 0.08);
}

.gear-option:first-of-type {
  border-top: 0;
}

.gear-option.active .gear-check {
  background: #33483e;
  color: #fff;
}

.gear-copy {
  flex: 1;
  min-width: 0;
}

.gear-name {
  display: block;
  font-size: 27rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #1f2a27;
}

.gear-check {
  flex: 0 0 auto;
  min-width: 86rpx;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  background: #edf1ec;
  color: #30443b;
  font-size: 22rpx;
  text-align: center;
}

.save-btn {
  width: 100%;
  height: 76rpx;
  margin: 22rpx 0 0;
  border-radius: 8rpx;
  background: #33483e;
  color: #fff;
  font-size: 26rpx;
  line-height: 76rpx;
}

.dark .form-card,
.dark .text-input,
.dark .note-input {
  background: rgba(238, 245, 242, 0.07);
  border-color: rgba(238, 245, 242, 0.1);
  color: #edf4ef;
}

.dark .form-label,
.dark .section-title,
.dark .gear-name {
  color: #edf4ef;
}
