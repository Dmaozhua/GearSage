<!--pages/my-publish/my-publish.wxml-->
<!-- 自定义导航栏 -->
<custom-navbar 
  id="custom-navbar"
  title="我的发布" 
  show-back="{{true}}"
  background-color="#BDC3C7"
  text-color="#000000">
</custom-navbar>

<view class="publish-container {{containerClass}}" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
  <!-- 状态切换标签 -->
  <view class="tab-container">
    <view class="tab-item {{activeTab === 2 ? 'active' : ''}}" bindtap="onTabChange" data-tab="2">
      <text class="tab-text">已发布</text>
      <text class="tab-count" wx:if="{{publishedCount > 0}}">({{publishedCount}})</text>
    </view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" bindtap="onTabChange" data-tab="1">
      <text class="tab-text">审核中</text>
      <text class="tab-count" wx:if="{{pendingCount > 0}}">({{pendingCount}})</text>
    </view>
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" bindtap="onTabChange" data-tab="0">
      <text class="tab-text">未通过</text>
      <text class="tab-count" wx:if="{{notpassedCount > 0}}">({{notpassedCount}})</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 帖子列表 -->
  <view class="posts-list" wx:if="{{!loading}}">
    <!-- 已发布的帖子 -->
    <view wx:if="{{activeTab === 2}}">
      <view class="post-item" wx:for="{{publishedPosts}}" wx:key="id" bindtap="onPostTap" data-post="{{item}}">
        <view class="post-header">
          <text class="post-title">{{item.title}}</text>
          <view class="post-status published">
            <text class="status-text">已发布</text>
          </view>
        </view>
        <text class="post-content">{{item.content}}</text>
        <view class="post-footer">
          <text class="post-time">{{item.publishTime}}</text>
          <view class="post-stats">
            <text class="stat-item">👍 {{item.likesCount || 0}}</text>
            <text class="stat-item">💬 {{item.commentsCount || 0}}</text>
            <text class="stat-item">👁 {{item.viewsCount || 0}}</text>
          </view>
        </view>
      </view>
      
      <!-- 已发布列表为空 -->
      <view class="empty-container" wx:if="{{publishedPosts.length === 0}}">
        <image class="empty-icon" src="/images/empty.png" mode="aspectFit" />
        <text class="empty-text">暂无已发布的帖子</text>
        <text class="empty-subtitle">快去发布你的第一篇帖子吧</text>
      </view>
    </view>

    <!-- 审核中的帖子 -->
    <view wx:if="{{activeTab === 1}}">
      <view class="post-item" wx:for="{{pendingPosts}}" wx:key="id" bindtap="onPostTap" data-post="{{item}}">
        <view class="post-header">
          <text class="post-title">{{item.title}}</text>
          <view class="post-status pending">
            <text class="status-text">审核中</text>
          </view>
        </view>
        <text class="post-content">{{item.content}}</text>
        <view class="post-footer">
          <text class="post-time">{{item.createTime}}</text>
        </view>
      </view>
      
      <!-- 审核中列表为空 -->
      <view class="empty-container" wx:if="{{pendingPosts.length === 0}}">
        <image class="empty-icon" src="/images/empty.png" mode="aspectFit" />
        <text class="empty-text">暂无审核中的帖子</text>
        <text class="empty-subtitle">发布的帖子会在这里显示</text>
      </view>
    </view>

    <!-- 未通过的帖子 -->
    <view wx:if="{{activeTab === 0}}">
      <view class="post-item" wx:for="{{notpassedPosts}}" wx:key="id" bindtap="onPostTap" data-post="{{item}}">
        <view class="post-header">
          <text class="post-title">{{item.title}}</text>
          <view class="post-status rejected">
            <text class="status-text">未通过</text>
          </view>
        </view>
        <text class="post-content">{{item.content}}</text>
        <view class="post-footer">
          <text class="post-time">{{item.createTime}}</text>
          <view class="post-actions">
            <!-- <text class="action-btn edit" bindtap="onEditPost" data-post="{{item}}">编辑</text>
            <text class="action-btn delete" bindtap="onDeletePost" data-post="{{item}}">删除</text> -->
          </view>
        </view>
      </view>
      
      <!-- 未通过列表为空 -->
      <view class="empty-container" wx:if="{{notpassedPosts.length === 0}}">
        <image class="empty-icon" src="/images/empty.png" mode="aspectFit" />
        <text class="empty-text">暂无未通过的帖子</text>
        <text class="empty-subtitle">被驳回的帖子会在这里显示</text>
      </view>
    </view>
  </view>

  <!-- 上拉加载更多 -->
  <view class="load-more" wx:if="{{!loading && hasMore}}">
    <text class="load-more-text">上拉加载更多</text>
  </view>

  <!-- 没有更多数据 -->
  <view class="no-more" wx:if="{{!loading && !hasMore && (pendingPosts.length > 0 || publishedPosts.length > 0 || notpassedPosts.length > 0)}}">
    <text class="no-more-text">没有更多数据了</text>
  </view>
</view>