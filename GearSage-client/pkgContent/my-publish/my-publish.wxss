/* pages/my-publish/my-publish.wxss */
@import "../../styles/dark.wxss";
.publish-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

/* 标签切换 */
.tab-container {
  display: flex;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e0e0e0;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  padding: 30rpx 0;
  text-align: center;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
}

.tab-item.active {
  color: #007AFF;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #007AFF;
  border-radius: 2rpx;
}

.tab-text {
  font-size: 32rpx;
  font-weight: 500;
}

.tab-count {
  font-size: 24rpx;
  color: #999999;
}

.tab-item.active .tab-count {
  color: #007AFF;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top: 4rpx solid #007AFF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999999;
}

/* 帖子列表 */
.posts-list {
  padding: 0 30rpx;
}

.post-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.post-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.4;
  margin-right: 20rpx;
}

.post-status {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.post-status.pending {
  background-color: #fff3cd;
  color: #856404;
}

.post-status.published {
  background-color: #d4edda;
  color: #155724;
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
}

.post-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.5;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.reject-tip {
  display: block;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #b85c00;
}

.post-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.post-time {
  font-size: 24rpx;
  color: #999999;
}

.post-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.action-btn.edit {
  background-color: #e3f2fd;
  color: #1976d2;
}

.action-btn.delete {
  background-color: #ffebee;
  color: #d32f2f;
}

.post-stats {
  display: flex;
  gap: 18rpx;
  flex-wrap: wrap;
}

.stat-item {
  font-size: 24rpx;
  color: #999999;
  display: flex;
  align-items: center;
  line-height: 1;
  min-width: 64rpx;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.6;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.empty-subtitle {
  font-size: 28rpx;
  color: #999999;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx 0;
}

.load-more-text {
  font-size: 28rpx;
  color: #999999;
}

.no-more {
  text-align: center;
  padding: 30rpx 0;
}

.no-more-text {
  font-size: 28rpx;
  color: #cccccc;
}

/* 夜间模式 */
.publish-container.dark-mode {
  background-color: #1a1a1a;
}

.dark-mode .tab-container {
  background-color: #2d2d2d;
  border-bottom-color: #404040;
}

.dark-mode .tab-item {
  color: #cccccc;
}

.dark-mode .tab-item.active {
  color: #409eff;
}

.dark-mode .tab-item.active::after {
  background-color: #409eff;
}

.dark-mode .tab-count {
  color: #888888;
}

.dark-mode .tab-item.active .tab-count {
  color: #409eff;
}

.dark-mode .loading-spinner {
  border-color: #404040;
  border-top-color: #409eff;
}

.dark-mode .loading-text {
  color: #888888;
}

.dark-mode .post-item {
  background-color: #2d2d2d;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.dark-mode .post-title {
  color: #ffffff;
}

.dark-mode .post-content {
  color: #cccccc;
}

.dark-mode .reject-tip {
  color: #ffb74d;
}

.dark-mode .post-time {
  color: #888888;
}

.dark-mode .stat-item {
  color: #888888;
}

.dark-mode .action-btn.edit {
  background-color: #1e3a5f;
  color: #64b5f6;
}

.dark-mode .action-btn.delete {
  background-color: #4a1e1e;
  color: #ef5350;
}

.dark-mode .post-status.pending {
  background-color: #3d3520;
  color: #ffc107;
}

.dark-mode .post-status.published {
  background-color: #1e3a2e;
  color: #4caf50;
}

.dark-mode .empty-text {
  color: #cccccc;
}

.dark-mode .empty-subtitle {
  color: #888888;
}

.dark-mode .load-more-text {
  color: #888888;
}

.dark-mode .no-more-text {
  color: #666666;
}
