/* pages/my-publish/my-publish.wxss */
@import "../../styles/dark.wxss";
.publish-container {
  min-height: 100vh;
  background-color: #f4f5f1;
  padding-bottom: 40rpx;
}

/* 标签切换 */
.tab-container {
  display: flex;
  background-color: #ffffff;
  border: 1rpx solid rgba(58, 68, 62, 0.11);
  border-radius: 10rpx;
  margin: 24rpx 28rpx 22rpx;
  box-shadow: 0 6rpx 18rpx rgba(31, 42, 39, 0.045);
  overflow: hidden;
}

.tab-item {
  flex: 1;
  min-height: 84rpx;
  padding: 0;
  text-align: center;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
}

.tab-item.active {
  color: #1f2a27;
  background: #f6f7f3;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #6c7654;
  border-radius: 2rpx;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #59655f;
}

.tab-item.active .tab-text {
  color: #1f2a27;
}

.tab-count {
  font-size: 23rpx;
  color: #8a918a;
}

.tab-item.active .tab-count {
  color: #6c7654;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e2e5de;
  border-top: 4rpx solid #6c7654;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #8a918a;
}

/* 帖子列表 */
.posts-list {
  padding: 0 28rpx;
}

.post-item {
  background-color: #ffffff;
  border: 1rpx solid rgba(58, 68, 62, 0.11);
  border-radius: 10rpx;
  padding: 26rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 6rpx 18rpx rgba(31, 42, 39, 0.045);
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.post-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2a27;
  line-height: 1.4;
  margin-right: 20rpx;
}

.post-status {
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  border: 1rpx solid transparent;
}

.post-status.pending {
  background-color: #f3efe2;
  border-color: #ded2a9;
  color: #766f4f;
}

.post-status.published {
  background-color: #eef2ed;
  border-color: #cfdbcf;
  color: #4f6654;
}

.post-status.rejected {
  background-color: #f3e7e4;
  border-color: #d9bdb8;
  color: #9a4a42;
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
}

.post-content {
  font-size: 26rpx;
  color: #68716b;
  line-height: 1.55;
  margin-bottom: 18rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.reject-tip {
  display: block;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #8b6d32;
}

.post-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.post-time {
  font-size: 24rpx;
  color: #8a918a;
}

.post-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.action-btn.edit {
  background-color: #eef2ed;
  color: #4f6654;
}

.action-btn.delete {
  background-color: #f3e7e4;
  color: #9a4a42;
}

.post-stats {
  display: flex;
  gap: 18rpx;
  flex-wrap: wrap;
}

.stat-item {
  font-size: 24rpx;
  color: #8a918a;
  display: flex;
  align-items: center;
  line-height: 1;
  min-width: 64rpx;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx 28rpx;
  margin: 0 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(58, 68, 62, 0.1);
  border-radius: 10rpx;
}

.empty-icon {
  width: 150rpx;
  height: 150rpx;
  opacity: 0.42;
  margin-bottom: 26rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #1f2a27;
  margin-bottom: 10rpx;
}

.empty-subtitle {
  font-size: 25rpx;
  color: #8a918a;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx 0;
}

.load-more-text {
  font-size: 26rpx;
  color: #8a918a;
}

.no-more {
  text-align: center;
  padding: 30rpx 0;
}

.no-more-text {
  font-size: 26rpx;
  color: #a3aaa3;
}

/* 夜间模式 */
.publish-container.dark-mode {
  background-color: #0f1518;
}

.dark-mode .tab-container {
  background-color: #182028;
  border-color: rgba(229, 236, 231, 0.08);
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.22);
}

.dark-mode .tab-item {
  color: rgba(236, 244, 241, 0.68);
}

.dark-mode .tab-text {
  color: rgba(236, 244, 241, 0.68);
}

.dark-mode .tab-item.active {
  color: #eef5f2;
  background: rgba(238, 245, 242, 0.06);
}

.dark-mode .tab-item.active .tab-text {
  color: #eef5f2;
}

.dark-mode .tab-item.active::after {
  background-color: #9aa083;
}

.dark-mode .tab-count {
  color: rgba(236, 244, 241, 0.48);
}

.dark-mode .tab-item.active .tab-count {
  color: #9aa083;
}

.dark-mode .loading-spinner {
  border-color: rgba(229, 236, 231, 0.08);
  border-top-color: #9aa083;
}

.dark-mode .loading-text {
  color: rgba(236, 244, 241, 0.48);
}

.dark-mode .post-item {
  background-color: #182028;
  border-color: rgba(229, 236, 231, 0.08);
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.22);
}

.dark-mode .post-title {
  color: #ffffff;
}

.dark-mode .post-content {
  color: rgba(236, 244, 241, 0.68);
}

.dark-mode .reject-tip {
  color: #c0aa72;
}

.dark-mode .post-time {
  color: rgba(236, 244, 241, 0.48);
}

.dark-mode .stat-item {
  color: rgba(236, 244, 241, 0.48);
}

.dark-mode .action-btn.edit {
  background-color: rgba(154, 160, 131, 0.12);
  color: #b8bfa0;
}

.dark-mode .action-btn.delete {
  background-color: rgba(154, 74, 66, 0.16);
  color: #d59a92;
}

.dark-mode .post-status.pending {
  background-color: rgba(151, 117, 62, 0.16);
  color: #c7b37d;
}

.dark-mode .post-status.published {
  background-color: rgba(79, 102, 84, 0.2);
  color: #a7b79c;
}

.dark-mode .post-status.rejected {
  background-color: rgba(154, 74, 66, 0.18);
  color: #d59a92;
}

.dark-mode .empty-text {
  color: #cccccc;
}

.dark-mode .empty-subtitle {
  color: #888888;
}

.dark-mode .empty-container {
  background: #182028;
  border-color: rgba(229, 236, 231, 0.08);
}

.dark-mode .load-more-text {
  color: #888888;
}

.dark-mode .no-more-text {
  color: #666666;
}
