.timeline-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(164, 193, 218, 0.24), transparent 34%),
    linear-gradient(180deg, #eef5fb 0%, #f7fbff 40%, #ffffff 100%);
}

.timeline-page.dark {
  background:
    radial-gradient(circle at top right, rgba(112, 143, 172, 0.16), transparent 34%),
    linear-gradient(180deg, #0d1620 0%, #101b27 42%, #09121a 100%);
}

.timeline-shell {
  padding: 28rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.hero-card,
.panel-card,
.cta-card,
.empty-state,
.skeleton-card {
  margin-bottom: 24rpx;
  border-radius: 32rpx;
}

.hero-card,
.panel-card,
.cta-card,
.empty-state {
  overflow: hidden;
  border: 1rpx solid rgba(151, 177, 201, 0.22);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(246, 250, 255, 0.9)),
    linear-gradient(135deg, rgba(170, 196, 219, 0.08), rgba(170, 196, 219, 0));
  box-shadow:
    0 20rpx 44rpx rgba(121, 145, 170, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.88);
}

.timeline-page.dark .hero-card,
.timeline-page.dark .panel-card,
.timeline-page.dark .cta-card,
.timeline-page.dark .empty-state {
  border-color: rgba(103, 124, 147, 0.24);
  background:
    linear-gradient(180deg, rgba(19, 28, 39, 0.96), rgba(14, 22, 31, 0.98)),
    linear-gradient(135deg, rgba(132, 160, 188, 0.08), rgba(132, 160, 188, 0));
  box-shadow:
    0 22rpx 50rpx rgba(3, 8, 14, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.hero-card {
  position: relative;
  min-height: 440rpx;
}

.hero-cover,
.hero-overlay {
  position: absolute;
  inset: 0;
}

.hero-cover {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  background:
    linear-gradient(180deg, rgba(18, 33, 52, 0.12), rgba(18, 33, 52, 0.82)),
    linear-gradient(135deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0));
}

.hero-body {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  min-height: 440rpx;
  padding: 32rpx 28rpx;
  box-sizing: border-box;
}

.hero-badge,
.hero-category,
.tag-item {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-badge {
  align-self: flex-start;
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #f3f7fc;
  letter-spacing: 2rpx;
}

.hero-meta {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 16rpx;
}

.hero-category {
  background: rgba(255, 255, 255, 0.14);
  color: #f3f7fc;
}

.hero-time {
  font-size: 24rpx;
  color: rgba(243, 247, 252, 0.76);
}

.hero-title,
.panel-title,
.cta-title,
.empty-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 700;
}

.hero-title {
  color: #f8fbff;
}

.panel-title,
.cta-title,
.empty-title {
  color: #102033;
}

.timeline-page.dark .panel-title,
.timeline-page.dark .cta-title,
.timeline-page.dark .empty-title {
  color: #eef5fb;
}

.author-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 22rpx;
}

.author-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.author-copy {
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #f7fbff;
}

.author-stats,
.panel-text,
.cta-desc,
.cta-tip,
.empty-desc,
.fact-label {
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(16, 32, 51, 0.68);
}

.timeline-page.dark .panel-text,
.timeline-page.dark .cta-desc,
.timeline-page.dark .cta-tip,
.timeline-page.dark .empty-desc,
.timeline-page.dark .fact-label {
  color: rgba(228, 237, 246, 0.72);
}

.author-stats {
  color: rgba(247, 251, 255, 0.72);
}

.panel-card,
.cta-card,
.empty-state {
  padding: 30rpx 28rpx;
}

.facts-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 22rpx;
}

.fact-item {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(245, 249, 253, 0.86);
}

.timeline-page.dark .fact-item {
  background: rgba(255, 255, 255, 0.03);
}

.fact-value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
  color: #102033;
}

.timeline-page.dark .fact-value {
  color: #eef5fb;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.tag-item {
  color: #3c5d7a;
  background: rgba(234, 243, 250, 0.92);
}

.timeline-page.dark .tag-item {
  color: #d9e7f3;
  background: rgba(255, 255, 255, 0.04);
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.gallery-image {
  width: 100%;
  height: 200rpx;
  border-radius: 22rpx;
}

.cta-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.primary-btn,
.ghost-btn,
.empty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.primary-btn {
  flex: 1;
  color: #f8fbff;
  background: linear-gradient(135deg, #4c6a84 0%, #7a9ab6 100%);
}

.ghost-btn {
  flex: 1;
  color: #294764;
  background: rgba(241, 247, 252, 0.96);
  border: 1rpx solid rgba(113, 139, 163, 0.2);
}

.timeline-page.dark .ghost-btn {
  color: #dbe7f2;
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(132, 160, 188, 0.16);
}

.primary-btn::after,
.ghost-btn::after,
.empty-btn::after {
  border: none;
}

.cta-tip {
  display: block;
  margin-top: 18rpx;
}

.empty-btn {
  margin-top: 26rpx;
  color: #f8fbff;
  background: linear-gradient(135deg, #4c6a84 0%, #7a9ab6 100%);
}

.skeleton-card {
  background: linear-gradient(
    90deg,
    rgba(182, 198, 214, 0.14) 0%,
    rgba(255, 255, 255, 0.55) 50%,
    rgba(182, 198, 214, 0.14) 100%
  );
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
}

.timeline-page.dark .skeleton-card {
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0.05) 0%,
    rgba(170, 190, 212, 0.14) 50%,
    rgba(255, 255, 255, 0.05) 100%
  );
  background-size: 200% 100%;
}

.skeleton-hero {
  height: 420rpx;
}

.skeleton-line {
  height: 180rpx;
}

.skeleton-grid {
  height: 240rpx;
}

@keyframes shimmer {
  0% {
    background-position: 200% 0;
  }

  100% {
    background-position: -200% 0;
  }
}
