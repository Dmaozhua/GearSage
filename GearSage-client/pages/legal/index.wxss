page {
  background: #f4f5f1;
}

.legal-page {
  height: 100vh;
  box-sizing: border-box;
  background: #f4f5f1;
}

.legal-header {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 36rpx 32rpx 22rpx;
}

.legal-kicker {
  color: #657369;
  font-size: 24rpx;
  font-weight: 600;
}

.legal-title {
  color: #1f2a27;
  font-size: 42rpx;
  font-weight: 760;
  line-height: 1.25;
}

.legal-updated {
  color: #7c867f;
  font-size: 24rpx;
}

.legal-card {
  margin: 0 24rpx;
  padding: 28rpx 28rpx 10rpx;
  border: 1rpx solid rgba(58, 68, 62, 0.1);
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 42, 39, 0.045);
}

.legal-section {
  padding: 0 0 30rpx;
  margin-bottom: 28rpx;
  border-bottom: 1rpx solid #edf0eb;
}

.legal-section:last-child {
  border-bottom: none;
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  color: #24312c;
  font-size: 30rpx;
  font-weight: 720;
  line-height: 1.35;
}

.paragraph-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.paragraph {
  color: #405048;
  font-size: 27rpx;
  line-height: 1.72;
}

.bullet-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.bullet-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.bullet-dot {
  flex: 0 0 auto;
  color: #4f6654;
  font-size: 28rpx;
  line-height: 1.65;
}

.bullet-text {
  flex: 1;
  color: #405048;
  font-size: 27rpx;
  line-height: 1.65;
}

.legal-footer {
  padding: 26rpx 36rpx calc(44rpx + env(safe-area-inset-bottom));
  color: #7c867f;
  font-size: 24rpx;
  line-height: 1.6;
}
