/* 稀有度5样式和动画已移至组件中 */
.user-intro {
  font-size: 28rpx;
  color: #666666;
  margin: 0 0 20rpx;
  line-height: 1.4;
  letter-spacing: 1rpx;
  opacity: 0.8;
}

.user-intro-empty {
  font-size: 28rpx;
  color: #999999;
  margin: 0 0 20rpx;
  font-style: italic;
  opacity: 0.8;
}



.admin-badge {
  display: inline-block;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  margin-top: 10rpx;
}

.badge-text {
  font-size: 20rpx;
  color: white;
  font-weight: 500;
}

/* 操作按钮区域 */
.action-buttons {
  display: flex;
  gap: 8rpx;
  margin-top: 20rpx;
}

.follow-btn,
.more-info-btn {
  padding: 10rpx;
  border: 2rpx solid #333333;
  color: #333333;
  font-size: 24rpx;
  text-transform: uppercase;
  margin: 20rpx 0;
  display: inline-block;
  opacity: 0.65;
  width: 47%;
  text-align: center;
  text-decoration: none;
  font-weight: 600;
  letter-spacing: 2rpx;
  background: transparent;
  border-radius: 0;
  transition: all 0.25s ease;
}

.follow-btn {
  margin-right: 4%;
  border-color: #2980b9;
  color: #2980b9;
}

.follow-btn:active,
.more-info-btn:active {
  opacity: 1;
  transform: scale(0.98);
}

.follow-text,
.more-info-text {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 功能菜单 */
/* .menu-section 已移除，直接设置 .quick-menu */

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background-color 0.3s ease;
}

.profile-card,
.quick-menu {
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  border-radius: 28rpx;
  padding: 26rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  margin: 24rpx 20rpx 60rpx;
}

.profile-container.dark .profile-card,
.profile-container.dark .quick-menu {
  background:
    linear-gradient(180deg, rgba(31, 38, 48, 0.98), rgba(19, 25, 34, 0.98)),
    radial-gradient(circle at top right, rgba(104, 135, 162, 0.12), transparent 54%);
  border: 1rpx solid rgba(108, 126, 144, 0.18);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04),
    0 16rpx 40rpx rgba(6, 10, 18, 0.12);
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.card-kicker {
  display: block;
  font-size: 22rpx;
  color: rgba(166, 181, 196, 0.72);
  letter-spacing: 2rpx;
}

.card-title {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #f4f7fb;
}

.card-link {
  font-size: 24rpx;
  color: #8fb6d8;
}

.card-desc {
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(214, 223, 232, 0.82);
}

.current-tag-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.current-tag-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.18);
}

.current-tag-meta {
  display: flex;
  flex-direction: column;
}

.current-tag-name {
  font-size: 30rpx;
  color: #f4f7fb;
  font-weight: 600;
}

.current-tag-caption {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(166, 181, 196, 0.7);
}

.current-tag-chip {
  margin-bottom: 18rpx;
}

.current-tag-empty,
.strategy-preview-empty {
  font-size: 24rpx;
  color: rgba(179, 189, 199, 0.72);
}

.strategy-preview-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.strategy-preview-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(120, 136, 152, 0.14);
}

.strategy-preview-label {
  font-size: 24rpx;
  color: rgba(214, 223, 232, 0.8);
}

.tag-tab-scroll {
  white-space: nowrap;
  margin-bottom: 18rpx;
}

.tag-tab-list {
  display: inline-flex;
  gap: 12rpx;
}

.tag-tab {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(128, 144, 159, 0.16);
}

.tag-tab.is-active {
  background: rgba(121, 167, 204, 0.14);
  border-color: rgba(133, 178, 215, 0.4);
}

.tag-tab-text {
  font-size: 24rpx;
  color: rgba(234, 240, 246, 0.9);
}

.tag-tab-count,
.tag-group-count {
  font-size: 22rpx;
  color: rgba(151, 169, 187, 0.78);
}

.tag-group-block + .tag-group-block {
  margin-top: 22rpx;
}

.tag-group-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.tag-group-title {
  display: block;
  font-size: 28rpx;
  color: #f4f7fb;
  font-weight: 600;
}

.tag-group-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(169, 182, 195, 0.74);
}

.tag-chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-chip-card {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(128, 144, 159, 0.14);
}

.tag-chip-source {
  font-size: 22rpx;
  color: rgba(155, 170, 184, 0.74);
}

.tag-empty-state {
  padding: 20rpx 0 4rpx;
}

.tag-empty-state-text {
  font-size: 24rpx;
  color: rgba(173, 187, 201, 0.72);
}

.quick-menu {
  padding: 0;
  overflow: hidden;
}

.quick-menu .menu-item {
  border-bottom-color: #f5f5f5;
}
.profile-container.dark .quick-menu .menu-item {
  border-bottom-color: rgba(128, 144, 159, 0.12);
}

.quick-menu .menu-title {
  color: #333333;
}
.profile-container.dark .quick-menu .menu-title {
  color: #f4f7fb;
}

.quick-menu .menu-subtitle,
.quick-menu .menu-arrow {
  color: #999999;
}
.profile-container.dark .quick-menu .menu-subtitle,
.profile-container.dark .quick-menu .menu-arrow {
  color: rgba(174, 188, 201, 0.78);
}

.quick-menu .menu-item:last-child {
  border-bottom: none;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f8f9fa;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 40rpx;
  text-align: center;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 5rpx;
}

.menu-subtitle {
  font-size: 24rpx;
  color: #999;
}

.menu-arrow {
  font-size: 28rpx;
  color: #999;
  font-weight: bold;
}

/* 主题开关样式 */
.theme-item {
  padding: 25rpx 30rpx;
  display: flex;
  align-items: center;
}

.theme-toggle-component {
  margin-right: 20rpx;
  flex-shrink: 0;
}

.theme-switch {
  transform: scale(0.8);
}



.logout-item {
  color: #ff4757;
}

.logout-item .menu-title {
  color: #ff4757;
}

/* 动画效果 */
.profile-content {
  animation: fadeInUp 0.5s ease-out;
  padding: 0; /* 移除整体内边距 */
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 我的发布模块样式 */
.publish-item .menu-subtitle {
  color: #666;
}

/* 夜间模式下的用户信息区域样式 */
.dark .user-section {
  background-color: #1a1a1a !important;
}

.dark .user-content {
  background-color: #1a1a1a !important;
}

.dark .user-content::before {
  border-color: transparent transparent transparent #1a1a1a !important;
}

.dark .user-name {
  color: #ffffff !important;
}

/* 暗色模式user-tag样式已移至组件中 */

.dark .user-intro {
  color: #e0e0e0 !important;
}

.dark .user-intro-empty {
  color: #e0e0e0 !important;
}

.dark .follow-btn,
.dark .more-info-btn {
  border-color: #e0e0e0 !important;
  color: #e0e0e0 !important;
}

.dark .follow-btn {
  border-color: #64b5f6 !important;
  color: #64b5f6 !important;
}

/* 暗色模式稀有度样式已移至组件中 */

/* 响应式适配 */
@media (max-width: 375px) {
  .profile-content {
    padding: 0 15rpx;
  }
  
  .user-section {
    margin: 15rpx;
  }
  
  .user-content {
    padding: 40rpx 30rpx;
  }
  
  .user-content::before {
    border-width: 80rpx 0 0 600rpx;
  }
  
  .user-avatar {
    width: 140rpx;
    height: 140rpx;
    left: 30rpx;
  }
  
  .user-name {
    font-size: 40rpx;
  }
  
  .background-image {
    height: 300rpx;
  }
  
  .menu-item {
    padding: 25rpx 20rpx;
  }
}

/* Loading测试相关样式 */
.loading-test-item {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  margin: 10rpx 0;
  border-radius: 15rpx;
}

.loading-test-item .menu-icon {
  color: #fff;
}

.loading-test-item .menu-title {
  color: #fff;
  font-weight: 600;
}

.loading-test-item .menu-subtitle {
  color: rgba(255, 255, 255, 0.8);
}

.loading-test-item .menu-arrow {
  color: #fff;
}

.loading-test-item:active {
  background: linear-gradient(135deg, #5a6fd8 0%, #6a4190 100%);
}

/* Loading测试遮罩层 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-container {
  background: white;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  margin: 40rpx;
  max-width: 600rpx;
  width: 80%;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-controls {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

.control-btn {
  padding: 20rpx 30rpx;
  border-radius: 10rpx;
  border: none;
  font-size: 28rpx;
  background: #667eea;
  color: white;
  transition: all 0.3s ease;
}

.control-btn:active {
  background: #5a6fd8;
  transform: scale(0.98);
}

.close-btn {
  background: #ff6b6b !important;
  margin-top: 20rpx;
}

.close-btn:active {
  background: #ff5252 !important;
}

/* Loading组件样式 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.network-loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9998;
}

/* 夜间模式下自定义导航栏的文字和图标颜色 */
.profile-container.dark .custom-nav .title,
.profile-container.dark .custom-nav .navbar-title {
  color: #ffffff !important;
}
.profile-container.dark .navbar-title {
    color: #ffffff;
}
.profile-container.dark .custom-nav .settings-icon,
.profile-container.dark .custom-nav .nav-icon {
  filter: brightness(1.2);
  opacity: 0.9;
}

/* 夜间模式下右侧按钮的点击反馈 */
.profile-container.dark .custom-nav .settings-btn:active {
  background-color: rgba(255,255,255,0.06);
  border-radius: 50%;
}

/* Recent Tag UI Theme Overrides */
.profile-container {
  --page-bg:
    linear-gradient(180deg, #f5f8fb 0%, #e8eef3 56%, #dde6ed 100%);
  --surface-bg: rgba(255, 255, 255, 0.92);
  --surface-border: rgba(122, 140, 158, 0.12);
  --surface-shadow: 0 12rpx 32rpx rgba(18, 34, 52, 0.08);
  --soft-bg: rgba(241, 245, 249, 0.9);
  --soft-border: rgba(143, 161, 180, 0.18);
  --text-primary: #223140;
  --text-secondary: #5c6d7d;
  --text-muted: #7f91a3;
  --accent: #5b7d9d;
  background: var(--page-bg);
}

.profile-container.dark {
  --page-bg:
    radial-gradient(circle at top, rgba(83, 113, 142, 0.18), transparent 26%),
    linear-gradient(180deg, #111821 0%, #0d131c 56%, #091018 100%);
  --surface-bg:
    linear-gradient(180deg, rgba(30, 37, 47, 0.98), rgba(18, 24, 33, 0.99)),
    radial-gradient(circle at top right, rgba(96, 123, 148, 0.14), transparent 54%);
  --surface-border: rgba(92, 110, 127, 0.22);
  --surface-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04),
    0 18rpx 44rpx rgba(6, 10, 18, 0.22);
  --soft-bg: rgba(255, 255, 255, 0.04);
  --soft-border: rgba(116, 132, 148, 0.16);
  --text-primary: #f4f7fb;
  --text-secondary: rgba(214, 223, 232, 0.84);
  --text-muted: rgba(166, 181, 196, 0.76);
  --accent: #d8e9f7;
}

.profile-container .container {
  background: var(--page-bg);
}

.profile-container .login-content,
.profile-container .profile-card,
.profile-container .quick-menu,
.profile-container .user-content {
  background: var(--surface-bg);
  border: 1rpx solid var(--surface-border);
  box-shadow: var(--surface-shadow);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.profile-container .login-content {
  padding: 60rpx 40rpx;
}

.profile-container .user-content {
  color: var(--text-primary);
}

.profile-container .user-content::before {
  border-color: transparent transparent transparent rgba(255, 255, 255, 0.92);
}

.profile-container.dark .user-content::before {
  border-color: transparent transparent transparent rgba(27, 34, 43, 0.98) !important;
}

.profile-container .user-avatar {
  box-shadow: 0 18rpx 36rpx rgba(12, 20, 30, 0.22);
}

.profile-container .user-name,
.profile-container .quick-menu .menu-title,
.profile-container .menu-title {
  color: var(--text-primary);
}

.profile-container .user-intro,
.profile-container .publish-item .menu-subtitle {
  color: var(--text-secondary);
}

.profile-container .user-intro-empty,
.profile-container .quick-menu .menu-subtitle,
.profile-container .quick-menu .menu-arrow,
.profile-container .menu-subtitle,
.profile-container .menu-arrow {
  color: var(--text-muted);
}

.profile-container .menu-item {
  border-bottom: 1rpx solid var(--soft-border);
}

.profile-container .menu-item:active {
  background-color: var(--soft-bg);
}

.profile-container.dark .user-content {
  background: var(--surface-bg) !important;
}
