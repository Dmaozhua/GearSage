/* pages/profile/profile.wxss */
@import '../../styles/dark.wxss';

/* 自定义导航栏样式 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  transition: all 0.3s ease;
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  box-sizing: content-box;
}

.nav-inner .left,
.nav-inner .right {
  width: 180rpx;
  display: flex;
  align-items: center;
}

.nav-inner .right {
  justify-content: flex-end;
}

.nav-inner .title {
    font-size: 32rpx;
    font-weight: 700;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text-primary);
}

.nav-btn::after {
  border: none;
}

.nav-icon {
  width: 48rpx;
  height: 48rpx;
}
/* 页面容器 */
.profile-container, .custom-nav {
    --page-bg: #f4f5f1;
    --surface-bg: #ffffff;
    --surface-soft: #f7f8f4;
    --surface-border: rgba(58, 68, 62, 0.11);
    --surface-shadow: 0 6rpx 18rpx rgba(31, 42, 39, 0.045);
    --user-content-shadow: 0 -8rpx 22rpx rgba(31, 42, 39, 0.08);
    --text-primary: #1f2a27;
    --text-secondary: #68716b;
    --text-muted: #8a918a;
    --accent: #4f6654;
    --accent-gradient: #26332d;
    --btn-shadow: 0 8rpx 20rpx rgba(31, 42, 39, 0.14);
    --admin-gradient: #766f4f;
    --danger: #9a4a42;
    --menu-hover: #f6f7f3;
}

.profile-container.dark,
.custom-nav--dark {
    --page-bg: #0f1518;
    --surface-bg: #182028;
    --surface-soft: rgba(238, 245, 242, 0.08);
    --surface-border: rgba(229, 236, 231, 0.08);
    --surface-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.22);
    --user-content-shadow: 0 -8rpx 22rpx rgba(0,0,0,0.28);
    --text-primary: #eef5f2;
    --text-secondary: rgba(236, 244, 241, 0.68);
    --text-muted: rgba(236, 244, 241, 0.48);
    --accent: #9aa083;
    --accent-gradient: #9aa083;
    --btn-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.24);
    --admin-gradient: #9a8f63;
    --danger: #c9796f;
    --menu-hover: rgba(238, 245, 242, 0.06);
}

.profile-container {
    min-height: 100vh;
    width: 100%;
    margin: 0;
    padding: 0;
    background-color: var(--page-bg);
    overflow-x: hidden;
    box-sizing: border-box;
    transition: background-color 0.3s ease, color 0.3s ease;
}

/* 页面容器 */
.container {
  min-height: 100vh;
  background-color: var(--page-bg);
  padding-bottom: 40rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 未登录状态 */
.login-prompt {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
  padding: 40rpx;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background: var(--surface-bg);
  border-radius: 10rpx;
  padding: 52rpx 40rpx;
  box-shadow: var(--surface-shadow);
  width: 100%;
  max-width: 500rpx;
  border: 1rpx solid var(--surface-border);
}

.login-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
}

.login-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 15rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.login-btn {
  background: var(--accent-gradient);
  border: none;
  border-radius: 8rpx;
  padding: 22rpx 56rpx;
  width: 100%;
  max-width: 300rpx;
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: var(--btn-shadow);
  transition: all 0.3s ease;
}

.login-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 6rpx 12rpx rgba(0, 0, 0, 0.15);
}
.navbar-title{
    font-size: 32rpx;
    font-weight: 700;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text-primary);
}
/* 个人资料内容 */
.profile-content {
  padding: 0 20rpx;
}
/* 为其他组件恢复必要的内边距，避免影响其他元素 */
.profile-content .menu-section,
.profile-content .login-content {
  padding: 0 20rpx; /* 仅对菜单和登录区域添加内边距 */
  margin-top: 20rpx; /* 给菜单区域添加顶部间距 */
}

/* 用户信息区域 - 修改后 */
.user-section {
    position: relative;
    overflow: visible; /* 改为visible，避免影响滚动 */
    margin: 0 !important; /* 强制移除外边距 */
    border-radius: 0 !important; /* 移除圆角 */
    background-color: transparent !important; /* 透明背景 */
    box-shadow: none !important; /* 移除阴影 */
    width: 100% !important; /* 强制全屏宽度 */
  }

/* 背景图片 - 确保全屏显示 */
.background-image {
    top: 0;
    left: 0;
    width: 100%;
    height: 520rpx;
    opacity: 1;
    vertical-align: top;
    object-fit: cover; /* 确保图片覆盖整个区域 */
    margin-left: calc(-50vw + 50%) !important; /* 居中全屏显示 */
    z-index: -1; /* 确保在内容下方 */
  }

/* 内容区域 - 调整内边距 */
.user-content {
    position: relative;
    background-color: var(--surface-bg);
    padding: 30rpx 28rpx 34rpx;
    color: var(--text-primary);
    margin-top: -40rpx;
    box-shadow: var(--user-content-shadow);
    transition: background-color 0.3s ease;
    overflow: visible;
  }
.user-content::before {
    content: '';
    position: absolute;
    bottom: 99%;
    left: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 78rpx 0 0 800rpx;
    border-color: transparent transparent transparent var(--surface-bg);
    mask-image: linear-gradient(to bottom, rgba(0,0,0,0), rgba(0,0,0,1));
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0), rgba(0,0,0,1));
    pointer-events: none;
}

.user-avatar {
  position: absolute;
  bottom: 100%;
  left: 42rpx;
  margin-bottom: -78rpx;
  z-index: 1;
  width: 156rpx;
  height: 156rpx;
  border-radius: 50%;
  opacity: 1;
  box-shadow: 0 8rpx 22rpx rgba(31, 42, 39, 0.16);
  border: 5rpx solid var(--surface-bg);
}

.user-info {
  margin-top: 72rpx;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.user-name {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

/* user-tag 样式已移至组件中 */

/* 稀有度样式已移至组件中 */

/* 稀有度2样式已移至组件中 */

/* 稀有度3样式已移至组件中 */

/* 稀有度4样式已移至组件中 */

/* 稀有度5样式和动画已移至组件中 */
.user-intro {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin: 0 0 20rpx;
  line-height: 1.55;
}

.user-intro-empty {
  font-size: 26rpx;
  color: var(--text-muted);
  margin: 0 0 20rpx;
  font-style: italic;
}



.admin-badge {
  display: inline-block;
  background: var(--admin-gradient);
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  margin-top: 10rpx;
}

.badge-text {
  font-size: 20rpx;
  color: white;
  font-weight: 500;
}

/* 操作按钮区域 */
.action-buttons {
  display: flex;
  gap: 8rpx;
  margin-top: 20rpx;
}

.follow-btn,
.more-info-btn {
  padding: 10rpx;
  border: 2rpx solid var(--text-primary);
  color: var(--text-primary);
  font-size: 24rpx;
  text-transform: uppercase;
  margin: 20rpx 0;
  display: inline-block;
  opacity: 0.8;
  width: 47%;
  text-align: center;
  text-decoration: none;
  font-weight: 600;
  letter-spacing: 2rpx;
  background: transparent;
  border-radius: 8rpx;
  transition: all 0.25s ease;
}

.follow-btn {
  margin-right: 4%;
  border-color: var(--accent);
  color: #ffffff;
  background: var(--accent);
  opacity: 1;
}

.follow-btn:active,
.more-info-btn:active {
  opacity: 1;
  transform: scale(0.98);
}

.follow-text,
.more-info-text {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 功能菜单 */
/* .menu-section 已移除，直接设置 .quick-menu */

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 28rpx;
  border-bottom: 1rpx solid var(--surface-border);
  transition: background-color 0.3s ease;
  border-radius: 0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: var(--menu-hover);
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  margin-right: 20rpx;
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  position: relative;
  border-radius: 8rpx;
  background: var(--surface-soft);
  border: 1rpx solid var(--surface-border);
  box-sizing: border-box;
}

.menu-icon::before,
.menu-icon::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.menu-icon--message::before {
  left: 10rpx;
  right: 10rpx;
  top: 10rpx;
  bottom: 12rpx;
  border: 3rpx solid var(--accent);
  border-radius: 50% 50% 42% 42%;
  border-bottom-color: transparent;
}

.menu-icon--message::after {
  left: 17rpx;
  bottom: 8rpx;
  width: 10rpx;
  height: 3rpx;
  background: var(--accent);
  border-radius: 4rpx;
}

.menu-icon--publish::before {
  left: 12rpx;
  top: 8rpx;
  width: 20rpx;
  height: 28rpx;
  border: 3rpx solid var(--accent);
  border-radius: 3rpx;
}

.menu-icon--publish::after {
  left: 16rpx;
  top: 17rpx;
  width: 12rpx;
  height: 3rpx;
  background: var(--accent);
  box-shadow: 0 8rpx 0 var(--accent);
}

.menu-icon--gear::before {
  left: 10rpx;
  top: 12rpx;
  width: 24rpx;
  height: 18rpx;
  border: 3rpx solid var(--accent);
  border-radius: 8rpx;
}

.menu-icon--gear::after {
  left: 16rpx;
  top: 7rpx;
  width: 12rpx;
  height: 10rpx;
  border: 3rpx solid var(--accent);
  border-bottom: none;
  border-radius: 8rpx 8rpx 0 0;
}

.menu-icon--points::before {
  left: 10rpx;
  top: 10rpx;
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid var(--accent);
  border-radius: 50%;
}

.menu-icon--points::after {
  left: 18rpx;
  top: 18rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--accent);
}

.menu-icon--tag::before {
  left: 10rpx;
  top: 12rpx;
  width: 24rpx;
  height: 20rpx;
  border: 3rpx solid var(--accent);
  border-radius: 4rpx;
  transform: rotate(-12deg);
}

.menu-icon--tag::after {
  left: 15rpx;
  top: 15rpx;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: var(--accent);
}

.menu-icon--edit::before {
  left: 13rpx;
  top: 12rpx;
  width: 22rpx;
  height: 4rpx;
  background: var(--accent);
  border-radius: 4rpx;
  transform: rotate(-42deg);
}

.menu-icon--edit::after {
  left: 10rpx;
  bottom: 10rpx;
  width: 24rpx;
  height: 3rpx;
  background: var(--accent);
  border-radius: 3rpx;
}

.menu-icon--about::before {
  left: 19rpx;
  top: 17rpx;
  width: 6rpx;
  height: 16rpx;
  background: var(--accent);
  border-radius: 4rpx;
}

.menu-icon--about::after {
  left: 19rpx;
  top: 10rpx;
  width: 6rpx;
  height: 6rpx;
  background: var(--accent);
  border-radius: 50%;
}

.menu-icon--admin::before {
  left: 10rpx;
  top: 20rpx;
  width: 24rpx;
  height: 4rpx;
  background: var(--accent);
  border-radius: 4rpx;
  transform: rotate(-36deg);
}

.menu-icon--admin::after {
  left: 23rpx;
  top: 9rpx;
  width: 4rpx;
  height: 26rpx;
  background: var(--accent);
  border-radius: 4rpx;
  transform: rotate(-36deg);
}

.menu-icon--logout::before {
  left: 11rpx;
  top: 10rpx;
  width: 17rpx;
  height: 24rpx;
  border: 3rpx solid var(--danger);
  border-right: 0;
  border-radius: 4rpx 0 0 4rpx;
}

.menu-icon--logout::after {
  right: 9rpx;
  top: 20rpx;
  width: 17rpx;
  height: 3rpx;
  background: var(--danger);
  border-radius: 3rpx;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-title {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: 6rpx;
}

.menu-subtitle {
  font-size: 23rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

.menu-arrow {
  font-size: 28rpx;
  color: var(--text-muted);
  font-weight: bold;
}

.profile-card,
.quick-menu {
  background: var(--surface-bg);
  border: 1rpx solid var(--surface-border);
  border-radius: 10rpx;
  padding: 24rpx;
  box-shadow: var(--surface-shadow);
  margin: 24rpx 28rpx 60rpx;
  transition: all 0.3s ease;
}

.profile-container.dark .profile-card,
.profile-container.dark .quick-menu {
  /* Dark mode overrides handled by CSS variables */
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.card-kicker {
  display: block;
  font-size: 22rpx;
  color: rgba(166, 181, 196, 0.72);
  letter-spacing: 2rpx;
}

.card-title {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #f4f7fb;
}

.card-link {
  font-size: 24rpx;
  color: #8fb6d8;
}

.card-desc {
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(214, 223, 232, 0.82);
}

.current-tag-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.current-tag-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.18);
}

.current-tag-meta {
  display: flex;
  flex-direction: column;
}

.current-tag-name {
  font-size: 30rpx;
  color: #f4f7fb;
  font-weight: 600;
}

.current-tag-caption {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(166, 181, 196, 0.7);
}

.current-tag-chip {
  margin-bottom: 18rpx;
}

.current-tag-empty,
.strategy-preview-empty {
  font-size: 24rpx;
  color: rgba(179, 189, 199, 0.72);
}

.strategy-preview-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.strategy-preview-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(120, 136, 152, 0.14);
}

.strategy-preview-label {
  font-size: 24rpx;
  color: rgba(214, 223, 232, 0.8);
}

.tag-tab-scroll {
  white-space: nowrap;
  margin-bottom: 18rpx;
}

.tag-tab-list {
  display: inline-flex;
  gap: 12rpx;
}

.tag-tab {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(128, 144, 159, 0.16);
}

.tag-tab.is-active {
  background: rgba(121, 167, 204, 0.14);
  border-color: rgba(133, 178, 215, 0.4);
}

.tag-tab-text {
  font-size: 24rpx;
  color: rgba(234, 240, 246, 0.9);
}

.tag-tab-count,
.tag-group-count {
  font-size: 22rpx;
  color: rgba(151, 169, 187, 0.78);
}

.tag-group-block + .tag-group-block {
  margin-top: 22rpx;
}

.tag-group-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.tag-group-title {
  display: block;
  font-size: 28rpx;
  color: #f4f7fb;
  font-weight: 600;
}

.tag-group-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(169, 182, 195, 0.74);
}

.tag-chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-chip-card {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(128, 144, 159, 0.14);
}

.tag-chip-source {
  font-size: 22rpx;
  color: rgba(155, 170, 184, 0.74);
}

.tag-empty-state {
  padding: 20rpx 0 4rpx;
}

.tag-empty-state-text {
  font-size: 24rpx;
  color: rgba(173, 187, 201, 0.72);
}

.quick-menu {
  padding: 0;
  overflow: hidden;
}

.quick-menu .menu-item {
  border-bottom-color: var(--surface-border);
}
.profile-container.dark .quick-menu .menu-item {
  border-bottom-color: var(--surface-border);
}

.quick-menu .menu-title {
  color: var(--text-primary);
}

.quick-menu .menu-subtitle,
.quick-menu .menu-arrow {
  color: var(--text-muted);
}

.quick-menu .menu-item:last-child {
  border-bottom: none;
}

.legal-menu-section {
  padding: 26rpx 28rpx 10rpx;
  border-bottom: 1rpx solid var(--surface-border);
}

.legal-public-card {
  margin-top: -12rpx;
}

.legal-menu-header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding-bottom: 18rpx;
}

.legal-menu-title {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 700;
}

.legal-menu-subtitle {
  color: var(--text-secondary);
  font-size: 23rpx;
  line-height: 1.45;
}

.legal-menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid var(--surface-border);
}

.legal-menu-item:active {
  background: var(--menu-hover);
}

.legal-menu-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.legal-title-text {
  color: var(--text-primary);
  font-size: 27rpx;
  font-weight: 650;
}

.legal-subtitle-text {
  color: var(--text-muted);
  font-size: 22rpx;
  line-height: 1.4;
}



/* 主题开关样式 */
.theme-item {
  padding: 25rpx 28rpx;
  display: flex;
  align-items: center;
}

.theme-toggle-component {
  margin-right: 20rpx;
  flex-shrink: 0;
}

.theme-switch {
  transform: scale(0.8);
}



.logout-item {
  color: var(--danger);
}

.logout-item .menu-title {
  color: var(--danger);
}

/* 动画效果 */
.profile-content {
  animation: fadeInUp 0.5s ease-out;
  padding: 0; /* 移除整体内边距 */
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 我的发布模块样式 */
.publish-item .menu-subtitle {
  color: var(--text-secondary);
}

/* 暗色模式user-tag样式已移至组件中 */

/* 暗色模式稀有度样式已移至组件中 */

/* 响应式适配 */
@media (max-width: 375px) {
  .profile-content {
    padding: 0 15rpx;
  }
  
  .user-section {
    margin: 15rpx;
  }
  
  .user-content {
    padding: 40rpx 30rpx;
  }
  
  .user-content::before {
    border-width: 80rpx 0 0 600rpx;
  }
  
  .user-avatar {
    width: 140rpx;
    height: 140rpx;
    left: 30rpx;
  }
  
  .user-name {
    font-size: 40rpx;
  }
  
  .background-image {
    height: 300rpx;
  }
  
  .menu-item {
    padding: 25rpx 20rpx;
  }
}

/* Loading测试相关样式 */
.loading-test-item {
  background: #4f6654;
  color: white;
  margin: 10rpx 0;
  border-radius: 8rpx;
}

.loading-test-item .menu-icon {
  color: #fff;
}

.loading-test-item .menu-title {
  color: #fff;
  font-weight: 600;
}

.loading-test-item .menu-subtitle {
  color: rgba(255, 255, 255, 0.8);
}

.loading-test-item .menu-arrow {
  color: #fff;
}

.loading-test-item:active {
  background: #3e5145;
}

/* Loading测试遮罩层 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-container {
  background: white;
  border-radius: 10rpx;
  padding: 60rpx 40rpx;
  margin: 40rpx;
  max-width: 600rpx;
  width: 80%;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-controls {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

.control-btn {
  padding: 20rpx 30rpx;
  border-radius: 8rpx;
  border: none;
  font-size: 28rpx;
  background: #4f6654;
  color: white;
  transition: all 0.3s ease;
}

.control-btn:active {
  background: #3e5145;
  transform: scale(0.98);
}

.close-btn {
  background: #9a4a42 !important;
  margin-top: 20rpx;
}

.close-btn:active {
  background: #7d3933 !important;
}

/* Loading组件样式 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.network-loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9998;
}

/* 夜间模式下自定义导航栏的图标样式 */
.custom-nav--dark .nav-icon {
  filter: brightness(1.2);
  opacity: 0.9;
}

