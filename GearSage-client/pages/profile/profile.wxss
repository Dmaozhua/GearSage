/* pages/profile/profile.wxss */
@import '../../styles/dark.wxss';

/* 自定义导航栏样式 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  transition: all 0.3s ease;
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  box-sizing: content-box;
}

.nav-inner .left,
.nav-inner .right {
  width: 180rpx;
  display: flex;
  align-items: center;
}

.nav-inner .right {
  justify-content: flex-end;
}

.nav-inner .title {
    font-size: 36rpx;
    font-weight: 600;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}


.settings-btn {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.8;
}

.settings-btn::after {
  border: none;
}

.nav-btn::after {
  border: none;
}

.nav-icon {
  width: 48rpx;
  height: 48rpx;
}
/* 页面容器 */
.profile-container {
    --page-bg:
      linear-gradient(180deg, #f5f8fb 0%, #e8eef3 56%, #dde6ed 100%);
    --surface-bg: rgba(255, 255, 255, 0.92);
    --surface-border: rgba(122, 140, 158, 0.12);
    --surface-shadow: 0 12rpx 32rpx rgba(18, 34, 52, 0.08);
    --soft-bg: rgba(241, 245, 249, 0.9);
    --soft-border: rgba(143, 161, 180, 0.18);
    --text-primary: #223140;
    --text-secondary: #5c6d7d;
    --text-muted: #7f91a3;
    --accent: #5b7d9d;
    min-height: 100vh; /* 设置最小高度为视口高度的100% */
    width: 100%; /* 设置宽度为视口宽度的100% */
    margin: 0; /* 去除外边距 */
    padding: 0; /* 去除内边距 */
    background-color: #f5f5f5; /* 设置背景颜色，可根据需要修改 */
    overflow-x: hidden; /* 禁止水平方向滚动条及滚动行为 */
    box-sizing: border-box; /* 确保padding计算在内 */
  }

/* 页面容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(to bottom, #f8f9fa, #e9ecef);
  padding-bottom: 40rpx;

}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
  font-size: 28rpx;
  color: #666;
}

/* 未登录状态 */
.login-prompt {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
  padding: 40rpx;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background: white;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
  width: 100%;
  max-width: 500rpx;
}

.login-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
}

.login-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.login-btn {
  background: linear-gradient(135deg, #3a87f0, #2c5aa0);
  border: none;
  border-radius: 50rpx;
  padding: 25rpx 60rpx;
  width: 100%;
  max-width: 300rpx;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
}
.navbar-title{
    font-size: 36rpx;
    font-weight: 600;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
/* 个人资料内容 */
.profile-content {
  padding: 0 20rpx;
}
/* 为其他组件恢复必要的内边距，避免影响其他元素 */
.profile-content .menu-section,
.profile-content .login-content {
  padding: 0 20rpx; /* 仅对菜单和登录区域添加内边距 */
  margin-top: 20rpx; /* 给菜单区域添加顶部间距 */
}

.server-debug-panel {
  margin: 24rpx 0;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(32, 48, 64, 0.92);
  box-shadow: 0 12rpx 32rpx rgba(10, 18, 28, 0.14);
}

.server-debug-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.server-debug-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f5f7fa;
}

.server-debug-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(111, 209, 187, 0.18);
  color: #84f1d8;
  font-size: 22rpx;
}

.server-debug-url {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: rgba(231, 240, 248, 0.78);
  word-break: break-all;
}

.server-debug-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.server-debug-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #f2f6fa;
  font-size: 26rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
}

.server-debug-btn.active {
  background: #84f1d8;
  color: #15313a;
  border-color: #84f1d8;
}

.server-debug-btn::after {
  border: none;
}

/* 用户信息区域 - 修改后 */
.user-section {
    position: relative;
    overflow: visible; /* 改为visible，避免影响滚动 */
    margin: 0 !important; /* 强制移除外边距 */
    border-radius: 0 !important; /* 移除圆角 */
    background-color: transparent !important; /* 透明背景 */
    box-shadow: none !important; /* 移除阴影 */
    width: 100% !important; /* 强制全屏宽度 */
  }

/* 背景图片 - 确保全屏显示 */
.background-image {
    top: 0;
    left: 0;
    width: 100%;
    height: 660rpx;
    opacity: 0.85;
    vertical-align: top;
    object-fit: cover; /* 确保图片覆盖整个区域 */
    margin-left: calc(-50vw + 50%) !important; /* 居中全屏显示 */
    z-index: -1; /* 确保在内容下方 */
  }

/* 内容区域 - 调整内边距 */
.user-content {
    position: relative;
    background-color: #ffffff; /* 白色背景 */
    padding: 30rpx 30rpx; /* 适当调整内边距 */
    color: #333333;
  }
.user-content::before {
  position: absolute;
  content: '';
  bottom: 99%;
  left: 0;
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 110rpx 0 0 800rpx;
  border-color: transparent transparent transparent #ffffff;
    /* 渐变遮罩 */
    mask-image: linear-gradient(to bottom, rgba(0,0,0,0), rgba(0,0,0,1));
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0), rgba(0,0,0,1));
    
}

.user-avatar {
  position: absolute;
  bottom: 100%;
  left: 50rpx;
  z-index: 1;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  opacity: 1;
  box-shadow: 0 0 30rpx rgba(0, 0, 0, 0.3);
  border: 6rpx solid #fff;
}

.user-info {
  margin-top: 20rpx;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.user-name {
  font-size: 52rpx;
  font-weight: 400;
  color: #333333;
  margin-bottom: 10rpx;
}

/* user-tag 样式已移至组件中 */

/* 稀有度样式已移至组件中 */

/* 稀有度2样式已移至组件中 */

/* 稀有度3样式已移至组件中 */

