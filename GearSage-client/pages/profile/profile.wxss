/* pages/profile/profile.wxss */
@import '../../styles/dark.wxss';

/* 自定义导航栏样式 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  transition: all 0.3s ease;
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  box-sizing: content-box;
}

.nav-inner .left,
.nav-inner .right {
  width: 180rpx;
  display: flex;
  align-items: center;
}

.nav-inner .right {
  justify-content: flex-end;
}

.nav-inner .title {
    font-size: 36rpx;
    font-weight: 600;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text-primary);
}


.settings-btn {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.8;
}

.settings-btn::after {
  border: none;
}

.nav-btn::after {
  border: none;
}

.nav-icon {
  width: 48rpx;
  height: 48rpx;
}
/* 页面容器 */
.profile-container, .custom-nav {
    --page-bg: #f7f9fc;
    --surface-bg: #ffffff;
    --surface-border: rgba(0, 0, 0, 0.04);
    --surface-shadow: 0 16rpx 32rpx rgba(58, 135, 240, 0.06);
    --user-content-shadow: 0 -10rpx 30rpx rgba(0,0,0,0.05);
    --text-primary: #1a1f26;
    --text-secondary: #6e7a8a;
    --text-muted: #94a3b8;
    --accent: #4492fe;
    --accent-gradient: linear-gradient(135deg, #4492fe 0%, #2b70d4 100%);
    --btn-shadow: 0 12rpx 32rpx rgba(58, 135, 240, 0.25);
    --admin-gradient: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
    --menu-hover: #f8fafc;
}

.profile-container.dark, .custom-nav.dark {
    --page-bg: #0d1117;
    --surface-bg: #161b22;
    --surface-border: rgba(240, 246, 252, 0.1);
    --surface-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.3);
    --user-content-shadow: 0 -10rpx 30rpx rgba(0,0,0,0.4);
    --text-primary: #c9d1d9;
    --text-secondary: #8b949e;
    --text-muted: #6e7681;
    --accent: #58a6ff;
    --accent-gradient: linear-gradient(135deg, #58a6ff 0%, #3178c6 100%);
    --btn-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.3);
    --admin-gradient: linear-gradient(135deg, #e55353 0%, #c83d1c 100%);
    --menu-hover: #21262d;
}

.profile-container {
    min-height: 100vh;
    width: 100%;
    margin: 0;
    padding: 0;
    background-color: var(--page-bg);
    overflow-x: hidden;
    box-sizing: border-box;
    transition: background-color 0.3s ease, color 0.3s ease;
}

/* 页面容器 */
.container {
  min-height: 100vh;
  background-color: var(--page-bg);
  padding-bottom: 40rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 未登录状态 */
.login-prompt {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
  padding: 40rpx;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background: var(--surface-bg);
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
  box-shadow: var(--surface-shadow);
  width: 100%;
  max-width: 500rpx;
  border: 1rpx solid var(--surface-border);
}

.login-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
}

.login-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 15rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.login-btn {
  background: var(--accent-gradient);
  border: none;
  border-radius: 48rpx;
  padding: 25rpx 60rpx;
  width: 100%;
  max-width: 300rpx;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: var(--btn-shadow);
  transition: all 0.3s ease;
}

.login-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 6rpx 12rpx rgba(0, 0, 0, 0.15);
}
.navbar-title{
    font-size: 36rpx;
    font-weight: 600;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text-primary);
}
/* 个人资料内容 */
.profile-content {
  padding: 0 20rpx;
}
/* 为其他组件恢复必要的内边距，避免影响其他元素 */
.profile-content .menu-section,
.profile-content .login-content {
  padding: 0 20rpx; /* 仅对菜单和登录区域添加内边距 */
  margin-top: 20rpx; /* 给菜单区域添加顶部间距 */
}

/* 用户信息区域 - 修改后 */
.user-section {
    position: relative;
    overflow: visible; /* 改为visible，避免影响滚动 */
    margin: 0 !important; /* 强制移除外边距 */
    border-radius: 0 !important; /* 移除圆角 */
    background-color: transparent !important; /* 透明背景 */
    box-shadow: none !important; /* 移除阴影 */
    width: 100% !important; /* 强制全屏宽度 */
  }

/* 背景图片 - 确保全屏显示 */
.background-image {
    top: 0;
    left: 0;
    width: 100%;
    height: 660rpx;
    opacity: 0.85;
    vertical-align: top;
    object-fit: cover; /* 确保图片覆盖整个区域 */
    margin-left: calc(-50vw + 50%) !important; /* 居中全屏显示 */
    z-index: -1; /* 确保在内容下方 */
  }

/* 内容区域 - 调整内边距 */
.user-content {
    position: relative;
    background-color: var(--surface-bg);
    padding: 30rpx 30rpx;
    color: var(--text-primary);
    margin-top: -40rpx;
    box-shadow: var(--user-content-shadow);
    transition: background-color 0.3s ease;
    overflow: visible;
  }
.user-content::before {
    content: '';
    position: absolute;
    bottom: 99%;
    left: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 110rpx 0 0 800rpx;
    border-color: transparent transparent transparent var(--surface-bg);
    mask-image: linear-gradient(to bottom, rgba(0,0,0,0), rgba(0,0,0,1));
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0), rgba(0,0,0,1));
    pointer-events: none;
}

.user-avatar {
  position: absolute;
  bottom: 100%;
  left: 50rpx;
  margin-bottom: -90rpx;
  z-index: 1;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  opacity: 1;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  border: 6rpx solid var(--surface-bg);
}

.user-info {
  margin-top: 80rpx;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.user-name {
  font-size: 52rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

/* user-tag 样式已移至组件中 */

/* 稀有度样式已移至组件中 */

/* 稀有度2样式已移至组件中 */

/* 稀有度3样式已移至组件中 */

/* 稀有度4样式已移至组件中 */

/* 稀有度5样式和动画已移至组件中 */
.user-intro {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin: 0 0 20rpx;
  line-height: 1.4;
  letter-spacing: 1rpx;
}

.user-intro-empty {
  font-size: 28rpx;
  color: var(--text-muted);
  margin: 0 0 20rpx;
  font-style: italic;
}



.admin-badge {
  display: inline-block;
  background: var(--admin-gradient);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  margin-top: 10rpx;
}

.badge-text {
  font-size: 20rpx;
  color: white;
  font-weight: 500;
}

/* 操作按钮区域 */
.action-buttons {
  display: flex;
  gap: 8rpx;
  margin-top: 20rpx;
}

.follow-btn,
.more-info-btn {
  padding: 10rpx;
  border: 2rpx solid var(--text-primary);
  color: var(--text-primary);
  font-size: 24rpx;
  text-transform: uppercase;
  margin: 20rpx 0;
  display: inline-block;
  opacity: 0.8;
  width: 47%;
  text-align: center;
  text-decoration: none;
  font-weight: 600;
  letter-spacing: 2rpx;
  background: transparent;
  border-radius: 40rpx;
  transition: all 0.25s ease;
}

.follow-btn {
  margin-right: 4%;
  border-color: var(--accent);
  color: #ffffff;
  background: var(--accent);
  opacity: 1;
}

.follow-btn:active,
.more-info-btn:active {
  opacity: 1;
  transform: scale(0.98);
}

.follow-text,
.more-info-text {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 功能菜单 */
/* .menu-section 已移除，直接设置 .quick-menu */

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--surface-border);
  transition: background-color 0.3s ease;
  border-radius: 20rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: var(--menu-hover);
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 40rpx;
  text-align: center;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-title {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 5rpx;
}

.menu-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.menu-arrow {
  font-size: 28rpx;
  color: var(--text-muted);
  font-weight: bold;
}

.profile-card,
.quick-menu {
  background: var(--surface-bg);
  border: 1rpx solid var(--surface-border);
  border-radius: 40rpx;
  padding: 26rpx;
  box-shadow: var(--surface-shadow);
  margin: 24rpx 20rpx 60rpx;
  transition: all 0.3s ease;
}

.profile-container.dark .profile-card,
.profile-container.dark .quick-menu {
  /* Dark mode overrides handled by CSS variables */
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.card-kicker {
  display: block;
  font-size: 22rpx;
  color: rgba(166, 181, 196, 0.72);
  letter-spacing: 2rpx;
}

.card-title {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #f4f7fb;
}

.card-link {
  font-size: 24rpx;
  color: #8fb6d8;
}

.card-desc {
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(214, 223, 232, 0.82);
}

.current-tag-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.current-tag-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.18);
}

.current-tag-meta {
  display: flex;
  flex-direction: column;
}

.current-tag-name {
  font-size: 30rpx;
  color: #f4f7fb;
  font-weight: 600;
}

.current-tag-caption {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(166, 181, 196, 0.7);
}

.current-tag-chip {
  margin-bottom: 18rpx;
}

.current-tag-empty,
.strategy-preview-empty {
  font-size: 24rpx;
  color: rgba(179, 189, 199, 0.72);
}

.strategy-preview-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.strategy-preview-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(120, 136, 152, 0.14);
}

.strategy-preview-label {
  font-size: 24rpx;
  color: rgba(214, 223, 232, 0.8);
}

.tag-tab-scroll {
  white-space: nowrap;
  margin-bottom: 18rpx;
}

.tag-tab-list {
  display: inline-flex;
  gap: 12rpx;
}

.tag-tab {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(128, 144, 159, 0.16);
}

.tag-tab.is-active {
  background: rgba(121, 167, 204, 0.14);
  border-color: rgba(133, 178, 215, 0.4);
}

.tag-tab-text {
  font-size: 24rpx;
  color: rgba(234, 240, 246, 0.9);
}

.tag-tab-count,
.tag-group-count {
  font-size: 22rpx;
  color: rgba(151, 169, 187, 0.78);
}

.tag-group-block + .tag-group-block {
  margin-top: 22rpx;
}

.tag-group-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.tag-group-title {
  display: block;
  font-size: 28rpx;
  color: #f4f7fb;
  font-weight: 600;
}

.tag-group-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(169, 182, 195, 0.74);
}

.tag-chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-chip-card {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(128, 144, 159, 0.14);
}

.tag-chip-source {
  font-size: 22rpx;
  color: rgba(155, 170, 184, 0.74);
}

.tag-empty-state {
  padding: 20rpx 0 4rpx;
}

.tag-empty-state-text {
  font-size: 24rpx;
  color: rgba(173, 187, 201, 0.72);
}

.quick-menu {
  padding: 0;
  overflow: hidden;
}

.quick-menu .menu-item {
  border-bottom-color: var(--surface-border);
}
.profile-container.dark .quick-menu .menu-item {
  border-bottom-color: var(--surface-border);
}

.quick-menu .menu-title {
  color: var(--text-primary);
}

.quick-menu .menu-subtitle,
.quick-menu .menu-arrow {
  color: var(--text-muted);
}

.quick-menu .menu-item:last-child {
  border-bottom: none;
}



/* 主题开关样式 */
.theme-item {
  padding: 25rpx 30rpx;
  display: flex;
  align-items: center;
}

.theme-toggle-component {
  margin-right: 20rpx;
  flex-shrink: 0;
}

.theme-switch {
  transform: scale(0.8);
}



.logout-item {
  color: #ff4757;
}

.logout-item .menu-title {
  color: #ff4757;
}

/* 动画效果 */
.profile-content {
  animation: fadeInUp 0.5s ease-out;
  padding: 0; /* 移除整体内边距 */
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 我的发布模块样式 */
.publish-item .menu-subtitle {
  color: var(--text-secondary);
}

/* 暗色模式user-tag样式已移至组件中 */

/* 暗色模式稀有度样式已移至组件中 */

/* 响应式适配 */
@media (max-width: 375px) {
  .profile-content {
    padding: 0 15rpx;
  }
  
  .user-section {
    margin: 15rpx;
  }
  
  .user-content {
    padding: 40rpx 30rpx;
  }
  
  .user-content::before {
    border-width: 80rpx 0 0 600rpx;
  }
  
  .user-avatar {
    width: 140rpx;
    height: 140rpx;
    left: 30rpx;
  }
  
  .user-name {
    font-size: 40rpx;
  }
  
  .background-image {
    height: 300rpx;
  }
  
  .menu-item {
    padding: 25rpx 20rpx;
  }
}

/* Loading测试相关样式 */
.loading-test-item {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  margin: 10rpx 0;
  border-radius: 15rpx;
}

.loading-test-item .menu-icon {
  color: #fff;
}

.loading-test-item .menu-title {
  color: #fff;
  font-weight: 600;
}

.loading-test-item .menu-subtitle {
  color: rgba(255, 255, 255, 0.8);
}

.loading-test-item .menu-arrow {
  color: #fff;
}

.loading-test-item:active {
  background: linear-gradient(135deg, #5a6fd8 0%, #6a4190 100%);
}

/* Loading测试遮罩层 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-container {
  background: white;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  margin: 40rpx;
  max-width: 600rpx;
  width: 80%;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-controls {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

.control-btn {
  padding: 20rpx 30rpx;
  border-radius: 10rpx;
  border: none;
  font-size: 28rpx;
  background: #667eea;
  color: white;
  transition: all 0.3s ease;
}

.control-btn:active {
  background: #5a6fd8;
  transform: scale(0.98);
}

.close-btn {
  background: #ff6b6b !important;
  margin-top: 20rpx;
}

.close-btn:active {
  background: #ff5252 !important;
}

/* Loading组件样式 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.network-loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9998;
}

/* 夜间模式下自定义导航栏的图标样式 */
.profile-container.dark .custom-nav .settings-icon,
.profile-container.dark .custom-nav .nav-icon {
  filter: brightness(1.2);
  opacity: 0.9;
}

/* 夜间模式下右侧按钮的点击反馈 */
.profile-container.dark .custom-nav .settings-btn:active {
  background-color: rgba(255,255,255,0.06);
  border-radius: 50%;
}

/* Recent Tag UI Theme Overrides */
