<!--pages/login/login.wxml-->
<view class="container">
  <!-- 顶部装饰背景 -->
  <view class="header-bg"></view>

  <view class="header">
    <image class="logo" src="/images/login-icon.png" mode="aspectFit"></image>
    <view class="title">欢迎来到钓友说</view>
    <view class="subtitle">记录你的每一次抛竿与中鱼</view>
  </view>

  <view class="form-container">
    <view class="input-group">
      <view class="input-label">手机号</view>
      <view class="input-wrapper">
        <text class="input-prefix">+86</text>
        <input 
          class="input-field" 
          type="number" 
          maxlength="11" 
          placeholder="请输入手机号" 
          placeholder-class="input-placeholder"
          disabled="{{loading}}"
          model:value="{{phone}}"
          bindinput="onPhoneInput"
        />
      </view>
    </view>

    <view class="input-group">
      <view class="input-label">验证码</view>
      <view class="code-input-wrapper">
        <input 
          class="input-field code-input" 
          type="number" 
          maxlength="6" 
          placeholder="请输入验证码 (测试: 123456)" 
          placeholder-class="input-placeholder"
          disabled="{{loading}}"
          model:value="{{code}}"
          bindinput="onCodeInput"
        />
        <button 
          class="send-code-btn {{countdown > 0 ? 'disabled' : ''}}" 
          hover-class="{{countdown > 0 ? 'none' : 'btn-hover'}}"
          bindtap="onSendCode" 
          disabled="{{countdown > 0 || loading}}"
        >
          {{countdown > 0 ? countdown + 's' : '获取验证码'}}
        </button>
      </view>
    </view>

    <view class="action-area">
      <button 
        class="login-btn {{!isFormValid ? 'disabled' : ''}}" 
        hover-class="{{!isFormValid || loading ? 'none' : 'login-btn-hover'}}"
        catchtap="onLogin" 
        disabled="{{!isFormValid || loading}}"
      >
        <text wx:if="{{!loading}}">立即登录</text>
        <view wx:else class="btn-spinner"></view>
      </button>
      
      <view class="cancel-link" catchtap="onCancel">
        <text>暂不登录，先去逛逛</text>
      </view>
    </view>
  </view>

  <!-- 全局防触摸遮罩 -->
  <view wx:if="{{loading}}" class="login-mask" catchtap="noop" catchtouchstart="noop" catchtouchmove="noop" catchtouchend="noop"></view>
</view>
