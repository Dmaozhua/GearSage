/* pages/login/login.wxss */
page {
  background-color: #f7f9fc;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: -200rpx;
  left: -10%;
  width: 120%;
  height: 500rpx;
  background: linear-gradient(135deg, #e3f0ff 0%, #f7f9fc 100%);
  border-radius: 0 0 50% 50%;
  z-index: 0;
}

.header {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 140rpx;
  margin-bottom: 80rpx;
}

.logo {
  width: 170rpx;
  height: 170rpx;
  margin-bottom: 32rpx;
  border-radius: 40rpx;
  box-shadow: 0 16rpx 32rpx rgba(58, 135, 240, 0.15);
  background: #ffffff;
  padding: 10rpx;
}

.title {
  font-size: 46rpx;
  font-weight: 700;
  color: #1a1f26;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #6e7a8a;
  letter-spacing: 1rpx;
}

.form-container {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 0 60rpx;
  box-sizing: border-box;
}

.server-debug-panel {
  margin-bottom: 40rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(32, 48, 64, 0.92);
  box-shadow: 0 12rpx 32rpx rgba(10, 18, 28, 0.14);
}

.server-debug-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.server-debug-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f5f7fa;
}

.server-debug-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(111, 209, 187, 0.18);
  color: #84f1d8;
  font-size: 22rpx;
}

.server-debug-url {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: rgba(231, 240, 248, 0.78);
  word-break: break-all;
}

.server-debug-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.server-debug-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #f2f6fa;
  font-size: 26rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
}

.server-debug-btn.active {
  background: #84f1d8;
  color: #15313a;
  border-color: #84f1d8;
}

.server-debug-btn::after {
  border: none;
}

.input-group {
  margin-bottom: 48rpx;
}

.input-label {
  font-size: 28rpx;
  color: #333d4a;
  margin-bottom: 20rpx;
  font-weight: 600;
  padding-left: 8rpx;
}

.input-wrapper,
.code-input-wrapper {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 24rpx;
  height: 104rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  overflow: hidden;
}

.input-wrapper:focus-within,
.code-input-wrapper:focus-within {
  border-color: #3a87f0;
  box-shadow: 0 8rpx 24rpx rgba(58, 135, 240, 0.08);
}

.input-prefix {
  font-size: 32rpx;
  color: #1a1f26;
  font-weight: 600;
  padding: 0 24rpx 0 32rpx;
  border-right: 2rpx solid #edf1f5;
}

.input-field {
  flex: 1;
  height: 100%;
  padding: 0 32rpx;
  font-size: 32rpx;
  color: #1a1f26;
  font-weight: 500;
}

.input-placeholder {
  color: #aab4c3;
  font-weight: 400;
}

.code-input {
  flex: 1;
}

.send-code-btn {
  height: 64rpx;
  line-height: 64rpx;
  background-color: #f0f6ff;
  color: #3a87f0;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 32rpx;
  padding: 0 32rpx;
  margin-right: 20rpx;
  border: none;
}

.btn-hover {
  background-color: #e1edff;
  opacity: 0.9;
}

.send-code-btn.disabled {
  color: #aab4c3;
  background-color: #f5f7fa;
}

.action-area {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #4492fe 0%, #2b70d4 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 50rpx;
  box-shadow: 0 12rpx 32rpx rgba(58, 135, 240, 0.25);
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.3s ease;
}

.login-btn-hover {
  transform: translateY(2rpx);
  box-shadow: 0 6rpx 16rpx rgba(58, 135, 240, 0.2);
}

.login-btn.disabled {
  background: #d4dbe3;
  color: #ffffff;
  box-shadow: none;
}

.btn-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: btn-spin 0.8s linear infinite;
}

.cancel-link {
  margin-top: 48rpx;
  padding: 20rpx;
}

.cancel-link text {
  font-size: 28rpx;
  color: #8a97a6;
  font-weight: 500;
}

/* 仅用于阻止点击的隐形遮罩，UI表现由按钮内loading实现 */
.login-mask {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: transparent;
}

@keyframes btn-spin {
  to { transform: rotate(360deg); }
}
