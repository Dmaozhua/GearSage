<custom-navbar
  id="custom-navbar"
  title="GearSage"
  show-back="{{false}}"
  left-icon="/images/logo/GearSageLogo.png"
  left-icon-dark="/images/logo/GearSageLogo-w.png"
  show-search="{{false}}"
  right-button-text=""
  background-color="#BDC3C7"
  text-color="#000000">
</custom-navbar>

<view class="pull-refresh-indicator {{containerClass}} {{isPullRefreshing ? 'pull-refresh-indicator--show' : ''}}" style="top: {{statusBarHeight + navBarHeight}}px;">
  <svg-loading spinning="{{true}}" showText="{{false}}" size="small" color="{{containerClass ? '#9cc3ff' : '#2c7cf6'}}"></svg-loading>
</view>

<view class="home-tool-page {{containerClass}}" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
  <view class="home-header">
    <view class="home-brand">
      <text class="home-brand__name">GearSage</text>
      <text class="home-brand__subtitle">路亚装备资料库与经验交流</text>
    </view>
    <view class="home-search" bindtap="onHomeSearchTap">
      <text class="home-search__icon">🔍</text>
      <text class="home-search__placeholder">搜索装备 / 型号 / SKU / 品牌</text>
    </view>
  </view>

  <view class="home-hero-card" bindtap="onHeroGearTap">
    <view class="home-hero-card__content">
      <text class="home-hero-card__title">查装备，问选择，看经验</text>
      <text class="home-hero-card__desc">看参数、比技术、找真实使用经验</text>
    </view>
    <view class="home-hero-card__action">
      <text>进入装备库</text>
      <text class="home-hero-card__arrow">›</text>
    </view>
  </view>

  <function-nav
    id="functionNav"
    show-title="{{false}}"
    function-list="{{homeFunctionList}}"
    container-height="{{functionNavHeight}}"
    bind:functionTap="onFunctionTap"
    bind:share="onShare"
    bind:refreshHome="onRefreshHome">
  </function-nav>

  <view class="home-preview">
    <view class="home-preview__loading" wx:if="{{homePreviewLoading}}">
      <svg-loading spinning="{{true}}" text="加载装备资料..." size="medium" show-text="{{true}}"></svg-loading>
    </view>

    <view class="home-section">
      <view class="home-section__header">
        <view>
          <text class="home-section__title">最近更新装备</text>
          <text class="home-section__subtitle">资料库新增与更新</text>
        </view>
        <view class="home-section__more" bindtap="onMoreRecentGear">查看更多</view>
      </view>
      <view wx:if="{{recentGearList.length === 0 && !homePreviewLoading}}" class="home-empty">暂无装备更新</view>
      <view wx:else class="home-card-list">
        <view
          wx:for="{{recentGearList}}"
          wx:key="id"
          class="home-gear-card"
          data-id="{{item.id}}"
          data-type="{{item.type}}"
          bindtap="onHomeGearItemTap">
          <image class="home-gear-card__image" src="{{item.imageUrl}}" mode="aspectFill" lazy-load="true"></image>
          <view class="home-gear-card__body">
            <text class="home-gear-card__title">{{item.title}}</text>
            <text class="home-gear-card__meta">{{item.meta}}</text>
            <view class="home-tag-row" wx:if="{{item.tags && item.tags.length}}">
              <text wx:for="{{item.tags}}" wx:key="*this" class="home-tag">{{item}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="home-section">
      <view class="home-section__header">
        <view>
          <text class="home-section__title">最新求推荐</text>
          <text class="home-section__subtitle">按真实需求找选择</text>
        </view>
        <view class="home-section__more" bindtap="onMoreRecommend">查看更多</view>
      </view>
      <view wx:if="{{latestRecommendList.length === 0 && !homePreviewLoading}}" class="home-empty">暂无新的求推荐</view>
      <view wx:else class="home-card-list">
        <view
          wx:for="{{latestRecommendList}}"
          wx:key="id"
          class="home-topic-card"
          data-id="{{item.id}}"
          bindtap="onHomeTopicTap">
          <view class="home-topic-card__label">求推荐</view>
          <view class="home-topic-card__main">
            <text class="home-topic-card__title">{{item.title}}</text>
            <text class="home-topic-card__meta">{{item.meta}}</text>
            <text class="home-topic-card__desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="home-section">
      <view class="home-section__header">
        <view>
          <text class="home-section__title">装备经验精选</text>
          <text class="home-section__subtitle">真实使用反馈预览</text>
        </view>
        <view class="home-section__more" bindtap="onMoreExperience">查看更多</view>
      </view>
      <view wx:if="{{featuredExperienceList.length === 0 && !homePreviewLoading}}" class="home-empty">暂无装备经验</view>
      <view wx:else class="home-card-list">
        <view
          wx:for="{{featuredExperienceList}}"
          wx:key="id"
          class="home-topic-card home-topic-card--experience"
          data-id="{{item.id}}"
          bindtap="onHomeTopicTap">
          <view class="home-topic-card__label">装备经验</view>
          <view class="home-topic-card__main">
            <text class="home-topic-card__title">{{item.title}}</text>
            <text class="home-topic-card__meta">{{item.meta}}</text>
            <text class="home-topic-card__desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="floating-publish-btn">
    <post-button bind:tap="onPublish" text=" GEARSAGE"></post-button>
  </view>
</view>
