/* pages/AnglerSay/AnglerSay.wxss */
@import "../../styles/dark.wxss";

/* 自定义导航栏样式 */
.custom-nav-bar .weui-navigation-bar__inner {
    z-index: 1000;
    --height: 50px; /* 增加导航栏高度 */
    background: linear-gradient(to right, #2c3e50, #34495e); /* 渐变背景 */
    color: white; /* 文字颜色 */
}
.banner-carousel-container {
    position: relative;
  }

.pull-refresh-indicator {
  position: fixed;
  left: 50%;
  transform: translateX(-50%) translateY(-8rpx);
  z-index: 10000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.15s ease, transform 0.15s ease;
}

.pull-refresh-indicator--show {
  opacity: 1;
  transform: translateX(-50%) translateY(8rpx);
}
  
  .banner-gradient {
    position: absolute;
    bottom: -1rpx; /* 避免出现缝隙 */
    left: 0;
    right: 0;
    height: 50rpx; /* 渐变高度，可调节 */
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0),  /* 轮播底部透明 */
      #f8f8f8                 /* 功能区背景色 */
    );
    pointer-events: none; /* 避免影响点击 */
  }

  /* 夜间模式下的banner-gradient */
  .dark-mode .banner-gradient {
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0),  /* 轮播底部透明 */
      #1a1a1a               /* 夜间模式功能区背景色 */
    );
  }
/* 页面容器 */
.container {
    display: flex;
    flex-direction: column;
    background-color: transparent; /* 改为透明，让子组件控制背景 */
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
    width: 100%;
    min-height: 100vh;
    padding: 0; /* 去除内边距 */
    margin: 0; /* 去除外边距 */
    align-items: stretch;
    justify-content: flex-start;
    /* 轮播图下方不需要额外的padding-top */
}

.container.dark-mode {
    background:
      radial-gradient(circle at top left, rgba(109, 136, 164, 0.18), transparent 34%),
      radial-gradient(circle at bottom right, rgba(74, 92, 115, 0.14), transparent 30%),
      linear-gradient(180deg, #0d141d 0%, #111a25 44%, #0c1219 100%);
}

.filter-toolbar {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 0 0rpx 0rpx;
    gap: 24rpx;
    box-sizing: border-box;
}

.dark-mode .filter-toolbar {
    margin-top: -2rpx;
    background:
      radial-gradient(circle at top left, rgba(109, 136, 164, 0.18), transparent 34%),
      radial-gradient(circle at bottom right, rgba(74, 92, 115, 0.14), transparent 30%),
      linear-gradient(180deg, #0d141d 0%, #111a25 44%, #0c1219 100%);
}

.filter-toolbar__tabs {
    flex: 1;
    min-width: 0;
}

.layout-toggle {
    display: flex;
    align-items: center;
    gap: 16rpx;
    padding: 12rpx 16rpx;
    background: rgba(255, 255, 255, 0.75);
    border-radius: 28rpx;
    box-shadow: 0 8rpx 24rpx rgba(44, 62, 80, 0.08);
    backdrop-filter: blur(12rpx);
    -webkit-backdrop-filter: blur(12rpx);
}

.layout-toggle__button {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6rpx;
    padding: 12rpx 18rpx;
    border-radius: 22rpx;
    color: #6b7280;
    font-size: 20rpx;
    transition: all 0.22s ease;
}

.layout-toggle__button--hover {
    opacity: 0.85;
}

.layout-toggle__button--active {
    background: transparent;
    color: #2c7cf6;
    box-shadow: none;
}

.layout-toggle__icon {
    position: relative;
    width: 48rpx;
    height: 48rpx;
    color: currentColor;
}

.layout-toggle__icon::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 14rpx;
    border: 2rpx solid currentColor;
    opacity: 0.35;
}

.layout-toggle__icon--list::after {
    content: '';
    position: absolute;
    left: 20%;
    right: 20%;
    top: 26%;
    height: 4rpx;
    background: currentColor;
    border-radius: 999rpx;
    box-shadow: 0 12rpx 0 0 currentColor, 0 24rpx 0 0 currentColor;
}

.layout-toggle__icon--waterfall::after {
    content: '';
    position: absolute;
    left: 18%;
    right: 18%;
    top: 18%;
    bottom: 18%;
    border-radius: 12rpx;
    background: linear-gradient(90deg, currentColor 0 45%, transparent 45% 55%, currentColor 55% 100%);
    opacity: 0.75;
}

.layout-toggle__label {
    font-size: 20rpx;
    letter-spacing: 1rpx;
}

.dark-mode .layout-toggle {
    background: rgba(30, 33, 44, 0.8);
    box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.35);
}

.dark-mode .layout-toggle__button {
    color: rgba(255, 255, 255, 0.72);
}

.dark-mode .layout-toggle__button--active {
    background: transparent;
    color: #9cc3ff;
    box-shadow: none;
}

.layout-transition {
    animation: layout-fade-in 0.24s ease;
}

@keyframes layout-fade-in {
    from {
        opacity: 0;
        transform: translateY(16rpx);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* 轮播图容器样式 */
.banner-carousel {
    width: 100%;
    position: relative;
    z-index: 1;
}

/* 功能导航区域样式 */
.function-nav {
  width: 100%;
  position: relative;
  z-index: 2;
  background: linear-gradient(135deg, 
    rgba(255, 255, 255, 0.1) 0%, 
    rgba(255, 255, 255, 0.05) 100%);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-bottom: none;
}

.dark-mode .function-nav {
  background: transparent;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  border-bottom: none;
}

/* 导航栏毛玻璃效果增强 */
.custom-navbar {
    backdrop-filter: blur(20rpx);
    -webkit-backdrop-filter: blur(20rpx);
    transition: background-color 0.5s ease, color 0.3s ease;
}

.home-feed {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
}

.home-feed--waterfall {
    padding-bottom: 10rpx;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(255, 255, 255, 0.75) 100%);
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
}

.dark-mode .home-feed--waterfall {
    background: linear-gradient(180deg, rgba(19, 21, 28, 0.95) 0%, rgba(19, 21, 28, 0.8) 100%);
}

.waterfall-scroll {
    flex: 1;
    padding: 2rpx 6rpx 20rpx;
    box-sizing: border-box;
    min-height: 0;
    height: 100%;
}

.waterfall-container {
    display: flex;
    align-items: flex-start;
    gap: 4rpx;
    width: 100%;
    box-sizing: border-box;
}

.waterfall-column {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4rpx;
}

.waterfall-card {
    position: relative;
    border-radius: 20rpx;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.85);
    box-shadow: 0 18rpx 42rpx rgba(44, 62, 80, 0.18);
    transform-origin: center;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.waterfall-card:active {
    transform: translateY(4rpx) scale(0.995);
    box-shadow: 0 12rpx 28rpx rgba(44, 62, 80, 0.22);
}

.dark-mode .waterfall-card {
    background: rgba(32, 35, 42, 0.92);
    box-shadow: 0 20rpx 46rpx rgba(0, 0, 0, 0.45);
}

.waterfall-card__media {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 20rpx;
}

.waterfall-card__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 20rpx;
    z-index: 0;
}

.waterfall-card__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, rgba(44, 62, 80, 0.25), rgba(44, 62, 80, 0.08));
    color: #2c3e50;
    font-size: 28rpx;
    font-weight: 600;
    letter-spacing: 2rpx;
    text-align: center;
    padding: 24rpx;
    box-sizing: border-box;
    z-index: 0;
}

.dark-mode .waterfall-card__placeholder {
    background: linear-gradient(145deg, rgba(90, 112, 150, 0.35), rgba(90, 112, 150, 0.12));
    color: rgba(255, 255, 255, 0.85);
}

.waterfall-card__placeholder-text {
    display: inline-block;
    line-height: 1.4;
}

.waterfall-card__overlay {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 24rpx;
    display: flex;
    flex-direction: column;
    gap: 16rpx;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.68) 100%);
    color: #fff;
    z-index: 1;
}

.dark-mode .waterfall-card__overlay {
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.75) 100%);
}

.waterfall-card__title {
    font-size: 28rpx;
    font-weight: 600;
    color: #ffffff;
    text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.35);
}

.waterfall-card__footer {
    display: flex;
    align-items: center;
    gap: 16rpx;
}

.waterfall-card__avatar {
    width: 64rpx;
    height: 64rpx;
    border-radius: 50%;
    border: 2rpx solid rgba(255, 255, 255, 0.7);
    box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.25);
}

.waterfall-card__user {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8rpx;
    min-width: 0;
}

.waterfall-card__name {
    font-size: 24rpx;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.95);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.waterfall-card__tags {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6rpx;
}

.waterfall-card__tag {
    padding: 4rpx 12rpx;
    border-radius: 999rpx;
    font-size: 18rpx;
    background: rgba(255, 255, 255, 0.16);
    color: rgba(255, 255, 255, 0.88);
}

.waterfall-card__stats {
    display: flex;
    align-items: center;
    gap: 12rpx;
}

.waterfall-card__stat {
    display: flex;
    align-items: center;
    gap: 6rpx;
}

.waterfall-card__stat-icon {
    width: 28rpx;
    height: 28rpx;
    opacity: 0.9;
}

.waterfall-card__stat-value {
    font-size: 22rpx;
    color: rgba(255, 255, 255, 0.92);
}

.waterfall-loading {
    display: flex;
    justify-content: center;
    gap: 10rpx;
    padding: 20rpx 0 40rpx;
}

.waterfall-loading__dot {
    width: 12rpx;
    height: 12rpx;
    border-radius: 50%;
    background: rgba(44, 124, 246, 0.8);
    animation: waterfall-loading-pulse 0.9s ease-in-out infinite;
}

.dark-mode .waterfall-loading__dot {
    background: rgba(120, 163, 255, 0.85);
}

.waterfall-loading__dot:nth-child(2) {
    animation-delay: 0.15s;
}

.waterfall-loading__dot:nth-child(3) {
    animation-delay: 0.3s;
}

@keyframes waterfall-loading-pulse {
    0%, 100% {
        transform: scale(0.6);
        opacity: 0.4;
    }
    50% {
        transform: scale(1);
        opacity: 1;
    }
}

.angler-skeleton {
    display: flex;
    flex-direction: column;
    gap: 24rpx;
    padding: 20rpx;
    box-sizing: border-box;
    width: 100%;
    max-width: 100%;
}

.skeleton-card {
    background: rgba(255, 255, 255, 0.7);
    border-radius: 24rpx;
    padding: 32rpx;
    box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
    overflow: hidden;
    position: relative;
}

.dark-mode .skeleton-card {
    background: rgba(32, 35, 42, 0.75);
    box-shadow: 0 10rpx 32rpx rgba(0, 0, 0, 0.45);
}

.skeleton-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: -150%;
    width: 120%;
    height: 100%;
    background: linear-gradient(120deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.2) 40%, rgba(255,255,255,0) 80%);
    animation: skeleton-glow 1.6s ease-in-out infinite;
}

.dark-mode .skeleton-card::after {
    background: linear-gradient(120deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.08) 40%, rgba(255,255,255,0) 80%);
}

.skeleton-header {
    display: flex;
    align-items: center;
    gap: 24rpx;
}

.skeleton-avatar {
    width: 112rpx;
    height: 112rpx;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(220, 226, 236, 0.8), rgba(244, 247, 252, 0.6));
}

.dark-mode .skeleton-avatar {
    background: linear-gradient(135deg, rgba(70, 74, 88, 0.7), rgba(54, 58, 70, 0.6));
}

.skeleton-header-lines {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12rpx;
}

.skeleton-body {
    margin: 28rpx 0;
    display: flex;
    flex-direction: column;
    gap: 18rpx;
}

.skeleton-line {
    height: 24rpx;
    border-radius: 16rpx;
    background: linear-gradient(135deg, rgba(220, 226, 236, 0.65), rgba(244, 247, 252, 0.5));
}

.dark-mode .skeleton-line {
    background: linear-gradient(135deg, rgba(70, 74, 88, 0.6), rgba(54, 58, 70, 0.4));
}

.skeleton-line--primary {
    width: 340rpx;
}

.skeleton-line--secondary {
    width: 260rpx;
}

.skeleton-line--full {
    width: 100%;
}

.skeleton-line--medium {
    width: 80%;
}

.skeleton-thumbs {
    display: flex;
    gap: 16rpx;
}

.skeleton-thumb {
    flex: 1;
    height: 160rpx;
    border-radius: 18rpx;
    background: linear-gradient(135deg, rgba(220, 226, 236, 0.6), rgba(244, 247, 252, 0.45));
}

.dark-mode .skeleton-thumb {
    background: linear-gradient(135deg, rgba(70, 74, 88, 0.5), rgba(54, 58, 70, 0.35));
}

.skeleton-footer {
    margin-top: 24rpx;
    display: flex;
    gap: 20rpx;
}

.skeleton-chip {
    flex: 1;
    height: 40rpx;
    border-radius: 999rpx;
    background: linear-gradient(135deg, rgba(220, 226, 236, 0.5), rgba(244, 247, 252, 0.4));
}

.dark-mode .skeleton-chip {
    background: linear-gradient(135deg, rgba(70, 74, 88, 0.4), rgba(54, 58, 70, 0.3));
}

@keyframes skeleton-glow {
    0% {
        transform: translateX(-150%);
    }
    100% {
        transform: translateX(100%);
    }
}

/* 钓友说列表 */
.angler-list {
    flex: 1;
    padding: 10rpx;
    overflow-y: auto;
    width: 100%; 
    display: flex; 
    flex-direction: column;
    align-items: center; 
    /* 添加以下样式 */
    box-sizing: border-box; /* 确保内边距和边框不会影响宽度 */
    margin: 0 auto; /* 水平居中 */
    max-width: 110%; /* 确保不会超出屏幕宽度 */
        /* 添加背景增强毛玻璃效果 */
        background:rgba(245, 245, 250, 0.7);
}

/* 钓友卡片容器 */
.angler-item {
    margin-bottom: 30rpx;
    width: 99%;
  }

.angler-card {
    position: relative; /* 关键：为伪元素定位提供参考 */
    background-color: rgba(255, 255, 255, 0.801);
    border-radius: 24rpx;
    padding: 20rpx 40rpx; 
    box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1); 
    transition: all 0.3s;
    /* 新增样式，设置宽度为 100%，确保卡片占满 item */
    width: 100%; 
    box-sizing: border-box; /* 确保内边距不会影响宽度 */
  }
  
/* 毛玻璃背景层 */
.angler-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(245, 245, 255, 0.65);
    backdrop-filter: blur(25rpx);
    -webkit-backdrop-filter: blur(25rpx);
    border: 1.5rpx solid rgba(255, 255, 255, 0.6);
    border-radius: 24rpx;
    box-shadow: 
      0 8rpx 32rpx rgba(142, 140, 140, 0.15),
      0 4rpx 16rpx rgba(140, 139, 139, 0.12),
      inset 0 2rpx 1px rgba(255, 255, 255, 0.7),
      inset 0 -1px 1px rgba(0, 0, 0, 0.08);
    z-index: 1; /* 置于底层 */
  }
  
  /* 添加微妙的渐变光泽 */
  .angler-card::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 40%;
    border-radius: 24rpx 24rpx 0 0;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.25) 0%,
      rgba(255, 255, 255, 0) 80%
    );
    pointer-events: none;
    z-index: 2; /* 置于背景层之上 */
  }
  
  /* 卡片悬停效果 */
  .angler-card:hover {
    transform: translateY(-8rpx);
    box-shadow: 0 12rpx 30rpx rgba(74, 74, 74, 0.18);
    border-radius: 20rpx;
  }
  
  .clickable-area,
  .interaction-btns {
    position: relative;
    z-index: 3; /* 确保内容在毛玻璃层上方 */
  }
/* 可点击区域 */
.clickable-area {
  cursor: pointer;
  transition: opacity 0.2s;
}

.clickable-area:active {
  opacity: 0.8;
}
/* 用户信息 */
.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

/* 用户头像添加毛玻璃边框效果 */
.user-avatar {
    width: 120rpx;
    height: 120rpx;
    border-radius: 50%;
    border: 1.5rpx solid rgba(255, 255, 255, 0.6);
    background-color: #f2f4f7;
    box-shadow:
      0 2rpx 8rpx rgba(0, 0, 0, 0.1),
      inset 0 1rpx 1px rgba(255, 255, 255, 0.7);
}

.dark-mode .user-avatar {
    background-color: rgba(70, 74, 88, 0.6);
}
  

.user-detail {
  flex: 1;
}

.user-name {
  /* font-size: 40rpx; */
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 10rpx;
  margin-left: 10rpx;
}

/* user-tag 样式已移至组件中 */
/* 给clock-icon添加垂直居中 */
.clock-icon {
    width: 24rpx;
    height: 24rpx;
    margin-right: 10rpx;
    margin-left: 10rpx;
    opacity: 1;
    vertical-align: middle; /* 新增：垂直居中对齐 */
  }

.user-meta-line {
    display: flex;
    align-items: center;
    margin-top: 8rpx;
}
  
  /* 给user-year添加垂直居中 */
  .user-year {
    font-size: 24rpx;
    color: #666;
    background-color: #f5f7fa;
    padding: 2.5rpx 12rpx;
    border-radius: 16rpx;
    display: inline-block;
    /* margin-top: 8rpx; */
    vertical-align: middle; /* 新增：垂直居中对齐 */
  }
.follow-btn {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  color: #3a87f0;
  border: 1rpx solid #3a87f0;
  border-radius: 30rpx;
}

/* 产品信息 */
.product-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.product-name {
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.topic-badge {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(44, 124, 246, 0.12);
  color: #2c7cf6;
  font-size: 22rpx;
  font-weight: 600;
}

.product-meta {
  margin-bottom: 14rpx;
}

.product-meta__text {
  font-size: 24rpx;
  color: #758095;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.product-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(44, 62, 80, 0.08);
  color: #425466;
  font-size: 22rpx;
}

.product-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #f7997d;
}

/* 产品图片区域优化 */
.product-images {
    display: flex;
    flex-wrap: wrap;
    gap: 15rpx;
    margin: 20rpx 0;
  }
/* 帖子图片 */

.product-image {
  width: 186rpx;
  height: 186rpx;
  margin-right: 10rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  background-color: #f2f4f7;
    /* 给图片添加毛玻璃边框效果 */
    border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow:
  0 3rpx 10rpx rgba(0, 0, 0, 0.1),
  inset 0 1rpx 1px rgba(255, 255, 255, 0.6);
  transition: all 0.3s;
}

/* 产品描述 */
.product-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 20rpx;
  max-height: 200rpx; /* 限制最大高度，约显示3行文本 */
  overflow: hidden; /* 隐藏溢出内容 */
  text-overflow: ellipsis; /* 显示省略号 */
  display: -webkit-box;
  -webkit-line-clamp: 5; /* 限制最多显示3行 */
  -webkit-box-orient: vertical;
}

.product-desc-rich-text {
  word-break: break-all;
  overflow-wrap: anywhere;
  max-width: 100%;
  display: block;
}

/* 评分信息 */
.rating-info {
    margin-bottom: 20rpx;
  }
  
  .rating-stars {
    display: flex;
    align-items: center;
    position: relative;
  }
  
  /* 一个 wrapper 用来限制背景和前景重叠对齐 */
  .stars-wrapper {
    position: relative;
    display: inline-block;
    /* 确保高度与字体大小一致，避免错位 */
    line-height: 28rpx;
  }
  
  /* 背景空心星，位于最底层 */
  .star-background {
    display: flex;
    color: #ddd;
    position: relative; /* foreground 用绝对定位覆盖在它上面 */
    z-index: 0;
  }
  
  /* 前景实心星，绝对定位并通过 width 控制可见区域 */
  .star-foreground {
    display: flex;
    position: absolute;
    top: 0;
    left: 0;
    overflow: hidden;
    z-index: 1;
    white-space: nowrap; /* 防止换行 */
    transition: width 0.25s ease;
  }
  
  /* 星星文字样式，保持一致的尺寸与间距 */
  .star-bg,
  .star-fg {
    font-size: 28rpx;
    margin-right: 4rpx;
    line-height: 28rpx;
    display: inline-block;
    pointer-events: none;
  }
  
  /* 前景星颜色 */
  .star-fg {
    color: #ffc107;
  }
  
  /* 数值显示在右侧，确保在最上层 */
  .rating-value {
    font-size: 28rpx;
    color: #333;
    margin-left: 10rpx;
    position: relative;
    z-index: 2;
  }

/* .rating-count {
  font-size: 24rpx;
