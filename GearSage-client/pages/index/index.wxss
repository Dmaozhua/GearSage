/* 互动按钮 */
.interaction-btns {
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(200, 200, 220, 0.3);
}

.interaction-btn {
    display: flex;
    align-items: center;
    padding: 1rpx 20rpx;
    border-radius: 30rpx;
    background: rgba(230, 230, 240, 0.4);
    backdrop-filter: blur(10rpx);
    -webkit-backdrop-filter: blur(10rpx);
    border: 0.5rpx solid rgba(255, 255, 255, 0.5);
    box-shadow: 
      inset 0 1rpx 1px rgba(255, 255, 255, 0.7),
      0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  }

.interaction-btn:active {
  background-color: #e9ecef;
  transform: scale(0.95);
}

.interaction-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.interaction-icon-img {
    width: 42rpx;
    height: 42rpx;
    margin-right: 8rpx;
  }

.interaction-count {
  font-size: 24rpx;
  color: #6c757d;
}

/* 已点赞状态样式 */
/* .interaction-btn.liked {
  background-color: #ffe6e6;
  border: 1rpx solid #ff6b6b;
} */

.interaction-btn.liked .interaction-icon {
  color: #ff6b6b;
}

.interaction-btn.liked .interaction-count {
  color: #ff6b6b;
  font-weight: bold;
}

/* 文章页签样式 */
.article-container {
  padding: 20rpx;
  background-color: #f8f9fa;
  min-height: calc(100vh - 200rpx);
}

/* 文章列表 */
.article-list {
  padding-bottom: 120rpx;
  -webkit-overflow-scrolling: touch;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.article-card {
  background-color: white;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  will-change: transform;
}

.article-card-hover {
  transform: translateY(-3rpx);
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.1);
  background-color: #f0f4ff;
}

.article-content {
  width: 100%;
}

.article-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
  line-height: 1.4;
}

.article-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
  font-size: 24rpx;
  color: #6c757d;
}

.article-author {
  color: #1E3A8A;
}

.article-date {
  color: #6c757d;
}

.article-preview {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

/* 加载中提示 */
.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #6c757d;
  font-size: 28rpx;
}

/* 悬浮发布按钮容器 - 仅负责定位 */
.floating-publish-btn {
  position: fixed;
  bottom: 50rpx;
  right: 60rpx;
  z-index: 999;
}

/* 悬浮动画 */
@keyframes float {
  0%, 100% {
    transform: translateY(0rpx);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

/* 旋转动画 */
@keyframes rotate {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

