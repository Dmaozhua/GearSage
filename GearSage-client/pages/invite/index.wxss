.invite-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(154, 186, 214, 0.28), transparent 34%),
    linear-gradient(180deg, #eef5fb 0%, #f7fbff 42%, #ffffff 100%);
}

.invite-page.dark {
  background:
    radial-gradient(circle at top left, rgba(109, 136, 164, 0.18), transparent 34%),
    linear-gradient(180deg, #0e1721 0%, #111c28 42%, #0b131c 100%);
}

.invite-shell {
  padding: 28rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.hero-card,
.panel-card,
.footer-card {
  margin-bottom: 24rpx;
  padding: 32rpx 28rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(151, 177, 201, 0.22);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(246, 250, 255, 0.9)),
    linear-gradient(135deg, rgba(170, 196, 219, 0.1), rgba(170, 196, 219, 0));
  box-shadow:
    0 20rpx 44rpx rgba(121, 145, 170, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.88);
}

.invite-page.dark .hero-card,
.invite-page.dark .panel-card,
.invite-page.dark .footer-card {
  border-color: rgba(103, 124, 147, 0.26);
  background:
    linear-gradient(180deg, rgba(19, 28, 39, 0.96), rgba(14, 22, 31, 0.98)),
    linear-gradient(135deg, rgba(132, 160, 188, 0.08), rgba(132, 160, 188, 0));
  box-shadow:
    0 22rpx 50rpx rgba(3, 8, 14, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.hero-badge,
.section-kicker {
  display: inline-flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(67, 100, 128, 0.1);
  color: #436480;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.invite-page.dark .hero-badge,
.invite-page.dark .section-kicker {
  background: rgba(156, 187, 214, 0.12);
  color: #d4e4f1;
}

.hero-title,
.section-title,
.footer-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #102033;
}

.invite-page.dark .hero-title,
.invite-page.dark .section-title,
.invite-page.dark .footer-title {
  color: #eef5fb;
}

.hero-desc,
.footer-desc,
.invite-desc,
.share-tip,
.benefit-desc,
.step-text,
.meta-label,
.meta-value {
  display: block;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(16, 32, 51, 0.68);
}

.invite-page.dark .hero-desc,
.invite-page.dark .footer-desc,
.invite-page.dark .invite-desc,
.invite-page.dark .share-tip,
.invite-page.dark .benefit-desc,
.invite-page.dark .step-text,
.invite-page.dark .meta-label,
.invite-page.dark .meta-value {
  color: rgba(228, 237, 246, 0.72);
}

.incoming-card {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(240, 247, 252, 0.86);
}

.invite-page.dark .incoming-card {
  background: rgba(255, 255, 255, 0.04);
}

.incoming-label,
.invite-code-label,
.benefit-title,
.meta-label {
  display: block;
  font-size: 22rpx;
  color: rgba(16, 32, 51, 0.56);
}

.invite-page.dark .incoming-label,
.invite-page.dark .invite-code-label,
.invite-page.dark .benefit-title,
.invite-page.dark .meta-label {
  color: rgba(208, 221, 233, 0.6);
}

.incoming-code,
.invite-name,
.invite-code-value {
  display: block;
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #102033;
}

.invite-page.dark .incoming-code,
.invite-page.dark .invite-name,
.invite-page.dark .invite-code-value {
  color: #f1f7fc;
}

.invite-head {
  display: flex;
  gap: 20rpx;
  align-items: stretch;
  justify-content: space-between;
}

.invite-copy {
  flex: 1;
  min-width: 0;
}

.invite-code-box {
  min-width: 196rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(238, 245, 251, 0.86);
}

.invite-page.dark .invite-code-box {
  background: rgba(255, 255, 255, 0.04);
}

.invite-meta {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.meta-item,
.benefit-item,
.step-item {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(245, 249, 253, 0.86);
}

.invite-page.dark .meta-item,
.invite-page.dark .benefit-item,
.invite-page.dark .step-item {
  background: rgba(255, 255, 255, 0.03);
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.primary-btn,
.secondary-btn,
.footer-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.primary-btn,
.footer-btn {
  color: #f8fbff;
  background: linear-gradient(135deg, #4c6a84 0%, #7a9ab6 100%);
}

.secondary-btn {
  color: #294764;
  background: rgba(241, 247, 252, 0.96);
  border: 1rpx solid rgba(113, 139, 163, 0.2);
}

.invite-page.dark .secondary-btn {
  color: #dbe7f2;
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(132, 160, 188, 0.16);
}

.primary-btn,
.secondary-btn {
  flex: 1;
}

.primary-btn::after,
.secondary-btn::after,
.footer-btn::after {
  border: none;
}

.share-tip {
  margin-top: 18rpx;
}

.benefit-list,
.step-list {
  display: grid;
  gap: 16rpx;
  margin-top: 22rpx;
}

.step-item {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.step-index {
  min-width: 56rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #4d6b86;
}

.invite-page.dark .step-index {
  color: #d2e2ef;
}

.footer-btn {
  margin-top: 26rpx;
}
