@import "../../styles/dark.wxss";

page {
  min-height: 100vh;
  background: #f4f7f5;
}

.gear-tab-scroll {
  min-height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(180deg, #edf3f1 0%, #f8f9f7 52%, #ffffff 100%);
}

.gear-tab-scroll.dark {
  background: linear-gradient(180deg, #0d141d 0%, #111a25 48%, #0c1219 100%);
}

.gear-tab-page {
  padding: 30rpx 32rpx 180rpx;
  box-sizing: border-box;
}

.gear-tab-header {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.gear-tab-title {
  font-size: 46rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #20302f;
}

.gear-tab-subtitle {
  font-size: 26rpx;
  line-height: 1.45;
  color: #64716d;
}

.gear-search-panel,
.gear-category-card,
.gear-compare-card,
.gear-list-card {
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(77, 100, 95, 0.12);
  box-shadow: 0 10rpx 26rpx rgba(35, 48, 47, 0.06);
}

.gear-search-panel {
  padding: 22rpx;
  box-sizing: border-box;
}

.gear-search-box {
  height: 76rpx;
  border-radius: 8rpx;
  background: #f1f5f3;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
}

.gear-search-icon {
  font-size: 28rpx;
}

.gear-search-input {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #263532;
}

.gear-search-types {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.gear-search-type {
  padding: 10rpx 18rpx;
  border-radius: 6rpx;
  background: #edf2f0;
  color: #52615c;
  font-size: 24rpx;
}

.gear-search-type--active {
  background: #2f6f5e;
  color: #ffffff;
}

.gear-search-button {
  margin-top: 18rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 8rpx;
  background: #22312f;
  color: #ffffff;
  font-size: 26rpx;
}

.gear-section {
  margin-top: 30rpx;
}

.gear-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.gear-section-title {
  font-size: 32rpx;
  font-weight: 750;
  color: #22312f;
}

.gear-category-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
}

.gear-category-card {
  min-height: 118rpx;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.gear-category-icon {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
}

.gear-category-copy,
.gear-list-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.gear-category-title,
.gear-list-title,
.gear-compare-title {
  font-size: 28rpx;
  line-height: 1.35;
  color: #22312f;
  font-weight: 700;
}

.gear-category-desc,
.gear-list-meta,
.gear-compare-desc {
  font-size: 23rpx;
  color: #6f7b77;
  line-height: 1.4;
}

.gear-category-arrow,
.gear-compare-arrow {
  font-size: 42rpx;
  color: #6a7773;
}

.gear-compare-card {
  margin-top: 26rpx;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.gear-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.gear-list-card {
  padding: 16rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.gear-list-image {
  width: 112rpx;
  height: 112rpx;
  border-radius: 8rpx;
  background: #edf0ef;
  flex-shrink: 0;
}

.gear-empty,
.gear-loading {
  border-radius: 8rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #798580;
  font-size: 24rpx;
  text-align: center;
}

.dark .gear-tab-title,
.dark .gear-section-title,
.dark .gear-category-title,
.dark .gear-list-title,
.dark .gear-compare-title {
  color: #eef5f2;
}

.dark .gear-tab-subtitle,
.dark .gear-category-desc,
.dark .gear-list-meta,
.dark .gear-compare-desc {
  color: rgba(236, 244, 241, 0.68);
}

.dark .gear-search-panel,
.dark .gear-category-card,
.dark .gear-compare-card,
.dark .gear-list-card,
.dark .gear-empty,
.dark .gear-loading {
  background: rgba(24, 34, 44, 0.88);
  border-color: rgba(255, 255, 255, 0.08);
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.25);
}

.dark .gear-search-box,
.dark .gear-search-type {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(236, 244, 241, 0.72);
}

.dark .gear-search-type--active {
  background: #76b9a5;
  color: #0c1219;
}

.dark .gear-search-input {
  color: #eef5f2;
}
