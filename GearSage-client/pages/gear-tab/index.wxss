@import "../../styles/dark.wxss";

page {
  min-height: 100vh;
  background: #f4f5f1;
}

.gear-tab-scroll {
  min-height: 100vh;
  box-sizing: border-box;
  background: #f4f5f1;
}

.gear-tab-scroll.dark {
  background: #0f1518;
}

.gear-tab-page {
  padding: 28rpx 28rpx 180rpx;
  box-sizing: border-box;
}

.gear-tab-header {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 26rpx;
  padding: 4rpx 4rpx 0;
}

.gear-tab-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1f2a27;
}

.gear-tab-subtitle {
  max-width: 640rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: #68716b;
}

.gear-search-panel,
.gear-category-card,
.gear-compare-card,
.gear-selection-card,
.gear-list-card {
  border-radius: 10rpx;
  background: #ffffff;
  border: 1rpx solid rgba(58, 68, 62, 0.11);
  box-shadow: 0 6rpx 18rpx rgba(31, 42, 39, 0.045);
}

.gear-search-panel {
  padding: 22rpx 22rpx 24rpx;
  box-sizing: border-box;
  border-top: 4rpx solid #4f6654;
}

.gear-search-box {
  height: 78rpx;
  border-radius: 8rpx;
  background: #f6f7f3;
  border: 1rpx solid rgba(67, 79, 72, 0.12);
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.gear-search-icon {
  position: relative;
  width: 26rpx;
  height: 26rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  border: 3rpx solid #62706a;
  border-radius: 50%;
}

.gear-search-icon::after {
  content: "";
  position: absolute;
  right: -8rpx;
  bottom: -6rpx;
  width: 12rpx;
  height: 3rpx;
  border-radius: 2rpx;
  background: #62706a;
  transform: rotate(45deg);
}

.gear-search-input {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #263532;
}

.gear-search-types {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.gear-search-type {
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 6rpx;
  background: #f2f3ef;
  border: 1rpx solid rgba(67, 79, 72, 0.1);
  color: #59655f;
  font-size: 23rpx;
  line-height: 48rpx;
  box-sizing: border-box;
}

.gear-search-type--active {
  background: #33443c;
  border-color: #33443c;
  color: #ffffff;
}

.gear-search-button {
  margin-top: 20rpx;
  height: 74rpx;
  line-height: 74rpx;
  border-radius: 8rpx;
  background: #26332d;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}

.gear-search-button::after {
  border: 0;
}

.gear-section {
  margin-top: 34rpx;
}

.gear-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  padding: 0 2rpx;
}

.gear-section-title {
  position: relative;
  padding-left: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2a27;
  line-height: 1.35;
}

.gear-section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 8rpx;
  width: 6rpx;
  height: 26rpx;
  border-radius: 4rpx;
  background: #6c7654;
}

.gear-category-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
}

.gear-category-card {
  min-height: 116rpx;
  padding: 18rpx 20rpx 18rpx 18rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.gear-category-icon {
  width: 70rpx;
  height: 70rpx;
  padding: 10rpx;
  border-radius: 8rpx;
  background: #f2f4ef;
  box-sizing: border-box;
  flex-shrink: 0;
}

.gear-category-copy,
.gear-list-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.gear-category-title,
.gear-list-title,
.gear-compare-title {
  font-size: 28rpx;
  line-height: 1.35;
  color: #1f2a27;
  font-weight: 700;
}

.gear-category-desc,
.gear-list-meta,
.gear-compare-desc {
  font-size: 23rpx;
  color: #747d76;
  line-height: 1.45;
}

.gear-category-arrow,
.gear-compare-arrow {
  font-size: 40rpx;
  color: #8a918a;
}

.gear-compare-card {
  margin-top: 24rpx;
  padding: 24rpx 22rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-left: 6rpx solid #8b8469;
}

.gear-selection-card {
  margin-top: 18rpx;
  padding: 24rpx 22rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-left: 6rpx solid #60715e;
}

.gear-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.gear-list-card {
  padding: 16rpx 18rpx 16rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.gear-list-image {
  width: 116rpx;
  height: 116rpx;
  border-radius: 8rpx;
  background: #eef0ec;
  flex-shrink: 0;
  border: 1rpx solid rgba(67, 79, 72, 0.08);
}

.gear-empty,
.gear-loading {
  border-radius: 8rpx;
  padding: 34rpx 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(58, 68, 62, 0.1);
  color: #7d857e;
  font-size: 24rpx;
  text-align: center;
}

.dark .gear-tab-title,
.dark .gear-section-title,
.dark .gear-category-title,
.dark .gear-list-title,
.dark .gear-compare-title {
  color: #eef5f2;
}

.dark .gear-tab-subtitle,
.dark .gear-category-desc,
.dark .gear-list-meta,
.dark .gear-compare-desc {
  color: rgba(236, 244, 241, 0.68);
}

.dark .gear-search-panel,
.dark .gear-category-card,
.dark .gear-compare-card,
.dark .gear-selection-card,
.dark .gear-list-card,
.dark .gear-empty,
.dark .gear-loading {
  background: #182028;
  border-color: rgba(229, 236, 231, 0.08);
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.22);
}

.dark .gear-search-box,
.dark .gear-search-type {
  background: rgba(238, 245, 242, 0.08);
  border-color: rgba(238, 245, 242, 0.08);
  color: rgba(236, 244, 241, 0.72);
}

.dark .gear-search-type--active {
  background: #9aa083;
  border-color: #9aa083;
  color: #101619;
}

.dark .gear-search-input {
  color: #eef5f2;
}

.dark .gear-search-icon {
  border-color: rgba(238, 245, 242, 0.66);
}

.dark .gear-search-icon::after {
  background: rgba(238, 245, 242, 0.66);
}

.dark .gear-category-icon {
  background: rgba(238, 245, 242, 0.08);
}

.dark .gear-list-image {
  background: rgba(238, 245, 242, 0.08);
  border-color: rgba(238, 245, 242, 0.06);
}
