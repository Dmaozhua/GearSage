page {
  min-height: 100vh;
  background: #f3f3f1;
}

.feedback-page {
  min-height: 100vh;
  padding: 22rpx;
  box-sizing: border-box;
}

.gear-summary,
.form-section {
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(16, 27, 34, 0.05);
}

.gear-summary {
  padding: 28rpx;
  margin-bottom: 22rpx;
}

.gear-summary__label {
  display: block;
  font-size: 23rpx;
  color: #6d7e79;
  margin-bottom: 8rpx;
}

.gear-summary__name {
  display: block;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #24343b;
}

.gear-summary__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.gear-summary__meta text {
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #eef3f0;
  color: #526963;
  font-size: 22rpx;
  line-height: 40rpx;
}

.form-section {
  padding: 28rpx;
}

.form-field + .form-field {
  margin-top: 28rpx;
}

.field-label {
  display: block;
  font-size: 25rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #273934;
  margin-bottom: 12rpx;
}

.picker-value,
.text-input,
.content-input {
  width: 100%;
  box-sizing: border-box;
  border-radius: 14rpx;
  border: 1rpx solid rgba(70, 91, 82, 0.16);
  background: #f8faf8;
  color: #263a35;
  font-size: 26rpx;
}

.picker-value,
.text-input {
  min-height: 78rpx;
  padding: 0 22rpx;
  line-height: 78rpx;
}

.content-input {
  height: 220rpx;
  padding: 20rpx 22rpx;
  line-height: 1.5;
}

.count-text {
  display: block;
  text-align: right;
  font-size: 21rpx;
  color: #87928f;
  margin-top: 8rpx;
}

.image-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.image-button {
  flex: none;
  min-width: 144rpx;
  min-height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #2d4a40;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 58rpx;
}

.image-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 16rpx;
}

.image-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 14rpx;
  overflow: hidden;
  background: #eef3f0;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  min-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(24, 35, 31, 0.78);
  color: #ffffff;
  font-size: 20rpx;
  line-height: 38rpx;
}

.submit-button {
  width: 100%;
  min-height: 88rpx;
  margin-top: 28rpx;
  border-radius: 16rpx;
  background: #2d4a40;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}
