/* pkgGear/pages/list/list.wxss */
@import "/styles/dark.wxss";

page {
  background-color: #f4f5f1;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: background-color 0.3s ease;
  box-sizing: border-box;
  align-items: stretch;
  padding: 0;
  width: 100%;
}

/* Dark Mode Container */
.container.dark {
  background-color: #0f1518;
}

/* Search Filter Wrapper */
.search-filter-wrapper {
  z-index: 100;
  background-color: #f4f5f1;
  padding: 0 0 8rpx;
}

.container.dark .search-filter-wrapper {
  background-color: #1a1a1a;
}

.compare-strip,
.selection-strip {
  margin: 12rpx 28rpx 0;
  padding: 16rpx 20rpx;
  border-radius: 10rpx;
  background: #ffffff;
  border: 1rpx solid rgba(58, 68, 62, 0.11);
  box-shadow: 0 6rpx 18rpx rgba(31, 42, 39, 0.045);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.selection-strip {
  border-left: 6rpx solid #60715e;
}

.container.dark .compare-strip,
.container.dark .selection-strip {
  background: #182028;
  border-color: rgba(229, 236, 231, 0.08);
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.22);
}

.compare-strip__copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.compare-strip__title {
  font-size: 24rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #1f2a27;
}

.container.dark .compare-strip__title {
  color: #dbe6ea;
}

.compare-strip__desc {
  font-size: 21rpx;
  line-height: 1.35;
  color: #68716b;
}

.container.dark .compare-strip__desc {
  color: #9fb0b8;
}

.compare-strip__actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.compare-strip__action {
  flex-shrink: 0;
  min-width: 96rpx;
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(79, 102, 84, 0.24);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #4f6654;
  font-size: 22rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.78);
}

.compare-strip__action--ghost {
  min-width: 78rpx;
  color: #8b4b48;
  border-color: rgba(139, 75, 72, 0.18);
  background: rgba(255, 255, 255, 0.54);
}

.selection-strip__action {
  flex-shrink: 0;
  min-width: 108rpx;
  min-height: 50rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  background: #26332d;
}

.container.dark .compare-strip__action {
  color: #dce9ed;
  border-color: rgba(159, 181, 189, 0.24);
  background: rgba(22, 31, 36, 0.42);
}

.container.dark .compare-strip__action--ghost {
  color: #d8aaa4;
  border-color: rgba(216, 170, 164, 0.2);
  background: rgba(22, 31, 36, 0.26);
}

.gear-list {
  flex: 1;
  height: 0;
  padding: 18rpx 28rpx;
  box-sizing: border-box;
  width: 100%;
}

.gear-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.gear-item {
  width: 48%;
  background-color: #ffffff;
  border: 1rpx solid rgba(58, 68, 62, 0.11);
  border-radius: 10rpx;
  margin-bottom: 16rpx;
  padding: 18rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 6rpx 18rpx rgba(31, 42, 39, 0.045);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  animation: fadeInUp 0.5s ease-out backwards;
}

.container.dark .gear-item {
  background-color: #182028;
  border-color: rgba(229, 236, 231, 0.08);
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.22);
}

.gear-item:active {
  transform: scale(0.98);
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* Staggered animation delays for first few items */
.gear-item:nth-child(1) { animation-delay: 0.05s; }
.gear-item:nth-child(2) { animation-delay: 0.1s; }
.gear-item:nth-child(3) { animation-delay: 0.15s; }
.gear-item:nth-child(4) { animation-delay: 0.2s; }
.gear-item:nth-child(5) { animation-delay: 0.25s; }
.gear-item:nth-child(6) { animation-delay: 0.3s; }

.gear-image {
  width: 100%;
  height: 184rpx;
  margin-bottom: 16rpx;
  background: #fdfdfd;
  border-radius: 8rpx;
}

.gear-info {
  width: 100%;
  text-align: left;
}

.gear-name {
  font-size: 27rpx;
  font-weight: 700;
  color: #1f2a27;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  height: 80rpx;
  line-height: 40rpx;
}

.container.dark .gear-name {
  color: #e0e0e0;
}

.gear-sub {
  font-size: 24rpx;
  color: #8a918a;
  display: block;
  margin-bottom: 14rpx;
}

.container.dark .gear-sub {
  color: #777;
}

.gear-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.gear-tag {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #4f6654;
  background: #eef2ed;
}

.container.dark .gear-tag {
  color: #bfd0d6;
  background: #33444c;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  flex: 1;
  min-height: 60vh;
  padding: 0 60rpx;
  box-sizing: border-box;
}

.empty-icon-placeholder {
  margin-bottom: 32rpx;
  width: 120rpx;
  height: 120rpx;
  background-color: #eef2ed;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-search-icon {
  position: relative;
  width: 44rpx;
  height: 44rpx;
  border: 5rpx solid #6c7654;
  border-radius: 50%;
  box-sizing: border-box;
}

.empty-search-icon::after {
  content: "";
  position: absolute;
  right: -16rpx;
  bottom: -10rpx;
  width: 22rpx;
  height: 5rpx;
  border-radius: 3rpx;
  background: #6c7654;
  transform: rotate(45deg);
}

.empty-title {
  font-size: 32rpx;
  color: #1f2a27;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.container.dark .empty-title {
  color: #e0e0e0;
}

.empty-sub {
  font-size: 26rpx;
  color: #8a918a;
  text-align: center;
  line-height: 1.5;
}

.empty-update-button {
  min-width: 176rpx;
  min-height: 72rpx;
  margin-top: 28rpx;
  padding: 0 30rpx;
  border-radius: 8rpx;
  background: #2d4a40;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 72rpx;
}

.empty-update-button::after {
  border: 0;
}

.container.dark .empty-sub {
  color: #777;
}

.container.dark .empty-update-button {
  background: #d8e2dd;
  color: #17211e;
}

.container.dark .empty-icon-placeholder {
  background-color: #2c2c2c;
}

.loading-more, .no-more {
  padding: 30rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  width: 100%;
}
