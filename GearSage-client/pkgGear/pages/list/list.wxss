/* pkgGear/pages/list/list.wxss */
@import "/styles/dark.wxss";

page {
  background-color: #f5f5f5;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: background-color 0.3s ease;
  box-sizing: border-box;
  align-items: stretch;
  padding: 0;
  width: 100%;
}

/* Dark Mode Container */
.container.dark {
  background-color: #1a1a1a;
}

/* Search Filter Wrapper */
.search-filter-wrapper {
  z-index: 100;
  background-color: #fff;
}

.container.dark .search-filter-wrapper {
  background-color: #1a1a1a;
}

.compare-strip {
  margin: 16rpx 20rpx 0;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #eef4f6 0%, #e6edf1 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.container.dark .compare-strip {
  background: linear-gradient(135deg, #24323a 0%, #202d34 100%);
}

.compare-strip__copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.compare-strip__title {
  font-size: 26rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #263841;
}

.container.dark .compare-strip__title {
  color: #dbe6ea;
}

.compare-strip__desc {
  font-size: 22rpx;
  line-height: 1.6;
  color: #60727a;
}

.container.dark .compare-strip__desc {
  color: #9fb0b8;
}

.compare-strip__action {
  flex-shrink: 0;
  min-width: 104rpx;
  min-height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(53, 87, 102, 0.2);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #365766;
  font-size: 24rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.78);
}

.container.dark .compare-strip__action {
  color: #dce9ed;
  border-color: rgba(159, 181, 189, 0.24);
  background: rgba(22, 31, 36, 0.42);
}

.gear-list {
  flex: 1;
  height: 0;
  padding: 20rpx;
  box-sizing: border-box;
  width: 100%;
}

.gear-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.gear-item {
  width: 48%;
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  animation: fadeInUp 0.5s ease-out backwards;
}

.container.dark .gear-item {
  background-color: #2c2c2c;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
}

.gear-item:active {
  transform: scale(0.98);
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* Staggered animation delays for first few items */
.gear-item:nth-child(1) { animation-delay: 0.05s; }
.gear-item:nth-child(2) { animation-delay: 0.1s; }
.gear-item:nth-child(3) { animation-delay: 0.15s; }
.gear-item:nth-child(4) { animation-delay: 0.2s; }
.gear-item:nth-child(5) { animation-delay: 0.25s; }
.gear-item:nth-child(6) { animation-delay: 0.3s; }

.gear-image {
  width: 100%;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.gear-info {
  width: 100%;
  text-align: left;
}

.gear-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  height: 80rpx;
  line-height: 40rpx;
}

.container.dark .gear-name {
  color: #e0e0e0;
}

.gear-sub {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 14rpx;
}

.container.dark .gear-sub {
  color: #777;
}

.gear-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.gear-tag {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #48616d;
  background: #edf3f5;
}

.container.dark .gear-tag {
  color: #bfd0d6;
  background: #33444c;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  flex: 1;
  min-height: 60vh;
  padding: 0 60rpx;
  box-sizing: border-box;
}

.empty-icon-placeholder {
  margin-bottom: 32rpx;
  width: 120rpx;
  height: 120rpx;
  background-color: #f5f7fa;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-icon-placeholder .iconfont {
  font-size: 64rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.container.dark .empty-title {
  color: #e0e0e0;
}

.empty-sub {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  line-height: 1.5;
}

.container.dark .empty-sub {
  color: #777;
}

.container.dark .empty-icon-placeholder {
  background-color: #2c2c2c;
}

.loading-more, .no-more {
  padding: 30rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  width: 100%;
}
