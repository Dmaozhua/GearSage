<custom-navbar title="{{compareTitle}}" show-back="{{true}}"></custom-navbar>

<view class="container {{isDarkMode ? 'dark' : ''}}" style="padding-top: {{navBarHeight}}px;">
  <block wx:if="{{!isLoading}}">
    <block wx:if="{{compareCards.length > 0}}">
      <view class="summary-card">
        <view class="summary-copy">
          <text class="summary-title">{{compareTitle}}</text>
          <text class="summary-desc">
            {{compareCards.length >= 2 ? '先看关键差异，再决定是否需要展开完整参数。' : '再补 1 个候选，就能更像真正的同类对比。'}}
          </text>
        </view>
        <view class="summary-actions">
          <view class="summary-action summary-action--ghost" bindtap="onClearCompareItems">清空</view>
          <view class="summary-action summary-action--primary" wx:if="{{compareCards.length >= 2}}" bindtap="onGoRecommend">去求推荐</view>
        </view>
      </view>

      <view class="warning-list" wx:if="{{compareWarnings.length > 0}}">
        <view class="warning-item" wx:for="{{compareWarnings}}" wx:key="*this">
          <view class="warning-dot"></view>
          <text class="warning-text">{{item}}</text>
        </view>
      </view>

      <scroll-view scroll-x class="candidate-scroll" show-scrollbar="{{false}}">
        <view class="candidate-list">
          <view class="candidate-card" wx:for="{{compareCards}}" wx:key="key">
            <image class="candidate-image" src="{{item.imageUrl || '/images/default-gear.png'}}" mode="aspectFit"></image>
            <text class="candidate-brand">{{item.brandName}}</text>
            <text class="candidate-master">{{item.masterLabelWithYear || item.masterLabel}}</text>
            <text class="candidate-variant">{{item.selectedVariant.__displayName}}</text>
            <view class="candidate-tags" wx:if="{{item.summaryTags.length > 0}}">
              <text class="candidate-group" wx:for="{{item.summaryTags}}" wx:key="*this">{{item}}</text>
            </view>
            <view class="candidate-actions">
              <view
                class="candidate-link"
                bindtap="onOpenDetail"
                data-id="{{item.masterId}}"
                data-type="{{item.gearType}}"
                data-variant-key="{{item.variantKey}}"
              >看详情</view>
              <view class="candidate-link candidate-link--danger" bindtap="onRemoveCompareItem" data-key="{{item.key}}">移除</view>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="compare-section" wx:if="{{compareInsights.length > 0}}">
        <view class="section-head">
          <text class="section-title">GearSage 提示</text>
          <text class="section-subtitle">先看核心参数、使用方向和技术差异。相同项默认收起，完整参数可展开核对。</text>
        </view>
        <view class="insight-list">
          <view class="insight-item" wx:for="{{compareInsights}}" wx:key="*this">
            <view class="insight-dot"></view>
            <text class="insight-text">{{item}}</text>
          </view>
        </view>
      </view>

      <view class="compare-section" wx:if="{{coreRows.length > 0}}">
        <view class="section-head">
          <text class="section-title">核心参数对比</text>
          <text class="section-subtitle">先看最常拿来排除候选的几项。灰掉的是差异不明显的字段。</text>
        </view>
        <scroll-view scroll-x class="table-scroll" show-scrollbar="{{false}}">
          <view class="compare-table">
            <view class="table-row table-head">
              <view class="table-cell table-cell--label">字段</view>
              <view class="table-cell table-cell--value" wx:for="{{compareCards}}" wx:key="key">
                <text class="head-name">{{item.selectedVariant.__displayName}}</text>
                <text class="head-sub">{{item.masterLabelWithYear || item.masterLabel}}</text>
              </view>
            </view>
            <view class="table-row {{row.isDifferent ? '' : 'table-row--same'}}" wx:for="{{coreRows}}" wx:key="key" wx:for-item="row">
              <view class="table-cell table-cell--label">{{row.label}}</view>
              <view class="table-cell table-cell--value" wx:for="{{row.values}}" wx:for-item="value">{{value || '-'}}</view>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="compare-section" wx:if="{{usageDirectionCards.length > 0}}">
        <view class="section-head">
          <text class="section-title">使用方向对比</text>
          <text class="section-subtitle">把 GearSage 整理出的推荐方向和搭配单独摊开看。</text>
        </view>
        <view class="usage-direction-list">
          <view class="usage-direction-card" wx:for="{{usageDirectionCards}}" wx:key="key">
            <view class="usage-direction-card__head">
              <text class="usage-direction-card__variant">{{item.variantLabel}}</text>
              <text class="usage-direction-card__master">{{item.masterLabel}}</text>
            </view>
            <view class="usage-direction-field" wx:if="{{item.direction}}">
              <text class="usage-direction-field__label">推荐方向</text>
              <text class="usage-direction-field__value">{{item.direction}}</text>
            </view>
            <view class="usage-direction-field" wx:if="{{item.pairing}}">
              <text class="usage-direction-field__label">推荐搭配</text>
              <text class="usage-direction-field__value">{{item.pairing}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="compare-section compare-section--specs" wx:if="{{specSections.length > 0}}">
        <view class="section-head section-head--inline">
          <view class="section-copy">
            <text class="section-title">完整规格对比</text>
            <text class="section-subtitle">默认只展示有差异的规格。需要时再展开全部。</text>
          </view>
          <view class="toggle-link" bindtap="toggleShowAllSpecs">{{showAllSpecs ? '只看差异' : '展开全部'}}</view>
        </view>

        <block wx:for="{{specSections}}" wx:key="title" wx:for-item="group">
          <view class="spec-group" wx:if="{{showAllSpecs || group.visibleDiffCount > 0}}">
            <text class="spec-group__title">{{group.title}}</text>
            <scroll-view scroll-x class="table-scroll" show-scrollbar="{{false}}">
              <view class="compare-table">
                <view class="table-row table-head">
                  <view class="table-cell table-cell--label">字段</view>
                  <view class="table-cell table-cell--value" wx:for="{{compareCards}}" wx:key="key">
                    <text class="head-name">{{item.selectedVariant.__displayName}}</text>
                    <text class="head-sub">{{item.masterLabelWithYear || item.masterLabel}}</text>
                  </view>
                </view>
                <block wx:for="{{group.rows}}" wx:key="key" wx:for-item="row">
                  <view class="table-row {{row.isDifferent ? '' : 'table-row--same'}}" wx:if="{{showAllSpecs || row.isDifferent}}">
                    <view class="table-cell table-cell--label">{{row.label}}</view>
                    <view class="table-cell table-cell--value" wx:for="{{row.values}}" wx:for-item="value">{{value || '-'}}</view>
                  </view>
                </block>
              </view>
            </scroll-view>
          </view>
        </block>
      </view>

      <view class="compare-section" wx:if="{{hasTechTerms}}">
        <view class="section-head">
          <text class="section-title">核心技术对比</text>
          <text class="section-subtitle">先看哪些技术是共同基础，哪些只出现在某个候选上。</text>
        </view>

        <view class="tech-compare-block" wx:if="{{commonTechTerms.length > 0}}">
          <text class="tech-compare-block__title">共同具备</text>
          <view class="tech-compare-tags">
            <view
              class="tech-compare-term {{tech.hasInfo ? 'tech-compare-term--interactive' : ''}}"
              wx:for="{{commonTechTerms}}"
              wx:key="key"
              wx:for-item="tech"
              catchtap="onCompareTechTermTap"
              data-key="{{tech.key}}"
            >
              {{tech.name}}
            </view>
          </view>
        </view>

        <view class="tech-compare-block" wx:if="{{differentTechGroups.length > 0}}">
          <text class="tech-compare-block__title">差异项</text>
          <view class="tech-diff-list">
            <view class="tech-diff-card" wx:for="{{differentTechGroups}}" wx:key="key" wx:for-item="group">
              <view class="tech-diff-card__head">
                <view class="tech-compare-tags tech-compare-tags--diff">
                  <view
                    class="tech-compare-term {{tech.hasInfo ? 'tech-compare-term--interactive' : ''}}"
                    wx:for="{{group.terms}}"
                    wx:key="key"
                    wx:for-item="tech"
                    catchtap="onCompareTechTermTap"
                    data-key="{{tech.key}}"
                  >
                    {{tech.name}}
                  </view>
                </view>
                <text class="tech-diff-count">{{group.holderCount}}/{{compareCards.length}}</text>
              </view>
              <view class="tech-holder-list">
                <view class="tech-holder" wx:for="{{group.holders}}" wx:key="key" wx:for-item="holder">
                  <text class="tech-holder__variant">{{holder.label}}</text>
                  <text class="tech-holder__master">{{holder.masterLabel}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <view class="tech-compare-panel" wx:if="{{activeCompareTechInfo}}">
          <text class="tech-compare-panel__title">{{activeCompareTechInfo.name}}</text>
          <text class="tech-compare-panel__simple" wx:if="{{activeCompareTechInfo.simpleText}}">{{activeCompareTechInfo.simpleText}}</text>
          <text class="tech-compare-panel__detail" wx:if="{{activeCompareTechInfo.detailText}}">{{activeCompareTechInfo.detailText}}</text>
        </view>
      </view>
    </block>

    <view class="empty-state" wx:else>
      <view class="empty-icon">对比</view>
      <text class="empty-title">对比池还是空的</text>
      <text class="empty-sub">先去装备详情里选好子型号，再把 2 到 3 个同类候选放进来。</text>
    </view>
  </block>

  <view class="loading-state" wx:else>
    <view class="loading-card skeleton-pulse"></view>
    <view class="loading-card skeleton-pulse"></view>
    <view class="loading-card skeleton-pulse"></view>
  </view>
</view>
