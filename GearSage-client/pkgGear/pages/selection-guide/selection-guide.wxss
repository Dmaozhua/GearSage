@import "/styles/dark.wxss";

page {
  min-height: 100vh;
  background: #f4f5f1;
}

.selection-page {
  min-height: 100vh;
  background: #f4f5f1;
  box-sizing: border-box;
}

.selection-page.dark {
  background: #0f1518;
}

.selection-inner {
  padding: 26rpx 28rpx 180rpx;
  box-sizing: border-box;
}

.selection-header {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.selection-title {
  font-size: 40rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #1f2a27;
}

.selection-subtitle {
  font-size: 25rpx;
  line-height: 1.55;
  color: #65716a;
}

.guide-panel,
.branch-card,
.result-toolbar,
.empty-box,
.loading-box {
  border-radius: 10rpx;
  background: #ffffff;
  border: 1rpx solid rgba(58, 68, 62, 0.11);
  box-shadow: 0 6rpx 18rpx rgba(31, 42, 39, 0.045);
}

.guide-panel {
  padding: 22rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.field-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.field-row--inline {
  min-width: 0;
}

.field-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.field-label {
  font-size: 24rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #26342f;
}

.field-input {
  height: 70rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  background: #f6f7f3;
  border: 1rpx solid rgba(67, 79, 72, 0.12);
  color: #263532;
  font-size: 26rpx;
  box-sizing: border-box;
}

.segmented,
.chip-row,
.toolbar-actions,
.branch-actions,
.empty-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.segment,
.chip,
.toolbar-action,
.branch-action,
.empty-action,
.branch-select {
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(79, 102, 84, 0.22);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #4f6654;
  background: #f6f7f3;
  font-size: 23rpx;
  line-height: 1.25;
  box-sizing: border-box;
}

.segment.active,
.chip.active,
.branch-card.selected .branch-select,
.toolbar-action--dark {
  background: #26332d;
  border-color: #26332d;
  color: #ffffff;
}

.generate-button {
  height: 74rpx;
  line-height: 74rpx;
  border-radius: 8rpx;
  background: #26332d;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}

.generate-button::after {
  border: 0;
}

.loading-box,
.empty-box,
.result-toolbar {
  margin-top: 22rpx;
  padding: 22rpx;
  box-sizing: border-box;
}

.empty-box {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.empty-title,
.result-title,
.branch-title,
.gear-name {
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #1f2a27;
}

.empty-desc,
.result-desc,
.branch-summary,
.gear-meta,
.evidence-empty {
  font-size: 23rpx;
  line-height: 1.45;
  color: #68716b;
}

.result-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.result-toolbar > view:first-child {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.toolbar-actions {
  flex-shrink: 0;
}

.branch-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 18rpx;
}

.branch-card {
  padding: 22rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.branch-card.selected {
  border-color: rgba(79, 102, 84, 0.38);
}

.branch-card__head,
.gear-line {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.branch-card__title-wrap,
.gear-line {
  min-width: 0;
  flex: 1;
  flex-direction: column;
}

.reason-list,
.tradeoff-list,
.evidence-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.reason-item,
.tradeoff-item,
.evidence-item {
  padding: 12rpx 14rpx;
  border-radius: 8rpx;
  background: #f7f8f4;
  color: #3a4741;
  font-size: 23rpx;
  line-height: 1.45;
}

.tradeoff-item {
  background: #f7f2ec;
  color: #75624b;
}

.evidence-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.evidence-item:active {
  background: #edf0e8;
}

.evidence-title {
  color: #26342f;
  font-size: 23rpx;
  line-height: 1.4;
  font-weight: 600;
}

.evidence-reason {
  color: #6f7a72;
  font-size: 21rpx;
  line-height: 1.35;
}

.selection-page.dark .selection-title,
.selection-page.dark .field-label,
.selection-page.dark .empty-title,
.selection-page.dark .result-title,
.selection-page.dark .branch-title,
.selection-page.dark .gear-name,
.selection-page.dark .evidence-title {
  color: #dbe6ea;
}

.selection-page.dark .selection-subtitle,
.selection-page.dark .empty-desc,
.selection-page.dark .result-desc,
.selection-page.dark .branch-summary,
.selection-page.dark .gear-meta,
.selection-page.dark .evidence-empty,
.selection-page.dark .evidence-reason {
  color: #9fb0b8;
}

.selection-page.dark .guide-panel,
.selection-page.dark .branch-card,
.selection-page.dark .result-toolbar,
.selection-page.dark .empty-box,
.selection-page.dark .loading-box {
  background: #182028;
  border-color: rgba(229, 236, 231, 0.08);
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.22);
}

.selection-page.dark .field-input,
.selection-page.dark .segment,
.selection-page.dark .chip,
.selection-page.dark .branch-action,
.selection-page.dark .toolbar-action,
.selection-page.dark .empty-action,
.selection-page.dark .branch-select,
.selection-page.dark .reason-item,
.selection-page.dark .evidence-item {
  background: #11191f;
  border-color: rgba(159, 181, 189, 0.18);
  color: #dce9ed;
}

.selection-page.dark .tradeoff-item {
  background: #211c17;
  color: #d8c1a3;
}

.selection-page.dark .evidence-item:active {
  background: #17232a;
}
