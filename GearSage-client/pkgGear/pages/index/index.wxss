/* pkgGear/pages/index/index.wxss */
@import "/styles/dark.wxss";

page {
  background: #f4f5f1;
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

.container {
  padding: 0 28rpx 400rpx;
  box-sizing: border-box;
  min-height: 100vh;
  transition: background-color 0.3s ease;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Header Section */
.header-section {
  position: relative;
  padding: 18rpx 0 24rpx 0;
  margin-bottom: 18rpx;
  overflow: hidden;
}

.header-content {
  position: relative;
  z-index: 2;
}

.header-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #1f2a27;
  margin-bottom: 12rpx;
}

.header-subtitle {
  display: block;
  font-size: 25rpx;
  color: #68716b;
  font-weight: 500;
  line-height: 1.55;
}

.bg-icon {
  position: absolute;
  top: 120rpx;
  left: 0;
  width: 100%;
  opacity: 0.035;
  z-index: 0;
}

/* Module Grid */
.module-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 0;
}

/* Module Item Card */
.module-item {
  position: relative;
  background: #ffffff;
  border-radius: 10rpx;
  padding: 18rpx 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(31, 42, 39, 0.045);
  border: 1rpx solid rgba(58, 68, 62, 0.11);
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  animation: fadeInUp 0.6s ease-out backwards;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 126rpx;
}

.module-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.module-item:nth-child(1) { animation-delay: 0.1s; }
.module-item:nth-child(2) { animation-delay: 0.2s; }
.module-item:nth-child(3) { animation-delay: 0.3s; }
.module-item:nth-child(4) { animation-delay: 0.4s; }
.module-item:nth-child(5) { animation-delay: 0.5s; }

/* Background Decoration */
.card-bg-decoration {
  display: none;
}

.module-item:hover .card-bg-decoration {
  transform: scale(1.2);
}

.content-wrapper {
  display: flex;
  align-items: center;
  z-index: 1;
  flex: 1;
}

/* Icons */
.icon-container {
  width: 74rpx;
  height: 74rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  position: relative;
  box-shadow: none;
  border: 1rpx solid rgba(58, 68, 62, 0.08);
}

.reel-icon-bg,
.rod-icon-bg,
.lure-icon-bg,
.line-icon-bg,
.hook-icon-bg { background: #f2f4ef; }

.module-icon {
  width: 48rpx;
  height: 48rpx;
}

/* Text */
.text-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.module-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2a27;
  margin-bottom: 6rpx;
}

.module-desc {
  font-size: 22rpx;
  color: #8a918a;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  font-weight: 600;
}

/* Arrow */
.arrow-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #f6f7f3;
  z-index: 1;
}

.arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid #8a918a;
  border-right: 3rpx solid #8a918a;
  transform: rotate(45deg);
  margin-right: 6rpx;
}

/* Dark Mode - Manual Class (.dark) */
.dark .header-title { color: #ecf0f1; text-shadow: 0 4rpx 8rpx rgba(0,0,0,0.5); }
.dark .header-subtitle { color: #bdc3c7; }
.dark .header-bg-icon { opacity: 0.05; filter: invert(1); }
.dark .module-item {
  background: rgba(44, 44, 44, 0.8);
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}
/* .dark .header-section {
  background: linear-gradient(135deg, #1a1a1a 0%, #2c3e50 100%);
} */
.dark .module-title { color: #ecf0f1; }
.dark .module-desc { color: #7f8c8d; }
.dark .arrow-icon { background: rgba(255,255,255,0.05); }
.dark .arrow { color: #7f8c8d; }
.dark .reel-icon-bg { background: linear-gradient(135deg, #4a3b69 0%, #2c4a69 100%); }
.dark .rod-icon-bg { background: linear-gradient(135deg, #4b5563 0%, #6b7280 100%); }
.dark .lure-icon-bg { background: linear-gradient(135deg, #7c5e10 0%, #9c4e2e 100%); }
.dark .line-icon-bg { background: linear-gradient(135deg, #334155 0%, #1d4ed8 100%); }
.dark .hook-icon-bg { background: linear-gradient(135deg, #334155 0%, #475569 100%); }
.dark .card-bg-decoration { background: radial-gradient(circle, rgba(255, 255, 255, 0.05) 0%, rgba(255,255,255,0) 70%); }

.container.dark {
  background: #0f1518;
}
