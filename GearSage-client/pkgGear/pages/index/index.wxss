/* pkgGear/pages/index/index.wxss */
@import "/styles/dark.wxss";

page {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

.container {
  padding: 0 40rpx 400rpx;
  box-sizing: border-box;
  min-height: 100vh;
  transition: background-color 0.3s ease;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Header Section */
.header-section {
  position: relative;
  padding: 10rpx 0 20rpx 0;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.header-content {
  position: relative;
  z-index: 2;
}

.header-title {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: #2c3e50;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 8rpx rgba(0,0,0,0.05);
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: #7f8c8d;
  letter-spacing: 1rpx;
  font-weight: 500;
}

.bg-icon {
  position: absolute;
  top: 120rpx;
  left: 0;
  width: 100%;
  opacity: 0.05;
  z-index: 0;
}

/* Module Grid */
.module-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: -60rpx;
}

/* Module Item Card */
.module-item {
  position: relative;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 24rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(31, 38, 135, 0.07);
  border: 1px solid rgba(255, 255, 255, 0.6);
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  animation: fadeInUp 0.6s ease-out backwards;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 160rpx;
}

.module-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.module-item:nth-child(1) { animation-delay: 0.1s; }
.module-item:nth-child(2) { animation-delay: 0.2s; }
.module-item:nth-child(3) { animation-delay: 0.3s; }
.module-item:nth-child(4) { animation-delay: 0.4s; }
.module-item:nth-child(5) { animation-delay: 0.5s; }

/* Background Decoration */
.card-bg-decoration {
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(64, 158, 255, 0.1) 0%, rgba(255,255,255,0) 70%);
  border-radius: 50%;
  z-index: 0;
  transition: all 0.5s ease;
}

.module-item:hover .card-bg-decoration {
  transform: scale(1.2);
}

.content-wrapper {
  display: flex;
  align-items: center;
  z-index: 1;
  flex: 1;
}

/* Icons */
.icon-container {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
  position: relative;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.08);
}

.reel-icon-bg { background: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%); }
.rod-icon-bg { background: linear-gradient(135deg, #cfd9df 0%, #e2ebf0 100%); }
.lure-icon-bg { background: linear-gradient(135deg, #f6d365 0%, #fda085 100%); }
.line-icon-bg { background: linear-gradient(135deg, #c7d2fe 0%, #93c5fd 100%); }
.hook-icon-bg { background: linear-gradient(135deg, #cbd5e1 0%, #94a3b8 100%); }

.module-icon {
  width: 60rpx;
  height: 60rpx;
}

/* Text */
.text-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.module-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 6rpx;
}

.module-desc {
  font-size: 24rpx;
  color: #95a5a6;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  font-weight: 600;
}

/* Arrow */
.arrow-icon {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0,0,0,0.03);
  z-index: 1;
}

.arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 4rpx solid #bdc3c7;
  border-right: 4rpx solid #bdc3c7;
  transform: rotate(45deg);
  margin-right: 6rpx;
}

/* Dark Mode - Manual Class (.dark) */
.dark .header-title { color: #ecf0f1; text-shadow: 0 4rpx 8rpx rgba(0,0,0,0.5); }
.dark .header-subtitle { color: #bdc3c7; }
.dark .header-bg-icon { opacity: 0.05; filter: invert(1); }
.dark .module-item {
  background: rgba(44, 44, 44, 0.8);
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}
/* .dark .header-section {
  background: linear-gradient(135deg, #1a1a1a 0%, #2c3e50 100%);
} */
.dark .module-title { color: #ecf0f1; }
.dark .module-desc { color: #7f8c8d; }
.dark .arrow-icon { background: rgba(255,255,255,0.05); }
.dark .arrow { color: #7f8c8d; }
.dark .reel-icon-bg { background: linear-gradient(135deg, #4a3b69 0%, #2c4a69 100%); }
.dark .rod-icon-bg { background: linear-gradient(135deg, #4b5563 0%, #6b7280 100%); }
.dark .lure-icon-bg { background: linear-gradient(135deg, #7c5e10 0%, #9c4e2e 100%); }
.dark .line-icon-bg { background: linear-gradient(135deg, #334155 0%, #1d4ed8 100%); }
.dark .hook-icon-bg { background: linear-gradient(135deg, #334155 0%, #475569 100%); }
.dark .card-bg-decoration { background: radial-gradient(circle, rgba(255, 255, 255, 0.05) 0%, rgba(255,255,255,0) 70%); }

.container.dark {
  background: linear-gradient(135deg, #1a1a1a 0%, #2c3e50 100%);
}
