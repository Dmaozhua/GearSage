/* pkgGear/pages/detail/detail.wxss */
@import "/styles/dark.wxss";

page {
  background-color: #f3f3f1;
  min-height: 100vh;
}

.container {
  display: block;
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
  transition: background-color 0.3s ease;
}

.container.dark {
  background-color: #181b1d;
}

.return-to-post-float {
  position: fixed;
  top: 68%;
  right: 18rpx;
  transform: translateY(-50%);
  z-index: 90;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(18, 34, 54, 0.9);
  box-shadow: 0 10rpx 28rpx rgba(17, 33, 51, 0.2);
  backdrop-filter: blur(12rpx);
}

.container.dark .return-to-post-float {
  background: rgba(33, 56, 84, 0.92);
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.3);
}

.return-to-post-float__label {
  font-size: 24rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #f6fbff;
  letter-spacing: 1rpx;
}

.detail-header,
.detail-section,
.related-section {
  background-color: #ffffff;
  border-radius: 22rpx;
  box-shadow: 0 6rpx 20rpx rgba(16, 27, 34, 0.05);
}

.container.dark .detail-header,
.container.dark .detail-section,
.container.dark .related-section {
  background-color: #262b2e;
  box-shadow: 0 6rpx 22rpx rgba(0, 0, 0, 0.22);
}

.detail-header {
  padding: 34rpx 30rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.detail-image {
  width: 100%;
  height: 540rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #fafbfb 0%, #f1f3f2 100%);
}

.container.dark .detail-image {
  background: linear-gradient(180deg, #30363a 0%, #262b2f 100%);
}

.detail-info {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.detail-brand {
  font-size: 24rpx;
  line-height: 1.5;
  color: #6f7f86;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.container.dark .detail-brand {
  color: #9aa7ac;
}

.detail-name {
  font-size: 40rpx;
  line-height: 1.32;
  font-weight: 800;
  color: #24343b;
}

.container.dark .detail-name {
  color: #edf2f4;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #4f666f;
  background: #edf3f4;
}

.container.dark .detail-tag {
  color: #c5d2d7;
  background: #344048;
}

.description-block {
  overflow: hidden;
}

.description-text {
  display: block;
  font-size: 25rpx;
  line-height: 1.8;
  color: #7e8e95;
}

.description-block--collapsed .description-text {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  max-height: 135rpx;
  overflow: hidden;
}

.description-block--variant {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #f7faf9;
  border: 1rpx solid #e4ebec;
}

.description-text--variant {
  font-size: 24rpx;
  line-height: 1.75;
  max-height: none;
}

.description-block--collapsed .description-text--variant {
  max-height: 126rpx;
}

.container.dark .description-text {
  color: #9ba7ac;
}

.container.dark .description-block--variant {
  background: #2b3236;
  border-color: #3b4449;
}

.detail-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 6rpx;
}

.detail-action {
  flex: 1;
  min-height: 78rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.detail-action--ghost {
  color: #355260;
  border: 1rpx solid rgba(53, 82, 96, 0.18);
  background: #f1f5f6;
}

.container.dark .detail-action--ghost {
  color: #dbe7eb;
  border-color: rgba(182, 202, 209, 0.2);
  background: #334048;
}

.detail-action--primary {
  color: #f4f8fb;
  background: linear-gradient(135deg, #254b67 0%, #355d7b 100%);
}

.container.dark .detail-action--primary {
  background: linear-gradient(135deg, #213646 0%, #2f4b60 100%);
}

.compare-note {
  font-size: 22rpx;
  line-height: 1.6;
  color: #6d7f86;
}

.container.dark .compare-note {
  color: #98a6ab;
}

.compare-entry-link {
  align-self: flex-start;
  margin-top: 4rpx;
  min-height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #355260;
  background: #edf3f4;
}

.container.dark .compare-entry-link {
  color: #d8e5e9;
  background: #344048;
}

.detail-section {
  margin-bottom: 24rpx;
  padding: 28rpx;
}

.section-head {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 800;
  color: #24343b;
}

.container.dark .section-title {
  color: #edf2f4;
}

.section-subtitle {
  font-size: 23rpx;
  line-height: 1.7;
  color: #7a8a91;
}

.container.dark .section-subtitle {
  color: #97a4a9;
}

.variant-float-bar {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  z-index: 88;
  padding: 14rpx 16rpx;
  border-radius: 0 0 20rpx 20rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 10rpx 30rpx rgba(16, 27, 34, 0.12);
  backdrop-filter: blur(18rpx);
  box-sizing: border-box;
}

.container.dark .variant-float-bar {
  background: rgba(38, 43, 46, 0.96);
  box-shadow: 0 12rpx 34rpx rgba(0, 0, 0, 0.32);
}

.variant-scroll {
  width: 100%;
  white-space: nowrap;
}

.variant-scroll--float {
  width: 100%;
}

.variant-list {
  display: inline-flex;
  gap: 16rpx;
  min-width: 100%;
}

.variant-pill {
  min-width: 250rpx;
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  background: #f1f4f3;
  border: 1rpx solid transparent;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.variant-pill--float {
  min-width: 220rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
}

.container.dark .variant-pill {
  background: #31383c;
}

.variant-pill.active {
  background: #e8f0f3;
  border-color: rgba(46, 79, 95, 0.22);
}

.container.dark .variant-pill.active {
  background: #37454d;
  border-color: rgba(181, 203, 209, 0.18);
}

.variant-pill__title {
  font-size: 27rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #27404a;
}

.container.dark .variant-pill__title {
  color: #ebf1f3;
}

.variant-pill__sub {
  font-size: 22rpx;
  line-height: 1.6;
  color: #72838a;
}

.container.dark .variant-pill__sub {
  color: #9eabb0;
}

.core-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.core-card {
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #f8faf9 0%, #f2f5f4 100%);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.container.dark .core-card {
  background: linear-gradient(180deg, #2d3438 0%, #273034 100%);
}

.core-card__label {
  font-size: 22rpx;
  line-height: 1.5;
  color: #73848a;
}

.container.dark .core-card__label {
  color: #99a7ac;
}

.core-card__value {
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #253841;
}

.container.dark .core-card__value {
  color: #eff4f6;
}

.tech-term-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tech-term {
  max-width: 100%;
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  background: #edf3f4;
  color: #4f666f;
  font-size: 22rpx;
  line-height: 1.4;
  box-sizing: border-box;
}

.tech-term--interactive {
  color: #2f6280;
  background: #e7f0f2;
}

.tech-term__name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tech-term-panel {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #f5f8f7;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tech-term-panel__title {
  font-size: 25rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #263a42;
}

.tech-term-panel__summary,
.tech-term-panel__official {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tech-term-panel__summary {
  padding: 16rpx;
  border-radius: 14rpx;
  background: #eaf2f1;
}

.tech-term-panel__label {
  align-self: flex-start;
  min-height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  font-size: 19rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #315c62;
  background: #d9e8e6;
}

.tech-term-panel__label--muted {
  color: #6f8086;
  background: transparent;
  padding: 0;
  border-radius: 0;
}

.tech-term-panel__simple,
.tech-term-panel__detail {
  display: block;
  word-break: break-word;
}

.tech-term-panel__simple {
  font-size: 25rpx;
  line-height: 1.65;
  color: #31515b;
  font-weight: 700;
}

.tech-term-panel__detail {
  font-size: 22rpx;
  line-height: 1.75;
  color: #667981;
}

.container.dark .tech-term {
  color: #c5d2d7;
  background: #344048;
}

.container.dark .tech-term--interactive {
  color: #d7edf5;
  background: #2f4b58;
}

.container.dark .tech-term-panel {
  background: #303639;
}

.container.dark .tech-term-panel__title {
  color: #edf2f4;
}

.container.dark .tech-term-panel__summary {
  background: #2b4549;
}

.container.dark .tech-term-panel__label {
  color: #d8eef0;
  background: #36575d;
}

.container.dark .tech-term-panel__label--muted {
  color: #9fb0b5;
  background: transparent;
}

.container.dark .tech-term-panel__simple {
  color: #d7e4e8;
}

.container.dark .tech-term-panel__detail {
  color: #aebbc0;
}

.spec-section + .spec-section {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #eef0ef;
}

.container.dark .spec-section + .spec-section {
  border-top-color: #353b3f;
}

.spec-section__title {
  display: block;
  margin-bottom: 6rpx;
  font-size: 25rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #35505b;
}

.container.dark .spec-section__title {
  color: #d7e4e8;
}

.spec-section__subtitle {
  display: block;
  margin-bottom: 14rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7d8c92;
}

.container.dark .spec-section__subtitle {
  color: #9ba7ac;
}

.spec-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.spec-row {
  min-height: 68rpx;
  border-radius: 14rpx;
  background: #f7f9f8;
  padding: 16rpx 18rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.container.dark .spec-row {
  background: #303639;
}

.spec-row__label {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
  color: #667981;
}

.container.dark .spec-row__label {
  color: #98a6ab;
}

.spec-row__value {
  max-width: 52%;
  text-align: right;
  font-size: 24rpx;
  line-height: 1.6;
  color: #253841;
  font-weight: 600;
}

.spec-row__value-wrap {
  position: relative;
  max-width: 52%;
  display: flex;
  justify-content: flex-end;
}

.container.dark .spec-row__value {
  color: #edf2f4;
}

.spec-row__value--link {
  color: #2f6280;
  text-decoration: underline;
}

.container.dark .spec-row__value--link {
  color: #9fc5d8;
}

.spec-row__value--term {
  max-width: 100%;
  color: #2f6280;
  text-decoration: underline;
}

.tech-tooltip {
  position: absolute;
  right: 0;
  top: 48rpx;
  z-index: 40;
  width: 520rpx;
  box-sizing: border-box;
  padding: 20rpx 22rpx;
  border-radius: 14rpx;
  background: #253841;
  color: #f2f6f7;
  font-size: 23rpx;
  line-height: 1.65;
  font-weight: 400;
  text-align: left;
  white-space: normal;
  box-shadow: 0 12rpx 30rpx rgba(20, 34, 42, 0.24);
}

.tech-tooltip::before {
  content: "";
  position: absolute;
  top: -10rpx;
  right: 28rpx;
  width: 20rpx;
  height: 20rpx;
  background: #253841;
  transform: rotate(45deg);
}

.container.dark .spec-row__value--term {
  color: #9fc5d8;
}

.container.dark .tech-tooltip {
  background: #e8eef0;
  color: #23343c;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.38);
}

.container.dark .tech-tooltip::before {
  background: #e8eef0;
}

.insight-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.insight-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx 18rpx;
  border-radius: 16rpx;
  background: #f6f8f7;
}

.container.dark .insight-item {
  background: #303639;
}

.insight-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #58727c;
  flex-shrink: 0;
}

.container.dark .insight-dot {
  background: #9db0b7;
}

.insight-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.75;
  color: #4a5f68;
}

.container.dark .insight-text {
  color: #d7e1e5;
}

.series-table-shell {
  width: 100%;
  overflow: hidden;
  border: 1rpx solid #e2e7e8;
  border-radius: 16rpx;
}

.container.dark .series-table-shell {
  border-color: #3d4448;
}

.series-x-scroll {
  width: 100%;
  white-space: nowrap;
}

.series-x-content {
  display: inline-flex;
  flex-direction: column;
}

.series-y-scroll {
  width: 100%;
}

.series-body-matrix {
  display: inline-flex;
  flex-direction: column;
  width: 100%;
}

.series-row {
  display: flex;
  width: 100%;
}

.series-cell {
  box-sizing: border-box;
  flex: 0 0 190rpx;
  width: 190rpx;
  height: 72rpx;
  padding: 18rpx 16rpx;
  border-bottom: 1rpx solid #e2e7e8;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #556a73;
  text-align: left;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  background: #ffffff;
}

.series-cell--first {
  flex-basis: 180rpx;
  width: 180rpx;
  color: #465e68;
  background: #fbfcfc;
  font-weight: 600;
}

.series-cell-link {
  color: #576b95;
  font-weight: 600;
}

.series-head-cell {
  font-weight: 700;
  background-color: #f3f6f6;
  color: #24343b;
  border-bottom: 2rpx solid #d8e0e2;
}

.series-row--active .series-cell,
.series-cell--active {
  background: #eef4f6;
}

.container.dark .series-cell {
  border-bottom-color: #3d4448;
  color: #d6e0e4;
  background: #262c30;
}

.container.dark .series-cell--first {
  color: #d6e0e4;
  background: #293034;
}

.container.dark .series-cell-link {
  color: #9ab0ff;
}

.container.dark .series-head-cell {
  background-color: #30373b;
  color: #edf2f4;
  border-bottom-color: #495156;
}

.container.dark .series-row--active .series-cell,
.container.dark .series-cell--active {
  background: #334148;
}

.expand-control {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0 8rpx;
  color: #576b95;
  font-size: 28rpx;
  border-top: 1rpx solid #edf0f1;
  margin-top: 12rpx;
}

.container.dark .expand-control {
  color: #9ab0ff;
  border-top-color: #3c4348;
}

.arrow {
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid #576b95;
  border-right: 2rpx solid #576b95;
  margin-left: 10rpx;
  transform: rotate(135deg);
  transition: transform 0.3s;
}

.container.dark .arrow {
  border-color: #9ab0ff;
}

.arrow.up {
  transform: rotate(-45deg);
}

.related-section {
  margin-top: 24rpx;
  padding: 30rpx;
}

.recommend-entry {
  margin-top: 24rpx;
  padding: 28rpx 26rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #244866 0%, #345f7f 100%);
  box-shadow: 0 12rpx 28rpx rgba(26, 52, 75, 0.16);
}

.container.dark .recommend-entry {
  background: linear-gradient(135deg, #23384a 0%, #2e4c62 100%);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.24);
}

.recommend-entry__copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.recommend-entry__title {
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #f3f8fd;
}

.recommend-entry__desc {
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(238, 246, 253, 0.9);
}

.recommend-entry__button {
  margin-top: 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 74rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  color: #234d6f;
  font-size: 28rpx;
  font-weight: 700;
}

.container.dark .recommend-entry__button {
  background: rgba(244, 248, 252, 0.94);
  color: #213d56;
}

.related-title {
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 800;
  color: #24343b;
  margin-bottom: 24rpx;
}

.container.dark .related-title {
  color: #edf2f4;
}

.related-tabs {
  display: flex;
  border-bottom: 1rpx solid #edf0f1;
  margin-bottom: 20rpx;
}

.container.dark .related-tabs {
  border-bottom-color: #3d4448;
}

.related-tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #667981;
  position: relative;
}

.container.dark .related-tab-item {
  color: #9aa7ac;
}

.related-tab-item.active {
  color: #2d667f;
  font-weight: 600;
}

.container.dark .related-tab-item.active {
  color: #a5cad9;
}

.active-bar {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 44rpx;
  height: 4rpx;
  background-color: #2d667f;
  border-radius: 2rpx;
}

.container.dark .active-bar {
  background-color: #a5cad9;
}

.related-content {
  min-height: 200rpx;
}

.related-post-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f3f4;
}

.container.dark .related-post-item {
  border-bottom-color: #394045;
}

.related-post-item:last-child {
  border-bottom: none;
}

.post-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  background-color: #f0f0f0;
}

.container.dark .post-cover {
  background-color: #333;
}

.post-cover--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a8f98;
  font-size: 22rpx;
  letter-spacing: 1rpx;
  background: linear-gradient(135deg, #f4f6f8 0%, #edf1f5 100%);
}

.container.dark .post-cover--placeholder {
  color: #7d8591;
  background: linear-gradient(135deg, #2c3138 0%, #242930 100%);
}

.post-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.post-title {
  font-size: 28rpx;
  color: #24343b;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.container.dark .post-title {
  color: #edf2f4;
}

.post-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #8f9ca1;
  margin-top: 10rpx;
}

.post-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.post-author {
  margin-right: 20rpx;
  max-width: 150rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-stats {
  display: flex;
  align-items: center;
}

.post-stats .iconfont {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: #999;
}

.empty-text {
  font-size: 26rpx;
  text-align: center;
}

.skeleton-pulse {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
}

.container.dark .skeleton-pulse {
  background: linear-gradient(90deg, #333 25%, #444 50%, #333 75%);
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.skeleton-image {
  width: 100%;
  height: 540rpx;
  border-radius: 18rpx;
}

.skeleton-text {
  height: 28rpx;
  border-radius: 4rpx;
  margin: 10rpx auto;
}

.skeleton-brand {
  width: 200rpx;
  height: 32rpx;
  margin: 0;
}

.skeleton-title {
  width: 420rpx;
  height: 48rpx;
  margin: 0;
}

.skeleton-desc {
  width: 90%;
  height: 80rpx;
  margin: 0;
}

.skeleton-section-title {
  width: 220rpx;
  height: 40rpx;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.skeleton-row {
  width: 100%;
  height: 60rpx;
  margin-bottom: 18rpx;
  border-radius: 8rpx;
}

.skeleton-related-title {
  width: 180rpx;
  height: 40rpx;
  margin-bottom: 24rpx;
}

.skeleton-tabs {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.skeleton-tab-item {
  width: 30%;
  height: 60rpx;
  border-radius: 30rpx;
}

.skeleton-post {
  display: flex;
  margin-bottom: 30rpx;
}

.skeleton-post-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.skeleton-post-title {
  width: 80%;
  height: 32rpx;
  margin: 0 0 20rpx 0;
}

.skeleton-post-meta {
  width: 40%;
  height: 24rpx;
  margin: 0;
}
