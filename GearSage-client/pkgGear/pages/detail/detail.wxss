/* pkgGear/pages/detail/detail.wxss */
@import "/styles/dark.wxss";

page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  display: block;
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
  transition: background-color 0.3s ease;
}

.container.dark {
  background-color: #1a1a1a;
}

.detail-header {
  background-color: #ffffff;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  animation: slideDown 0.5s ease-out;
}

.container.dark .detail-header {
  background-color: #2c2c2c;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.detail-image {
  width: 600rpx;
  height: 600rpx;
  margin-bottom: 30rpx;
}

.detail-info {
  text-align: center;
  width: 100%;
}

.detail-brand {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.container.dark .detail-brand {
  color: #aaa;
}

.detail-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.container.dark .detail-name {
  color: #e0e0e0;
}

.detail-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
  padding: 0 20rpx;
}

.container.dark .detail-desc {
  color: #999;
}

.detail-table-container {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  animation: fadeInUp 0.6s ease-out backwards;
  animation-delay: 0.2s;
}

.return-to-post-float {
  position: fixed;
  top: 68%;
  right: 18rpx;
  transform: translateY(-50%);
  z-index: 90;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(18, 34, 54, 0.9);
  box-shadow: 0 10rpx 28rpx rgba(17, 33, 51, 0.2);
  backdrop-filter: blur(12rpx);
}

.container.dark .return-to-post-float {
  background: rgba(33, 56, 84, 0.92);
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.3);
}

.return-to-post-float__label {
  font-size: 24rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #f6fbff;
  letter-spacing: 1rpx;
}

.container.dark .detail-table-container {
  background-color: #2c2c2c;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.table-header {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid #3cc51f;
  color: #333;
}

.container.dark .table-header {
  color: #e0e0e0;
  border-left-color: #2e8b1b;
}

.outer-scroll-x {
  width: 100%;
  white-space: nowrap; /* Ensure inline-block elements don't wrap */
}

.inner-scroll-y {
  max-height: 70vh; /* Vertical scroll height limit */
  transition: max-height 0.3s ease;
  width: max-content; /* Ensure it expands to fit table width */
  min-width: 100%;
}

.table {
  display: table;
  width: max-content;
  border-collapse: collapse;
}

.tr {
  display: table-row;
}

.th .td {
  position: sticky; /* Sticky header */
  top: 0;
  z-index: 10;
  font-weight: bold;
  background-color: #f9f9f9;
  color: #333;
  font-size: 26rpx;
  border-bottom: 2rpx solid #dcdcdc;
}

.expand-control {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  color: #576b95;
  font-size: 28rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 10rpx;
}

.arrow {
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid #576b95;
  border-right: 2rpx solid #576b95;
  margin-left: 10rpx;
  transform: rotate(135deg); /* Down */
  transition: transform 0.3s;
}

.arrow.up {
  transform: rotate(-45deg); /* Up */
}

.container.dark .expand-control {
  color: #7a9cff;
  border-top-color: #3a3a3a;
}

.container.dark .arrow {
  border-color: #7a9cff;
}

.container.dark .th .td {
  background-color: #333;
  color: #e0e0e0;
  border-bottom-color: #555;
}

.td {
  display: table-cell;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid #e0e0e0;
  font-size: 26rpx;
  color: #666;
  text-align: left;
  white-space: nowrap;
}

.container.dark .td {
  border-bottom-color: #444;
  color: #ccc;
}

/* Related Recommendations */
.related-section {
  margin-top: 30rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.recommend-entry {
  margin-top: 30rpx;
  padding: 28rpx 26rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #244866 0%, #345f7f 100%);
  box-shadow: 0 12rpx 28rpx rgba(26, 52, 75, 0.16);
}

.recommend-entry__copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.recommend-entry__title {
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #f3f8fd;
}

.recommend-entry__desc {
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(238, 246, 253, 0.9);
}

.recommend-entry__button {
  margin-top: 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 74rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  color: #234d6f;
  font-size: 28rpx;
  font-weight: 700;
}

.container.dark .related-section {
  background-color: #2c2c2c;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
}

.container.dark .recommend-entry {
  background: linear-gradient(135deg, #23384a 0%, #2e4c62 100%);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.24);
}

.container.dark .recommend-entry__button {
  background: rgba(244, 248, 252, 0.94);
  color: #213d56;
}

.related-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid #3cc51f;
}

.container.dark .related-title {
  color: #e0e0e0;
  border-left-color: #2e8b1b;
}

.related-tabs {
  display: flex;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 20rpx;
}

.container.dark .related-tabs {
  border-bottom-color: #444;
}

.related-tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.container.dark .related-tab-item {
  color: #aaa;
}

.related-tab-item.active {
  color: #3cc51f;
  font-weight: 500;
}

.container.dark .related-tab-item.active {
  color: #57d438;
}

.active-bar {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #3cc51f;
  border-radius: 2rpx;
}

.container.dark .active-bar {
  background-color: #57d438;
}

.related-content {
  min-height: 200rpx;
}

.related-post-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.container.dark .related-post-item {
  border-bottom-color: #3a3a3a;
}

.related-post-item:last-child {
  border-bottom: none;
}

.post-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  background-color: #f0f0f0;
}

.container.dark .post-cover {
  background-color: #333;
}

.post-cover--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a8f98;
  font-size: 22rpx;
  letter-spacing: 1rpx;
  background: linear-gradient(135deg, #f4f6f8 0%, #edf1f5 100%);
}

.container.dark .post-cover--placeholder {
  color: #7d8591;
  background: linear-gradient(135deg, #2c3138 0%, #242930 100%);
}

.post-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.post-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.container.dark .post-title {
  color: #e0e0e0;
}

.post-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.post-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.post-author {
  margin-right: 20rpx;
  max-width: 150rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-stats {
  display: flex;
  align-items: center;
}

.post-stats .iconfont {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: #999;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 26rpx;
  text-align: center;
}

.loading-state {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* Skeleton Styles */
.skeleton-pulse {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
}

.container.dark .skeleton-pulse {
  background: linear-gradient(90deg, #333 25%, #444 50%, #333 75%);
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.skeleton-image {
  width: 600rpx;
  height: 600rpx;
  margin-bottom: 30rpx;
  border-radius: 12rpx;
}

.skeleton-text {
  height: 28rpx;
  border-radius: 4rpx;
  margin: 10rpx auto;
}

.skeleton-brand {
  width: 200rpx;
  height: 32rpx;
  margin-bottom: 20rpx;
}

.skeleton-title {
  width: 400rpx;
  height: 48rpx;
  margin-bottom: 24rpx;
}

.skeleton-desc {
  width: 90%;
  height: 80rpx;
}

.skeleton-table-header {
  width: 200rpx;
  height: 40rpx;
  margin-bottom: 24rpx;
}

.skeleton-row {
  width: 100%;
  height: 60rpx;
  margin-bottom: 20rpx;
  border-radius: 8rpx;
}

.skeleton-related-title {
  width: 180rpx;
  height: 40rpx;
  margin-bottom: 24rpx;
}

.skeleton-tabs {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.skeleton-tab-item {
  width: 30%;
  height: 60rpx;
  border-radius: 30rpx;
}

.skeleton-post {
  display: flex;
  margin-bottom: 30rpx;
}

.skeleton-post-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.skeleton-post-title {
  width: 80%;
  height: 32rpx;
  margin: 0 0 20rpx 0;
}

.skeleton-post-meta {
  width: 40%;
  height: 24rpx;
  margin: 0;
}
