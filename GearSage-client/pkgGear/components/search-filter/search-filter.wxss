.search-filter-container {
  position: relative;
  width: 100%;
  background-color: #f4f5f1;
  z-index: 100;
  box-shadow: none;
  border-radius: 0;
}

.search-bar-wrapper {
  display: flex;
  align-items: center;
  padding: 18rpx 28rpx;
  background-color: #f4f5f1;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  height: 76rpx;
  background-color: #ffffff;
  border: 1rpx solid rgba(58, 68, 62, 0.13);
  border-radius: 8rpx;
  padding: 0 24rpx;
  margin-right: 20rpx;
  transition: all 0.3s ease;
}

.search-box:focus-within {
  background-color: #fff;
  box-shadow: 0 0 0 4rpx rgba(108, 118, 84, 0.1);
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #1f2a27;
}

.search-placeholder {
  color: #8a918a;
}

.clear-btn {
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(0, 0, 0, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  z-index: 10;
}

.clear-icon {
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1;
  padding-bottom: 2rpx;
  font-weight: bold;
}

.search-filter-container.dark .clear-btn {
  background-color: rgba(255, 255, 255, 0.3);
}

.search-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-left: 16rpx;
}

.search-icon {
  position: relative;
  width: 26rpx;
  height: 26rpx;
  border: 3rpx solid #62706a;
  border-radius: 50%;
  box-sizing: border-box;
}

.search-icon::after {
  content: "";
  position: absolute;
  right: -8rpx;
  bottom: -6rpx;
  width: 12rpx;
  height: 3rpx;
  border-radius: 2rpx;
  background: #62706a;
  transform: rotate(45deg);
}

.search-loading {
  font-size: 24rpx;
  color: #999;
}

.filter-toggle-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background-color: #ffffff;
  border: 1rpx solid rgba(58, 68, 62, 0.13);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #59655f;
  transition: all 0.2s ease;
}

.filter-toggle-btn.active {
  background-color: #eef2ed;
  color: #4f6654;
}

.filter-text {
  margin-right: 8rpx;
}

.filter-arrow {
  font-size: 20rpx;
  transition: transform 0.3s ease;
}

.filter-arrow.up {
  transform: rotate(180deg);
}

.suggestions-dropdown {
  position: absolute;
  top: 100%;
  left: 24rpx;
  right: 24rpx;
  background-color: #fff;
  border-radius: 0 0 10rpx 10rpx;
  box-shadow: 0 8rpx 22rpx rgba(31, 42, 39, 0.1);
  max-height: 400rpx;
  overflow-y: auto;
  z-index: 101;
  border-top: 1rpx solid #f0f0f0;
}

.suggestion-item {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #1f2a27;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background-color 0.2s;
}

.suggestion-item:active {
  background-color: #f9f9f9;
}

.suggestion-item:last-child {
  border-bottom: none;
}

.filter-popup {
  position: absolute;
  top: 100%;
  left: 0;
  width: 100%;
  background-color: #fff;
  box-shadow: 0 8rpx 22rpx rgba(31, 42, 39, 0.1);
  z-index: 100;
  border-top: 1rpx solid #f0f0f0;
  animation: slideDown 0.3s ease-out;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.filter-tabs {
  display: flex;
  border-bottom: 1rpx solid #eee;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.filter-tab.active {
  color: #4f6654;
  font-weight: 500;
}

.filter-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #6c7654;
  border-radius: 2rpx;
}

.filter-content {
  padding: 0;
}

.filter-scroll {
  max-height: 60vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.filter-group {
  margin-bottom: 32rpx;
}

.filter-group-label {
  display: block;
  font-size: 26rpx;
  color: #68716b;
  margin-bottom: 16rpx;
}

.filter-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-chip {
  padding: 12rpx 24rpx;
  background-color: #f6f7f3;
  border-radius: 6rpx;
  font-size: 26rpx;
  color: #1f2a27;
  transition: all 0.2s;
  border: 1rpx solid transparent;
}

.filter-chip.active {
  background-color: #eef2ed;
  color: #4f6654;
  border-color: rgba(79, 102, 84, 0.28);
}

.filter-actions {
  display: flex;
  
  padding: 24rpx;
  border-top: 1rpx solid #eee;
  gap: 24rpx;
}

.reset-btn, .apply-btn {
  flex: 1;
  font-size: 28rpx;
  height: 80rpx;
  border-radius: 8rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.reset-btn { background-color: #f6f7f3; color: #68716b; }
.apply-btn { background-color: #26332d; color: #fff; }

/* .wizard-mode { display: flex; justify-content: center; align-items: center; height: 200rpx; } */
.placeholder-text { color: #999; font-size: 28rpx; }
.filter-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0,0,0,0.5); z-index: 99; margin-top: 110rpx; }

/* Recommendation Tips */
.recommendation-bar {
  padding: 20rpx 24rpx;
  background-color: #f3efe2;
  border-bottom: 1rpx solid #ded2a9;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

.recommendation-label {
  font-size: 26rpx;
  color: #766f4f;
  font-weight: 500;
}

.recommendation-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  background-color: #fff;
  border: 1rpx solid rgba(118, 111, 79, 0.24);
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #766f4f;
}

.recommendation-item.disabled {
  color: #9aa5b1;
  border-color: #cfd8e3;
  background-color: #f4f7fa;
}

.recommendation-count {
  font-size: 22rpx;
  opacity: 0.72;
}

.recommendation-badge {
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(154, 165, 177, 0.16);
  font-size: 20rpx;
  color: #7b8794;
}

/* Dark Mode */
.search-filter-container.dark { background-color: #0f1518; }
.search-filter-container.dark .search-bar-wrapper { background-color: #0f1518; }
.search-filter-container.dark .search-box { background-color: #182028; border-color: rgba(229, 236, 231, 0.08); }
.search-filter-container.dark .search-input { color: #fff; }
.search-filter-container.dark .filter-toggle-btn { background-color: #182028; color: rgba(236, 244, 241, 0.68); border-color: rgba(229, 236, 231, 0.08); }
.search-filter-container.dark .suggestions-dropdown { background-color: #2c2c2c; border-top-color: #333; }
.search-filter-container.dark .suggestion-item { color: #ddd; border-bottom-color: #333; }
.search-filter-container.dark .suggestion-item:active { background-color: #333; }
.search-filter-container.dark .filter-popup { background-color: #1e1e1e; border-top-color: #333; }
.search-filter-container.dark .filter-tabs { border-bottom-color: #333; }
.search-filter-container.dark .filter-tab { color: #aaa; }
.search-filter-container.dark .filter-chip { background-color: #2c2c2c; color: #ddd; }
.search-filter-container.dark .filter-chip.active { background-color: rgba(154, 160, 131, 0.14); color: #b8bfa0; border-color: rgba(154, 160, 131, 0.28); }
.search-filter-container.dark .reset-btn { background-color: #2c2c2c; color: #aaa; }
.search-filter-container.dark .filter-actions { border-top-color: #333; }
.search-filter-container.dark .recommendation-bar { background-color: rgba(151, 117, 62, 0.16); border-bottom-color: rgba(199, 179, 125, 0.22); }
.search-filter-container.dark .recommendation-item { background-color: #2c2c2c; color: #e6a23c; border-color: #e6a23c; }
.search-filter-container.dark .recommendation-item.disabled { background-color: #2a2f36; color: #94a0ad; border-color: #46505c; }
.search-filter-container.dark .recommendation-badge { background: rgba(148, 160, 173, 0.16); color: #b3bdc8; }
