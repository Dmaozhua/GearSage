/* publish-wechatcontent 组件样式 */
@import "../../styles/dark.wxss";

/* 微信朋友圈风格内容区域 */
.wechat-content-section {
  background: transparent;
  margin: 0;
  padding: 0;
}

.title-input-container {
  padding: 20rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.wechat-title-input {
  width: 100%;
  font-size: 36rpx;
  font-weight: 500;
  color: #ffffff;
  background: transparent;
  border: none;
  outline: none;
  padding: 0;
  margin: 0;
  line-height: 1.4;
}

.wechat-title-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
  font-weight: 400;
}

.content-input-container {
  padding: 24rpx 0;
}

.wechat-content-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 30rpx;
  color: #ffffff;
  background: transparent;
  border: none;
  outline: none;
  padding: 0;
  margin: 0;
  line-height: 1.6;
  resize: none;
}

.wechat-content-textarea::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.wechat-content-textarea:focus {
  background: transparent;
}

.wechat-content-textarea.error {
  color: #ff6b6b;
}

/* 微信朋友圈风格图片区域 */
.wechat-image-container {
  margin-top: 24rpx;
  padding-bottom: 10rpx;
  border-bottom: none;
}

.wechat-image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.wechat-image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}

.wechat-image-item .wechat-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.wechat-image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.wechat-image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.3);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
  transition: all 0.3s ease;
}

.wechat-image-add:active {
  background: rgba(255, 255, 255, 0.1);
}

.add-icon {
  font-size: 60rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 300;
  line-height: 1;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 字符计数 */
.char-count {
  text-align: right;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 16rpx;
  font-weight: 400;
}

/* 错误提示 */
.error-text {
  color: #ff6b6b;
  font-size: 24rpx;
  margin-top: 8rpx;
  display: block;
}

/* 错误状态样式 */
.wechat-title-input.error,
.wechat-content-textarea.error {
  color: #ff6b6b;
}

/* 夜间模式样式 */
.dark {
    background-color: #12121200 !important;
    color: #e0e0e0 !important;
  }
.dark .wechat-content-section {
  background: transparent;
}

.dark .title-input-container {
  border-bottom-color: rgba(255, 255, 255, 0.05);
}

.dark .wechat-title-input {
  color: rgba(255, 255, 255, 0.95);
}

.dark .wechat-title-input::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.dark .wechat-content-textarea {
  color: rgba(255, 255, 255, 0.9);
}

.dark .wechat-content-textarea::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.dark .wechat-image-add {
  border-color: rgba(255, 255, 255, 0.2);
  background: rgba(13, 25, 48, 0.4);
}

.dark .wechat-image-add:active {
  background: rgba(13, 25, 48, 0.6);
}

.dark .add-icon {
  color: rgba(255, 255, 255, 0.5);
}

.dark .add-text {
  color: rgba(255, 255, 255, 0.5);
}

.dark .char-count {
  color: rgba(255, 255, 255, 0.4);
}
