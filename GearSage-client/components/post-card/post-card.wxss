/* components/post-card/post-card.wxss */
.post-card {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.post-header {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.username {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.post-time {
  font-size: 24rpx;
  color: #999;
}

.post-content {
  padding: 24rpx;
}

.equipment-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.equipment-info {
  margin-bottom: 24rpx;
}

.info-item {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.equipment-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.equipment-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.post-actions {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 48rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.iconfont {
  font-size: 32rpx;
  color: #666;
}

.icon-like-fill {
  color: #ff4757;
}

.action-text {
  font-size: 28rpx;
  color: #666;
}