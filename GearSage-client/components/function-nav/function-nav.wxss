/* components/function-nav/function-nav.wxss */
.function-nav-container {
  width: 100%;
  padding: 10rpx 0;
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  /* border-bottom: 1rpx solid rgba(220, 220, 230, 0.5); */
  background-color: rgba(245, 245, 250, 0.7);
  position: relative;
}

/* 标题样式 */
.nav-title {
  padding: 0 32rpx 24rpx;
  display: flex;
  align-items: center;
}

.title-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.2;
}

/* 横滑容器 */
.function-scroll {
  width: 100%;
  white-space: nowrap;
}

.function-list {
  display: flex;
  padding: 0 24rpx;
  gap: 24rpx;
  min-width: 100%;
}

/* 功能卡片 */
.function-card {
  position: relative;
  width: 160rpx;
  height: 180rpx;
  border-radius: 24rpx;
  overflow: hidden;
  flex-shrink: 0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  transform: scale(1);
}

.function-card:active {
  transform: scale(0.95);
}

.function-card.disabled {
  opacity: 0.5;
  pointer-events: none;
}

