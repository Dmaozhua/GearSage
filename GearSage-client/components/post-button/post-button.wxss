.button__text {
  position: absolute;
  inset: 0;
  display: block;
  animation: text-rotation 8s linear infinite;
}

.button__text > .text-node {
  position: absolute;
  top: 50%;
  left: 50%;
  transform-origin: 0 0; /* 关键修复：设置正确的变换原点 */
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}
@keyframes text-rotation {
  to {
    transform: rotate(360deg);
  }
}
.button__circle {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  overflow: hidden;
  background: transparent;
  color: #dc2743;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.button__icon {
  width: 65rpx;
  height: 65rpx;
  transition: transform 0.3s ease-in-out;
}

.button__icon--copy {
  position: absolute;
  transform: translate(-150%, 150%);
  transition: transform 0.3s ease-in-out 0.1s;
}

.button--hovered {
  background: radial-gradient(
      circle at center,
      transparent 47rpx,
      #000 34rpx
  );
  transform: scale(1.05);
  box-shadow: 0 12rpx 35rpx rgba(0, 0, 0, 0.6), 0 6rpx 15rpx rgba(0, 0, 0, 0.2);
}

.button--hovered .button__icon {
  color: #fff;
  transform: translate(150%, -150%);
}

.button--hovered .button__icon--copy {
  transform: translate(0, 0);
}

@keyframes text-rotation {
  to {
    transform: rotate(360deg);
  }
}
