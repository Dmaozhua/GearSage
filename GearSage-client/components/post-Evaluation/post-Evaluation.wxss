@import "../../styles/dark.wxss";

/* 步骤内容样式 */
.step-content {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 40rpx;
  border: 1px solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.step-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 40rpx;
  text-align: center;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

/* 表单项样式 */
.form-item {
  margin-bottom: 60rpx;
}

.sub-section {
  margin-bottom: 50rpx;
}

.sub-section:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.1);
}

.label-text {
  font-size: 30rpx;
  color: #ffffff;
}

.required {
  color: #ff6b6b;
  margin-left: 8rpx;
}

.optional {
  color: rgba(255, 255, 255, 0.5);
  margin-left: 12rpx;
  font-size: 24rpx;
  font-weight: normal;
}

.form-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 12rpx;
  line-height: 1.5;
}

.error-text {
  color: #ff6b6b;
  font-size: 24rpx;
  margin-top: 12rpx;
  display: block;
  animation: shake 0.4s ease-in-out;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-6rpx); }
  75% { transform: translateX(6rpx); }
}

/* Picker样式 */
.picker {
  width: 100%;
  padding: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  box-sizing: border-box;
  transition: all 0.3s ease;
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-text {
  flex: 1;
  min-width: 0;
  color: #ffffff;
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: flex;
  align-items: center;
}

.picker:active {
  background: rgba(255, 255, 255, 0.2);
}

.picker-arrow {
  margin-left: 20rpx;
  font-size: 38rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.65);
  transform: rotate(180deg);
}

/* 推荐理由样式 */
.recommend-list {
  background: transparent;
}

.recommend-item {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.recommend-input {
  flex: 1;
  padding: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  font-size: 28rpx;
  margin-right: 20rpx;
  transition: all 0.3s ease;
}

.recommend-input:focus {
  background: rgba(255, 255, 255, 0.15);
  border-color: rgba(255, 255, 255, 0.5);
}

.recommend-input.error {
  border-color: #ff6b6b;
  background: rgba(255, 107, 107, 0.1);
}

.recommend-actions {
  display: flex;
  gap: 16rpx;
}

.add-btn, .delete-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}

.add-btn {
  background: rgba(46, 204, 113, 0.8);
  color: #ffffff;
}

.delete-btn {
  background: rgba(231, 76, 60, 0.8);
  color: #ffffff;
}

/* 文本域样式 */
.problem-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.problem-textarea:focus {
  background: rgba(255, 255, 255, 0.15);
  border-color: rgba(255, 255, 255, 0.5);
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 12rpx;
}

/* 标签与抽屉样式
   =========================== */
.tags-section {
  margin-top: 24rpx;
  margin-bottom: 30rpx;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-chip {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #ffffff;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.custom-tag-input {
  width: 100%;
  padding: 24rpx;
  height: 80rpx; 
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-top: 24rpx;
  transition: all 0.3s ease;
}

.custom-tag-input:focus {
  background: rgba(255, 255, 255, 0.15);
  border-color: rgba(255, 255, 255, 0.5);
}

.add-tag-btn {
  padding: 12rpx 24rpx;
  background: rgba(46, 204, 113, 0.2);
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #2ecc71;
  border: 1px dashed rgba(46, 204, 113, 0.5);
  cursor: pointer;
  transition: all 0.3s;
}

.add-tag-btn:active {
  background: rgba(46, 204, 113, 0.3);
}

/* 抽屉样式 */
.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  backdrop-filter: blur(4rpx);
}

.drawer-content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100vw;
  max-width: 100vw;
  background: #2c3e50; /* Fallback */
  background: linear-gradient(180deg, #34495e 0%, #2c3e50 100%);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  max-height: 80vh;
  animation: slideUp 0.3s ease-out;
  overflow: hidden;
  box-sizing: border-box;
  padding-bottom: env(safe-area-inset-bottom);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.drawer-header {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  flex-shrink: 0;
}

.drawer-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.drawer-close {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.6);
  padding: 0 16rpx;
}

.drawer-body {
  flex: 1;
  min-height: 0;
  width: 100%;
  padding: 32rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.selector-option-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.selector-option {
  min-height: 92rpx;
  width: 100%;
  max-width: 100%;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  gap: 16rpx;
  overflow: hidden;
}

.selector-option-label {
  flex: 1;
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selector-option.selected {
  border-color: rgba(97, 176, 255, 0.55);
  background: rgba(28, 107, 209, 0.2);
}

.selector-option-check {
  color: #2ecc71;
  font-size: 32rpx;
  font-weight: 700;
}

.tag-group {
  margin-bottom: 40rpx;
}

.group-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 24rpx;
  font-weight: 500;
}

.group-limit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-left: 12rpx;
  font-weight: normal;
}

.group-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tag-option {
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  border: 1px solid transparent;
  transition: all 0.2s;
}

.tag-option.selected {
  background: rgba(46, 204, 113, 0.2);
  color: #2ecc71;
  border-color: rgba(46, 204, 113, 0.5);
  font-weight: 500;
}

.drawer-footer {
  padding: 32rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.btn-confirm {
  background: #2ecc71;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.btn-confirm:active {
  background: #27ae60;
}

/* ===========================
   夜间模式 (Dark Mode) 优化
   =========================== */

/* 容器背景调整为深色玻璃拟态 - 统一蓝调 */
.dark {
    background-color: #12121200 !important;
    color: #e0e0e0 !important;
  }
.dark .step-content {
  background: rgba(13, 25, 48, 0.6);
  border-color: rgba(255, 255, 255, 0.05);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

/* 文本颜色微调，避免纯白过亮 */
.dark .step-title,
.dark .form-label,
.dark .label-text {
  color: rgba(255, 255, 255, 0.9);
}

.dark .form-tip,
.dark .optional {
  color: rgba(255, 255, 255, 0.5);
}

.dark .selector-option {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(255, 255, 255, 0.08);
}
