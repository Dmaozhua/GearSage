/* components/post-mode/post-mode.wxss */
.carousel {
  position: relative;
  width: 100%;
  height: 800rpx; /* Increased height */
  perspective: 1500rpx;
  transform-style: preserve-3d;
  margin: 0 auto;
  overflow: visible;
  display: flex;
  justify-content: center;
  align-items: center;
}

.card-container {
  position: absolute;
  width: 520rpx; /* Fixed width */
  height: 680rpx; /* Fixed height */
  transform-origin: center;
  transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1), 
              filter 0.5s ease-out, 
              opacity 0.5s ease-out;
  /* Ensure clicks are captured correctly */
  pointer-events: none; 
}

/* Allow pointer events on the active card and visible ones */
.card-container[style*="opacity: 1"] {
  pointer-events: auto;
}

.card {
  width: 100%;
  height: 100%;
  border-radius: 32rpx;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  position: relative;
  overflow: hidden;
  box-shadow: 0 20rpx 50rpx rgba(0,0,0,0.3);
  transition: all 0.3s ease;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.card--active {
  box-shadow: 0 30rpx 60rpx rgba(0,0,0,0.4), 0 0 0 2rpx rgba(255, 255, 255, 0.2);
}

.card-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.8) 100%);
  z-index: 1;
}

.card-content-wrapper {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 40rpx;
  box-sizing: border-box;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 8rpx rgba(0,0,0,0.3);
  letter-spacing: 2rpx;
  text-align: center;
}

.card-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  line-height: 1.5;
  margin-bottom: 40rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-btn {
  padding: 16rpx 48rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 40rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  transition: all 0.3s ease;
}

.card--active .card-btn {
  background: #ffffff;
  color: #333;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.2);
}

.nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  border: 1px solid rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 48rpx;
  z-index: 10;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.2);
}

.nav:active {
  transform: translateY(-50%) scale(0.95);
  background: rgba(255, 255, 255, 0.25);
}

.nav.left {
  left: -360rpx;
}

.nav.right {
  right: -360rpx;
}
