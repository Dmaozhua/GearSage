/* components/post-mode/post-mode.wxss */
.carousel {
  position: relative;
  width: 100%;
  height: 720rpx;
  perspective: 1200rpx;
  transform-style: preserve-3d;
  margin: 0 auto;
  overflow: visible;
  display: flex;
  justify-content: center;
  align-items: center;
}

.card-container {
  position: absolute;
  width: 500rpx;
  height: 620rpx;
  transform-origin: center;
  transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1), 
              filter 0.5s ease-out, 
              opacity 0.5s ease-out;
  /* Ensure clicks are captured correctly */
  pointer-events: none; 
}

/* Allow pointer events on the active card and visible ones */
.card-container[style*="opacity: 1"] {
  pointer-events: auto;
}

.card {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
  background-color: #26332d;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  position: relative;
  overflow: hidden;
  box-shadow: 0 10rpx 28rpx rgba(31, 42, 39, 0.12);
  transition: all 0.3s ease;
  border: 1rpx solid rgba(58, 68, 62, 0.14);
}

.card--active {
  box-shadow: 0 12rpx 32rpx rgba(31, 42, 39, 0.18), 0 0 0 2rpx rgba(108, 118, 84, 0.18);
}

.card-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background:
    linear-gradient(180deg, rgba(31, 42, 39, 0.44) 0%, rgba(31, 42, 39, 0.68) 54%, rgba(20, 28, 25, 0.94) 100%),
    linear-gradient(135deg, rgba(79, 102, 84, 0.34), rgba(118, 111, 79, 0.2));
  z-index: 1;
}

.card-content-wrapper {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 34rpx;
  box-sizing: border-box;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 14rpx;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.28);
  text-align: center;
}

.card-desc {
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.82);
  text-align: center;
  line-height: 1.5;
  margin-bottom: 30rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-btn {
  padding: 14rpx 40rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 8rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.card--active .card-btn {
  background: #f4f5f1;
  color: #1f2a27;
  box-shadow: 0 6rpx 18rpx rgba(31, 42, 39, 0.16);
}

.nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 72rpx;
  height: 72rpx;
  border-radius: 8rpx;
  background: rgba(31, 42, 39, 0.64);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 44rpx;
  z-index: 10;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 8rpx 22rpx rgba(31, 42, 39, 0.18);
}

.nav:active {
  transform: translateY(-50%) scale(0.95);
  background: rgba(31, 42, 39, 0.78);
}

.nav.left {
  left: -360rpx;
}

.nav.right {
  right: -360rpx;
}
