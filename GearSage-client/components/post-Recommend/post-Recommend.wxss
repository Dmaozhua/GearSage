/* components/post-Recommend/post-Recommend.wxss */
@import "../../styles/dark.wxss";

.post-recommend-container {
  padding: 0 10rpx 180rpx; /* Increased bottom padding for fixed buttons */
  background: transparent;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 步骤器样式 */
.stepper-container {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  padding: 40rpx 30rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.stepper-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  cursor: pointer;
  z-index: 1;
}

.stepper-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.stepper-item.active .stepper-circle {
  background: #ffffff;
  border-color: #ffffff;
  transform: scale(1.1);
  box-shadow: 0 0 20rpx rgba(255, 255, 255, 0.4);
}

.stepper-item.completed .stepper-circle {
  background: rgba(46, 204, 113, 0.2);
  border-color: #2ecc71;
  color: #2ecc71;
}

.stepper-number {
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.8);
}

.stepper-item.active .stepper-number {
  color: #333;
}

.stepper-check {
  font-size: 32rpx;
  font-weight: bold;
  color: #2ecc71;
}

.stepper-title {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
  transition: all 0.3s ease;
}

.stepper-item.active .stepper-title {
  color: #ffffff;
  font-weight: 700;
}

.stepper-item.completed .stepper-title {
  color: #2ecc71;
}

.stepper-line {
  width: 80rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.15);
  margin: 0 20rpx;
  border-radius: 2rpx;
  position: relative;
  overflow: hidden;
  margin-bottom: 36rpx; /* Align with circle center */
}

.stepper-line::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: #2ecc71;
  transition: left 0.6s ease;
}

.stepper-line.active::before {
  left: 0;
}

/* 步骤内容样式 */
.step-content {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 40rpx;
  border: 1px solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.step-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 40rpx;
  text-align: center;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

/* 表单项样式 */
.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.1);
}

.label-text {
  font-size: 30rpx;
  color: #ffffff;
}

.required {
  color: #ff6b6b;
  margin-left: 8rpx;
}

.optional {
  color: rgba(255, 255, 255, 0.5);
  margin-left: 12rpx;
  font-size: 24rpx;
  font-weight: normal;
}

.form-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 12rpx;
  line-height: 1.5;
}

.error-text {
  color: #ff6b6b;
  font-size: 24rpx;
  margin-top: 12rpx;
  display: block;
  animation: shake 0.4s ease-in-out;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-6rpx); }
  75% { transform: translateX(6rpx); }
}

/* Picker 样式 */
.picker {
  width: 100%;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.picker:active {
  background: rgba(255, 255, 255, 0.15);
  border-color: rgba(255, 255, 255, 0.4);
}

.picker-text {
  color: #ffffff;
  font-size: 30rpx;
}

.picker-arrow {
  font-size: 40rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.65);
  transform: rotate(90deg);
}

.gear-model-block {
  margin-top: 20rpx;
}

.gear-model-label {
  margin-bottom: 12rpx;
}

.gear-model-input-wrap {
  position: relative;
}

.gear-model-input {
  width: 100%;
  height: 80rpx; 
  padding: 24rpx 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  box-sizing: border-box;
  color: #ffffff;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.1);
}

.gear-model-dropdown {
  position: absolute;
  top: calc(100% + 8rpx);
  left: 0;
  right: 0;
  max-height: 320rpx;
  overflow-y: auto;
  z-index: 20;
  border-radius: 16rpx;
  border: 1px solid rgba(255, 255, 255, 0.2);
  background: rgba(28, 35, 52, 0.95);
}

.gear-model-option,
.gear-model-empty {
  padding: 18rpx 24rpx;
  font-size: 26rpx;
  color: #ffffff;
}

.gear-model-option:active {
  background: rgba(255, 255, 255, 0.12);
}

.gear-model-empty {
  color: rgba(255, 255, 255, 0.7);
}

/* 环境选择器样式 */
.custom-scene-input {
  width: 100%;
  height: 80rpx;
  padding: 24rpx 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  box-sizing: border-box;
  color: #ffffff;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.1);
}

.env-control-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.env-control {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 20rpx;
  cursor: pointer;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  width: calc((100% - 40rpx) / 3);
  box-sizing: border-box;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  transition: all 0.3s ease;
}

.env-control:active {
  background: rgba(255, 255, 255, 0.1);
}

.env-control.checked {
  background: rgba(255, 255, 255, 0.9);
  color: #333;
  border-color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.env-control__indicator {
  margin-right: 16rpx;
  height: 32rpx;
  width: 32rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  flex-shrink: 0;
  position: relative;
}

.env-control.checked .env-control__indicator {
  background: #333;
  border-color: #333;
}

.env-control.checked .env-control__indicator:after {
  content: '';
  position: absolute;
  top: 45%;
  left: 50%;
  width: 10rpx;
  height: 18rpx;
  border: solid #ffffff;
  border-width: 0 4rpx 4rpx 0;
  transform: translate(-50%, -50%) rotate(45deg);
}

.env-control.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.custom-scene-container {
  margin-top: 20rpx;
}

.custom-scene-tip {
  margin-top: 12rpx;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.tag-chip {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #ffffff;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.tag-option-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-option {
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
  border: 1px solid rgba(255, 255, 255, 0.15);
  transition: all 0.3s ease;
}

.tag-option.selected {
  background: rgba(46, 204, 113, 0.2);
  color: #2ecc71;
  border-color: rgba(46, 204, 113, 0.5);
  font-weight: 500;
}

.selected-count {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
}

.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  backdrop-filter: blur(4rpx);
}

.drawer-content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100vw;
  max-width: 100vw;
  max-height: 76vh;
  background: linear-gradient(180deg, #34495e 0%, #2c3e50 100%);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.drawer-header {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  flex-shrink: 0;
}

.drawer-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.drawer-close {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.65);
  padding: 0 16rpx;
}

.drawer-body {
  flex: 1;
  min-height: 0;
  width: 100%;
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.selector-option-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.selector-option {
  min-height: 92rpx;
  width: 100%;
  max-width: 100%;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.selector-option-label {
  flex: 1;
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selector-option.selected {
  background: rgba(46, 204, 113, 0.2);
  border-color: rgba(46, 204, 113, 0.45);
  color: #ffffff;
}

.selector-option-check {
  color: #2ecc71;
  font-size: 32rpx;
  font-weight: 700;
}

/* 推荐理由样式 */
.recommend-list {
  background: transparent;
}

.recommend-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.recommend-input {
  flex: 1;
  padding: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  font-size: 28rpx;
  margin-right: 20rpx;
  transition: all 0.3s ease;
}

.recommend-input:focus {
  background: rgba(255, 255, 255, 0.15);
  border-color: rgba(255, 255, 255, 0.5);
}

.recommend-input.error {
  border-color: #ff6b6b;
  background: rgba(255, 107, 107, 0.1);
}

.recommend-actions {
  display: flex;
  gap: 16rpx;
}

.add-btn, .delete-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}

.add-btn {
  background: rgba(46, 204, 113, 0.8);
  color: #ffffff;
}

.delete-btn {
  background: rgba(231, 76, 60, 0.8);
  color: #ffffff;
}

/* 文本域样式 */
.problem-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.problem-textarea:focus {
  background: rgba(255, 255, 255, 0.15);
  border-color: rgba(255, 255, 255, 0.5);
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 12rpx;
}

/* 底部按钮 */
.bottom-buttons {
  position: fixed;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100vw;
  box-sizing: border-box;
  background: rgba(30, 30, 30, 0.85); /* Slightly opaque for legibility */
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  padding: 30rpx 80rpx calc(30rpx + env(safe-area-inset-bottom)); 
  display: flex;
  gap: 30rpx;
  z-index: 100;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
  text-align: center;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.15);
  color: #ffffff;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.btn-primary {
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(58, 107, 139, 0.3);
}

.btn-success {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(46, 204, 113, 0.3);
}

.btn:active {
  transform: scale(0.98);
}

/* 响应式调整 */
@media (max-width: 360px) {
  .env-control {
    font-size: 24rpx;
  }
}

/* ===========================
   夜间模式 (Dark Mode) 优化
   =========================== */

/* 容器背景调整为深色玻璃拟态 - 统一蓝调 */
.dark {
    background-color: #12121200 !important;
    color: #e0e0e0 !important;
  }
.dark .stepper-container,
.dark .step-content {
  background: rgba(13, 25, 48, 0.6);
  border-color: rgba(255, 255, 255, 0.05);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

/* 步骤器圆圈 */
.dark .stepper-circle {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.1);
}

.dark .stepper-item.active .stepper-circle {
  background: rgba(255, 255, 255, 0.9);
  border-color: rgba(255, 255, 255, 0.9);
  box-shadow: 0 0 20rpx rgba(255, 255, 255, 0.2);
}

.dark .stepper-item.active .stepper-number {
  color: #000;
}

/* 输入框和文本域背景变深 - 统一蓝调 */
.dark .recommend-input,
.dark .problem-textarea {
  background: rgba(13, 25, 48, 0.4);
  border-color: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.9);
}

.dark .gear-model-input,
.dark .gear-model-dropdown {
  background: rgba(13, 25, 48, 0.75);
  border-color: rgba(255, 255, 255, 0.1);
}

.dark .custom-scene-input,
.dark .picker,
.dark .tag-option {
  background: rgba(13, 25, 48, 0.4);
  border-color: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.9);
}

.dark .picker-arrow {
  color: rgba(255, 255, 255, 0.65);
}

.dark .recommend-input:focus,
.dark .problem-textarea:focus {
  background: rgba(13, 25, 48, 0.6);
  border-color: rgba(255, 255, 255, 0.3);
}

/* 文本颜色微调 */
.dark .step-title,
.dark .form-label,
.dark .label-text {
  color: rgba(255, 255, 255, 0.9);
}

.dark .form-tip,
.dark .char-count {
  color: rgba(255, 255, 255, 0.5);
}

.dark .selected-count {
  color: rgba(255, 255, 255, 0.55);
}

.dark .drawer-content {
  background: linear-gradient(180deg, #16243a 0%, #0f1d31 100%);
}

.dark .selector-option {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(255, 255, 255, 0.08);
}

/* 底部按钮栏背景更深 - 统一蓝调 */
.dark .bottom-buttons {
  background: rgba(10, 15, 30, 0.9);
  border-top-color: rgba(255, 255, 255, 0.05);
}

.dark .btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.8);
}
