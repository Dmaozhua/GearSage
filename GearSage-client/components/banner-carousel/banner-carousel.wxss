/* components/banner-carousel/banner-carousel.wxss */
.banner-carousel-container {
  position: relative;
  width: 100%;
  overflow: hidden;
}

.banner-swiper {
  width: 100%;
  border-radius: 0;
}

.banner-item {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.banner-item:active .banner-image {
  transform: scale(1.02);
}

/* 渐变遮罩 */
.banner-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0.1) 0%,
    rgba(0, 0, 0, 0.2) 50%,
    rgba(0, 0, 0, 0.4) 100%
  );
  pointer-events: none;
}

/* 内容区域 */
.banner-content {
  position: absolute;
  bottom: 60rpx;
  left: 40rpx;
  right: 40rpx;
  z-index: 2;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.banner-title {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 16rpx;
  text-overflow: ellipsis;
  overflow: hidden;
  white-space: nowrap;
}

.banner-subtitle {
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.4;
  opacity: 0.9;
  text-overflow: ellipsis;
  overflow: hidden;
  white-space: nowrap;
}

/* 自定义指示器 */
.custom-dots {
  position: absolute;
  bottom: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 3;
}

.custom-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.4);
  transition: all 0.3s ease;
  cursor: pointer;
}

.custom-dot.active {
  width: 32rpx;
  border-radius: 8rpx;
  background-color: rgba(255, 255, 255, 0.9);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* 加载状态 */
.banner-loading {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
  z-index: 1;
}

/* 错误状态 */
.banner-error {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  color: #999;
  font-size: 28rpx;
}

/* 响应式适配 */
@media screen and (max-width: 750rpx) {
  .banner-content {
    bottom: 40rpx;
    left: 30rpx;
    right: 30rpx;
  }
  
  .banner-title {
    font-size: 40rpx;
  }
  
  .banner-subtitle {
    font-size: 26rpx;
  }
  
  .custom-dots {
    bottom: 20rpx;
    gap: 12rpx;
  }
  
  .custom-dot {
    width: 12rpx;
    height: 12rpx;
  }
  
  .custom-dot.active {
    width: 24rpx;
  }
}

/* 深色模式适配 */
.banner-carousel-container.dark-mode .banner-mask {
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0.2) 0%,
    rgba(0, 0, 0, 0.4) 50%,
    rgba(0, 0, 0, 0.6) 100%
  );
}

.banner-carousel-container.dark-mode .banner-error {
  background-color: #2a2a2a;
  color: #666;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.banner-content {
  animation: fadeIn 0.6s ease-out;
}

/* 高分辨率屏幕优化 */
@media screen and (min-resolution: 2dppx) {
  .banner-image {
    image-rendering: -webkit-optimize-contrast;
  }
}