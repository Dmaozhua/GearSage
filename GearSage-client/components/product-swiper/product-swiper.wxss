/* components/product-swiper/product-swiper.wxss */
.product-swiper-container {
  width: 100%;
}

.product-swiper {
  position: relative;
  width: 100%;
  touch-action: pan-y;
  background: #000; /* 避免裁切时露底色 */
}

.swiper-wrapper {
  display: flex;
  width: 100%;
  height: 100%;
}

.swiper-slide {
  position: relative;
  flex: 0 0 100%;
  height: 100%;
  overflow: hidden; /* 保证裁切干净 */
}

.swiper-zoom-container {
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 100%;
  display: block;
  background: #111;
}

/* 指示点 */
.swiper-indicators {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
  z-index: 5;
}

.indicator {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.4);
}

.indicator.active {
  width: 24rpx;
  background: #fff;
}

/* 计数器 */
.image-counter {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  color: #fff;
  background: rgba(0,0,0,0.4);
  border-radius: 999rpx;
  z-index: 5;
}

/* 控制按钮（可选） */
.swiper-controls {
  position: absolute;
  top: 50%;
  left: 0; right: 0;
  display: flex;
  justify-content: space-between;
  transform: translateY(-50%);
  padding: 0 12rpx;
  z-index: 6;
}

.swiper-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 999rpx;
  background: rgba(0,0,0,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-icon {
  font-size: 40rpx;
  color: #fff;
  line-height: 1;
}

/* 水印不影响手势 */
.watermark {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  color: rgba(255,255,255,0.8);
  font-size: 22rpx;
  pointer-events: none;
  z-index: 4;
}

/* 防下载蒙层 */
.download-guard {
  position: absolute;
  inset: 0;
  z-index: 10;
  background: transparent;
}
