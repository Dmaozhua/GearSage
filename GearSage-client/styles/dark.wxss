/* 主页夜间模式样式 */
.dark-mode.container {
  background: linear-gradient(to bottom, #1a1a1a, #2d2d2d);
}

/* 筛选选项夜间模式 */
.dark-mode .filter-tabs {
    backdrop-filter: blur(25rpx);
    -webkit-backdrop-filter: blur(25rpx);
    border-bottom: 1rpx solid rgba(60, 60, 80, 0.4);
    background-color:  #1a1a1a;
  }

  .dark-mode .filter-tab {
    color: #bbb;
    background-color: rgba(50, 50, 65, 0.6);
    border: 1rpx solid rgba(100, 100, 120, 0.4);
    box-shadow: 
      0 3rpx 8rpx rgba(0, 0, 0, 0.3),
      inset 0 1rpx 1px rgba(100, 100, 120, 0.3);
  }

  .dark-mode .filter-tab.active {
    color: #fff;
    background-color: rgba(80, 90, 140, 0.8);
    border: 1rpx solid rgba(140, 150, 200, 0.4);
    box-shadow: 
      0 5rpx 15rpx rgba(0, 0, 0, 0.4),
      inset 0 1rpx 1px rgba(180, 190, 220, 0.4);
  }

  .dark-mode .sub-filter-tabs {
    backdrop-filter: blur(20rpx);
    -webkit-backdrop-filter: blur(20rpx);
    border-bottom: 1rpx solid rgba(60, 60, 80, 0.4);
    background-color: #1a1a1a;
  }

  .dark-mode .sub-filter-tab {
    color: #aaa;
  }
  .dark-mode .sub-filter-tab:active {
    background-color: rgba(60, 60, 75, 0.5);
  }
  
  .dark-mode .sub-filter-tab.active {
    color: #aaa;
  }

  .dark-mode .sub-filter-tab.active::after {
    background-color: #aaa;
    box-shadow: 0 1rpx 3rpx rgba(90, 156, 255, 0.4);
  }

/* 钓友说列表夜间模式 */
.dark-mode .angler-list {
    background-color: rgba(20, 20, 30, 0.6);
}
/* 滚动条样式优化 */
.tabs-scroll::-webkit-scrollbar {
    display: none; /* 隐藏滚动条 */
  }

/* 夜间模式额外效果增强 */
/* .dark-mode .angler-card { */
    /* 添加微弱的发光效果增强深度感 */
    /* filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.5)); */
  /* } */


/* 夜间模式卡片毛玻璃效果 */
.dark-mode .angler-card::before {
    background: rgba(40, 40, 50, 0.75);
    backdrop-filter: blur(30rpx);
    -webkit-backdrop-filter: blur(30rpx);
    border: 1.5rpx solid rgba(100, 100, 120, 0.4);
    box-shadow: 
      0 8rpx 32rpx rgba(0, 0, 0, 0.4),
      0 4rpx 16rpx rgba(0, 0, 0, 0.35),
      inset 0 1rpx 0 rgba(255, 255, 255, 0.1),
      inset 0 -1px 1px rgba(0, 0, 0, 0.3);
  }
  
  /* 夜间模式光泽层 */
  .dark-mode .angler-card::after {
    background: linear-gradient(
      135deg,
      rgba(80, 90, 120, 0.2) 0%,
      rgba(40, 40, 50, 0) 80%
    );
  }
  
  /* 夜间模式卡片悬停效果 */
  .dark-mode .angler-card:hover {
    transform: translateY(-8rpx);
    box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.5);
  }

  /* 夜间模式用户头像 */
.dark-mode .user-avatar {
    border: 1.5rpx solid rgba(100, 100, 120, 0.5);
    box-shadow: 
      0 2rpx 8rpx rgba(0, 0, 0, 0.4),
      inset 0 1rpx 1px rgba(100, 100, 120, 0.3);
  }
  
  /* 夜间模式产品图片 */
  .dark-mode .product-image {
    border: 1rpx solid rgba(80, 80, 100, 0.5);
    box-shadow: 
      0 3rpx 10rpx rgba(0, 0, 0, 0.4),
      inset 0 1rpx 1px rgba(100, 100, 120, 0.3);
  }
  

