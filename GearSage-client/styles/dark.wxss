/* 发布页面夜间模式样式 */
.publish-container.dark-mode {
  background: linear-gradient(to bottom, #1a1a1a, #1a1a1a);
}

.publish-container.dark-mode .publish-header {
  color: #4a9eff;
  background: linear-gradient(180deg, #2d2d2d 0%, #1a1a1a 100%);
}

.publish-container.dark-mode .header-title {
  color: #4a9eff;
  text-shadow: 0 2rpx 8rpx rgba(74, 158, 255, 0.3);
}

.publish-container.dark-mode .header-subtitle {
  color: #b0b0b0;
}

.publish-container.dark-mode .publish-form {
  background: #1a1a1a;
}

.publish-container.dark-mode .wechat-content-section {
  background: #1a1a1a;

}

.publish-container.dark-mode .wechat-title-input {
  color: #ffffff;
  background: transparent;
}

.publish-container.dark-mode .wechat-title-input::placeholder {
  color: #888888;
}

.publish-container.dark-mode .wechat-content-textarea {
  color: #ffffff;
  background: transparent;
}

.publish-container.dark-mode .wechat-content-textarea::placeholder {
  color: #888888;
}

.publish-container.dark-mode .wechat-image-container {
  border-bottom: 1rpx solid #404040;
}

.publish-container.dark-mode .wechat-image-add {
  border: 2rpx dashed #555555;
  background: #3a3a3a;
}

.publish-container.dark-mode .wechat-add-icon {
  color: #888888;
}

.publish-container.dark-mode .form-item {
  background: #1a1a1a;
  border-bottom: 1rpx solid #404040;
}

.publish-container.dark-mode .label-text {
  color: #e0e0e0;
}

.publish-container.dark-mode .required {
  color: #ff6b6b;
}

.publish-container.dark-mode .label-tip {
  color: #888888;
}

.publish-container.dark-mode .form-input {
  color: #ffffff;
  background: transparent;
}

.publish-container.dark-mode .form-input.error {
  color: #ff6b6b;
}

.publish-container.dark-mode .form-picker {
  background: transparent;
}

.publish-container.dark-mode .form-picker.error {
  color: #ff6b6b;
}

.publish-container.dark-mode .picker-text {
  color: #ffffff;
}

.publish-container.dark-mode .picker-text.placeholder {
  color: #888888;
}

.publish-container.dark-mode .form-textarea {
  color: #ffffff;
  background: transparent;
}

.publish-container.dark-mode .form-textarea.error {
  border-color: #ff6b6b;
}

.publish-container.dark-mode .environment-input {
  background: #2a2a2a;
  border: 1px solid #555555;
  color: #ffffff;
}

.publish-container.dark-mode .environment-input::placeholder {
  color: #888888;
}

.publish-container.dark-mode .environment-input.error {
  border-color: #ff6b6b;
}

.publish-container.dark-mode .environment-input:focus {
  border-color: #4a9eff;
  background: #333333;
}

.publish-container.dark-mode .char-count {
  color: #888888;
}

.publish-container.dark-mode .textarea-placeholder {
  color: #888888;
}

.publish-container.dark-mode .recommend-input {
  color: #ffffff;
  background: #3a3a3a;
  border: 1px solid #555555;
}

.publish-container.dark-mode .recommend-input::placeholder {
  color: #888888;
}

.publish-container.dark-mode .recommend-input.error {
  border-color: #ff6b6b;
}

.publish-container.dark-mode .add-btn {
  background: #4a9eff;
  color: #ffffff;
}

.publish-container.dark-mode .delete-btn {
  background: #ff6b6b;
  color: #ffffff;
}

.publish-container.dark-mode .checkbox-item {
  background: #3a3a3a;
  border: 1px solid #555555;
  color: #ffffff;
}

.publish-container.dark-mode .checkbox-item.checked {
  background: #4a9eff;
  border-color: #4a9eff;
}

.publish-container.dark-mode .checkbox-text {
  color: #ffffff;
}

.publish-container.dark-mode .frequency-result {
  color: #b0b0b0;
}

.publish-container.dark-mode .star-rating {
  background: transparent;
}

.publish-container.dark-mode .star-icon {
  color: #555555;
}

.publish-container.dark-mode .star-icon.filled {
  color: #ffd700;
}

.publish-container.dark-mode .btn {
  border: 1px solid #555555;
}

.publish-container.dark-mode .btn-primary {
  background: linear-gradient(135deg, #2c5aa0, #1e3a8a);
  color: #ffffff;
  border-color: #2c5aa0;
}

.publish-container.dark-mode .btn-primary:active {
  background: linear-gradient(135deg, #1e3a8a, #152a62);
}

.publish-container.dark-mode .btn-reset {
  background: transparent;
  border: none;
}

.publish-container.dark-mode .btn-reset:active {
  transform: scale(0.95);
}

.publish-container.dark-mode .reset-icon {
  opacity: 0.8;
}

.publish-container.dark-mode .publish-tips {
  background: #1a1a1a;
  border: 1px solid #1a1a1a;
}

.publish-container.dark-mode .tips-title {
  color: #e0e0e0;
}

.publish-container.dark-mode .tips-arrow {
  color: #b0b0b0;
}

.publish-container.dark-mode .tip-text {
  color: #d0d0d0;
}

.publish-container.dark-mode .error-text {
  color: #ff6b6b;
}

.publish-container.dark-mode .action-buttons {
  background: transparent;
}

/* 详情页面夜间模式样式 */
.container.dark {
  background: linear-gradient(to bottom, #1a1a1a, #2d2d2d);
}

.container.dark .product-info {
  background-color: #2d2d2d;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.container.dark .product-header {
  background: linear-gradient(to right, #404040, #555555);
  border-bottom-color: #404040;
}

.container.dark .product-title {
  color: #ffffff;
}

.container.dark .product-price {
  color: #ff9500;
}

.container.dark .user-info {
  background-color: #2d2d2d;
  border-bottom-color: #404040;
}

/* 夜间模式文字颜色优化 */
.dark-mode .user-name {
    color: #e0e0e0;
  }

.dark-mode .user-tag {
  color: #1a1a1a;
  background-color: #f59e0b;
}

.container.dark .usage-info {
  background-color: #2d2d2d;
  border-bottom-color: #404040;
}

.container.dark .usage-label,
.container.dark .gear-label {
  color: #cccccc;
}

.container.dark .usage-value {
  background-color: #404040;
  color: #ffffff;
}

.container.dark .rating-details {
  background-color: #2d2d2d;
  border-bottom-color: #404040;
}

.container.dark .rating-label {
  color: #cccccc;
}

.container.dark .rating-value {
  color: #ffffff;
}

.container.dark .rating-bar-container {
  background-color: #404040;
}

.container.dark .rating-bar {
  background: linear-gradient(to right, #ff9500, #ffb84d);
}

.container.dark .experience-section,
.container.dark .recommendation-section,
.container.dark .usage-scene-section,
.container.dark .comments-section {
  background-color: #2d2d2d;
  border-bottom-color: #121212;
}

.container.dark .section-title {
  color: #ffffff;
}

.container.dark .experience-content,
.container.dark .usage-scene-description {
  color: #cccccc;
}

.container.dark .environment-tag {
  background-color: #2d2d2d;
  color: #cccccc;
}

.container.dark .recommendation-text {
  color: #cccccc;
}

.container.dark .recommendation-number {
  color: #ff9500;
}

.container.dark .comment-item {
  background-color: #333333;
  border-color: #404040;
}

.container.dark .comment-user {
  color: #ffffff;
}

.container.dark .comment-text {
  color: #cccccc;
}

.container.dark .comment-time {
  color: #888888;
}

.container.dark .bottom-bar {
  background-color: #2d2d2d;
  border-top-color: #404040;
}

.container.dark .bottom-btn {
  color: #cccccc;
}

.container.dark .bottom-btn:active {
  background-color: #404040;
}

/* 搜索页面夜间模式 */
.search-container.dark {
  background-color: #1a1a1a;
  color: #e0e0e0;
}

.search-container.dark .search-input-container {
  background-color: #2d2d2d;
  border-bottom-color: #404040;
}

.search-container.dark .search-input-box {
  background-color: #404040;
}

.search-container.dark .search-icon {
  color: #b0b0b0;
}

.search-container.dark .search-input {
  color: #e0e0e0;
}

.search-container.dark .search-input::placeholder {
  color: #888888;
}

.search-container.dark .clear-btn {
  background-color: #666666;
}

.search-container.dark .loading-text {
  color: #b0b0b0;
}

.search-container.dark .search-results {
  background-color: #2d2d2d;
}

.search-container.dark .results-count {
  color: #b0b0b0;
}

.search-container.dark .result-item {
  border-bottom-color: #404040;
}

.search-container.dark .result-title {
  color: #ffffff;
}

.search-container.dark .result-description {
  color: #b0b0b0;
}

.search-container.dark .result-price {
  color: #ff6b35;
}

.search-container.dark .rating-score {
  color: #b0b0b0;
}

.search-container.dark .empty-title {
  color: #ffffff;
}

.search-container.dark .empty-subtitle {
  color: #b0b0b0;
}

.search-container.dark .history-title,
.search-container.dark .title-text {
  color: #ffffff;
}

.search-container.dark .clear-history {
  color: #b0b0b0;
}

.search-container.dark .history-tag {
  background-color: #404040;
}

.search-container.dark .history-tag:active {
  background-color: #505050;
}

.search-container.dark .hot-tag {
  background-color: #2d2d2d;
  border-color: #404040;
}

.search-container.dark .hot-tag:active {
  background-color: #404040;
}

.search-container.dark .tag-text {
  color: #e0e0e0;
}

.search-container.dark .hot-search-section {
  background-color: #2d2d2d;
}

/* 悬浮发布按钮夜间模式 */
.dark-mode .floating-publish-btn {
  /* 由组件自身处理夜间视觉，这里不再覆盖 */
}

.dark-mode .floating-publish-btn::before {
  /* 移除旧的渐变环绕效果 */
}

.dark-mode .floating-publish-btn:active {
  /* 移除旧的按压态视觉 */
}

.dark-mode .floating-publish-icon {
  /* 移除旧的图标阴影效果 */
}

/* 标签稀有度样式夜间模式 */
.dark .tag-rarity-1 {
  background: linear-gradient(135deg, #4a4a4a, #5a5a5a) !important;
  color: #e0e0e0 !important;
  border: 1px solid #666666 !important;
}

.dark .tag-rarity-2 {
  background: linear-gradient(135deg, #1e3a8a, #3b82f6) !important;
  color: #ffffff !important;
  border: 1px solid #60a5fa !important;
}

.dark .tag-rarity-3 {
  background: linear-gradient(135deg, #ea580c, #f97316) !important;
  color: #ffffff !important;
  border: 1px solid #fb923c !important;
}

.dark .tag-rarity-4 {
  background: linear-gradient(135deg, #b45309, #d97706, #f59e0b) !important;
  color: #1a1a1a !important;
  border: 1px solid #fbbf24 !important;
  box-shadow: 0 0 10px rgba(251, 191, 36, 0.3) !important;
}