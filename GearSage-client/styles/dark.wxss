/* 夜间模式样式 */

/* 基础容器 */
.dark {
  background-color: #121212 !important;
  color: #e0e0e0 !important;
}

/* 个人资料页面夜间模式 */
.dark .profile-container {
  background-color: #121212;
}

/* 加载状态 */
.dark .loading-container {
  background-color: #121212;
}

.dark .loading-text {
  color: #ffffff;
}

/* 登录提示 */
.dark .login-prompt {
  background-color: #121212;
}

.dark .login-content {
  background-color: #1e1e1e;
  border: 1px solid #333;
}

.dark .login-title {
  color: #ffffff;
}

.dark .login-subtitle {
  color: #cccccc;
}

.dark .login-btn {
  background: linear-gradient(135deg, #2c5aa0, #1a4480);
}

.dark .login-btn-text {
  color: #ffffff;
}

/* 用户信息区域 */
.dark .user-section {
  background-color: #1e1e1e;
  border: 1px solid #333;
}

.dark .user-name {
