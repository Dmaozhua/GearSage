# =========================
# GearSage API 环境变量模板
# =========================

# 运行端口
PORT=3001

# 应用名
APP_NAME=gearsage-api-local

# 环境名
NODE_ENV=development

# =========================
# 数据库
# =========================
# 本地开发推荐使用 SSH 隧道转发：
# ssh -L 5433:127.0.0.1:5432 root@你的服务器IP
#
# 然后本机连：
# 127.0.0.1:5433

DATABASE_URL=postgresql://gearsage_app:YOUR_DB_PASSWORD@127.0.0.1:5433/gearsage

# =========================
# JWT
# =========================
JWT_ACCESS_SECRET=YOUR_ACCESS_SECRET
JWT_ACCESS_EXPIRES_IN=2h

JWT_REFRESH_SECRET=YOUR_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# =========================
# API 域名
# =========================
API_BASE_URL=https://api.gearsage.club

# =========================
# 短信登录（第一阶段可不接真实短信）
# =========================
SMS_ENABLED=false

# 测试验证码模式
SMS_TEST_MODE=true
SMS_TEST_CODE=123456

# 如果后续接真实短信服务，再补以下变量
SMS_PROVIDER=
SMS_SECRET_ID=
SMS_SECRET_KEY=
SMS_APP_ID=
SMS_SIGN_NAME=
SMS_TEMPLATE_ID=

# =========================
# COS 对象存储（后续上传模块使用）
# =========================
COS_ENABLED=false

COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
COS_PUBLIC_BASE_URL=https://static.gearsage.club

# =========================
# 上传
# =========================
UPLOAD_MAX_SIZE_MB=20
UPLOAD_DIR=/lhcos-data/gearsage
UPLOAD_BASE_URL=https://static.gearsage.club/gearsage

# =========================
# 管理后台（预留）
# =========================
ADMIN_INIT_USERNAME=
ADMIN_INIT_PASSWORD=

# =========================
# 日志（预留）
# =========================
LOG_LEVEL=debug
